#!/bin/sh
# Publish a Nostr-backed page draft.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

page_slug=$(blog_nostr_page_slug "$(blog_param page_slug)")
if [ -z "$page_slug" ]; then
  page_slug=$(blog_nostr_page_slug "$(blog_param list_slug)")
fi
if [ -z "$page_slug" ]; then
  blog_json_error "page_slug is required" "missing_page_slug"
  exit 0
fi

page_type=$(blog_nostr_page_type_for_slug "$page_slug" 2>/dev/null || printf '')
if [ -z "$page_type" ]; then
  blog_json_error "Unknown Nostr page slug" "unknown_page"
  exit 0
fi

existing_draft_state=$(blog_nostr_page_load_draft_state_json "$page_slug" "$page_type" 2>/dev/null || printf '')
draft_extras_json='{"extras_before":"","extras_before_format":"markdown","extras_after":"","extras_after_format":"markdown"}'
if [ -n "$existing_draft_state" ]; then
  draft_extras_json=$(printf '%s\n' "$existing_draft_state" | jq -c '{
    extras_before: (.extras_before // ""),
    extras_before_format: ((.extras_before_format // "markdown") | ascii_downcase | if . == "html" then "html" else "markdown" end),
    extras_after: (.extras_after // ""),
    extras_after_format: ((.extras_after_format // "markdown") | ascii_downcase | if . == "html" then "html" else "markdown" end)
  }' 2>/dev/null || printf '{"extras_before":"","extras_before_format":"markdown","extras_after":"","extras_after_format":"markdown"}')
fi

state_json=$(blog_nostr_page_load_draft_state_json "$page_slug" "$page_type" 2>/dev/null || printf '')
if [ -z "$state_json" ]; then
  case "$page_type" in
    contact)
      canonical_event=$(blog_nostr_contact_latest_event_json 2>/dev/null || printf '')
      if [ -n "$canonical_event" ]; then
        state_json=$(blog_contact_state_from_event_json "$page_slug" "$canonical_event")
      else
        state_json=$(blog_contact_default_state_json "$page_slug")
      fi
      ;;
    *)
      state_json=$(blog_list_load_canonical_state_json "$page_slug")
      ;;
  esac
fi

case "$page_type" in
  contact)
    state_json=$(blog_contact_normalize_state_json "$page_slug" "$state_json")
    validation_json=$(blog_contact_validate_and_enrich_state_json "$state_json" true)
    can_publish=$(printf '%s\n' "$validation_json" | jq -r '.can_publish' 2>/dev/null || printf 'false')
    if [ "$can_publish" != "true" ]; then
      jq -cn --argjson validation "$validation_json" '{
        success: false,
        error: "Validation failed",
        code: "validation_failed",
        validation: {
          errors: $validation.errors,
          warnings: $validation.warnings,
          can_publish: false
        }
      }'
      printf '\n'
      exit 0
    fi
    content_json=$(printf '%s\n' "$validation_json" | jq -c '.content_json // {}' 2>/dev/null || printf '{}')
    event_json=$(blog_nostr_sign_contact_event "$content_json" 2>/dev/null || printf '')
    if [ -z "$event_json" ]; then
      reason=$(blog_nostr_publish_diagnostic 2>/dev/null || printf '')
      if [ -z "$reason" ]; then
        reason="Could not sign contact page event."
      fi
      blog_json_error "$reason" "nostr_publish_failed"
      exit 0
    fi
    canonical_state_json=$(blog_contact_state_from_event_json "$page_slug" "$event_json")
    canonical_state_json=$(printf '%s\n' "$canonical_state_json" | jq -c --argjson extras "$draft_extras_json" '. + $extras')
    validation_after=$(blog_contact_validate_and_enrich_state_json "$canonical_state_json" false)
    canonical_enriched=$(printf '%s\n' "$canonical_state_json" | jq -c --argjson validation "$validation_after" '. + {rows: $validation.rows, content_json: $validation.content_json}')
    ;;
  *)
    state_json=$(blog_list_normalize_state_json "$page_slug" "$state_json")
    validation_json=$(blog_list_validate_and_enrich_state_json "$state_json" true)
    can_publish=$(printf '%s\n' "$validation_json" | jq -r '.can_publish' 2>/dev/null || printf 'false')
    if [ "$can_publish" != "true" ]; then
      jq -cn --argjson validation "$validation_json" '{
        success: false,
        error: "Validation failed",
        code: "validation_failed",
        validation: {
          errors: $validation.errors,
          warnings: $validation.warnings,
          can_publish: false
        }
      }'
      printf '\n'
      exit 0
    fi
    content=$(printf '%s\n' "$state_json" | jq -r '.content // ""' 2>/dev/null || printf '')
    tags_json=$(printf '%s\n' "$state_json" | jq -c '.tags // []' 2>/dev/null || printf '[]')
    event_json=$(blog_nostr_sign_list_event "$page_slug" "$content" "$tags_json" 2>/dev/null || printf '')
    if [ -z "$event_json" ]; then
      reason=$(blog_nostr_publish_diagnostic 2>/dev/null || printf '')
      if [ -z "$reason" ]; then
        reason="Could not sign list page event."
      fi
      blog_json_error "$reason" "nostr_publish_failed"
      exit 0
    fi
    canonical_state_json=$(blog_list_state_from_event_json "$page_slug" "$event_json")
    canonical_state_json=$(printf '%s\n' "$canonical_state_json" | jq -c --argjson extras "$draft_extras_json" '. + $extras')
    validation_after=$(blog_list_validate_and_enrich_state_json "$canonical_state_json" false)
    canonical_enriched=$(printf '%s\n' "$canonical_state_json" | jq -c --argjson validation "$validation_after" '. + {elements: $validation.elements, entries: $validation.entries}')
    ;;
esac

pubkey=$(printf '%s\n' "$event_json" | jq -r '.pubkey // empty' 2>/dev/null || printf '')
author_count=$(blog_nostr_list_file_lines "$blog_nostr_authors_file" | wc -l | tr -d ' ')
if [ "${author_count:-0}" -eq 0 ] && [ -n "$pubkey" ]; then
  blog_nostr_append_author_if_missing "$pubkey" >/dev/null 2>&1 || true
fi
if [ -n "$pubkey" ] && ! blog_nostr_author_allowed "$pubkey"; then
  blog_json_error "Publisher pubkey is not allowed by site author policy" "nostr_author_not_allowed"
  exit 0
fi

if ! blog_nostr_store_event_json "$event_json" >/dev/null 2>&1; then
  blog_json_error "Could not store published event" "store_failed"
  exit 0
fi

blog_nostr_page_save_draft_state_json "$page_slug" "$page_type" "$canonical_state_json"

event_id=$(printf '%s\n' "$event_json" | jq -r '.id // ""' 2>/dev/null || printf '')

jq -cn \
  --arg slug "$page_slug" \
  --arg page_type "$page_type" \
  --arg event_id "$event_id" \
  --argjson state "$canonical_enriched" \
  --argjson validation "$validation_after" \
  '{
    success: true,
    slug: $slug,
    page_type: $page_type,
    event_id: $event_id,
    state: $state,
    validation: {
      errors: $validation.errors,
      warnings: $validation.warnings,
      can_publish: $validation.can_publish
    },
    message: "Published to Nostr."
  }'
printf '\n'
