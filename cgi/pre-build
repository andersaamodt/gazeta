#!/bin/sh
# Prepare derived site artifacts before build.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
if [ -z "${WIZARDRY_SITES_DIR:-}" ] || [ -z "${WIZARDRY_SITE_NAME:-}" ]; then
  script_site_root=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
  : "${WIZARDRY_SITES_DIR:=$(dirname "$script_site_root")}"
  : "${WIZARDRY_SITE_NAME:=$(basename "$script_site_root")}"
  export WIZARDRY_SITES_DIR WIZARDRY_SITE_NAME
fi
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"
. "$SCRIPT_DIR/blog-video-chat-schedule-common.sh"

blog_init
pages_json=$(blog_nostr_pages_load_json)
blog_nostr_pages_sync_source_pages "$pages_json"
blog_nostr_pages_prune_clean_url_build_dirs "$pages_json"
blog_public_posts_catalog_write_artifacts

site_title=$(config-get "$blog_site_conf" site_title 2>/dev/null || printf '')
theme=$(config-get "$blog_site_conf" theme 2>/dev/null || printf '')
append_site_title_to_page_title=$(config-get "$blog_site_conf" append_site_title_to_page_title 2>/dev/null || printf 'false')
plugins_json=$(blog_plugins_json)
video_chat_participant_limit=$(config-get "$blog_site_conf" video_chat_participant_limit 2>/dev/null || printf '6')
case "$video_chat_participant_limit" in ''|*[!0-9]*) video_chat_participant_limit=6 ;; esac
if [ "$video_chat_participant_limit" -lt 2 ]; then video_chat_participant_limit=2; fi
if [ "$video_chat_participant_limit" -gt 24 ]; then video_chat_participant_limit=24; fi
video_chat_token_ttl_seconds=$(config-get "$blog_site_conf" video_chat_token_ttl_seconds 2>/dev/null || printf '3600')
case "$video_chat_token_ttl_seconds" in ''|*[!0-9]*) video_chat_token_ttl_seconds=3600 ;; esac
if [ "$video_chat_token_ttl_seconds" -lt 60 ]; then video_chat_token_ttl_seconds=60; fi
if [ "$video_chat_token_ttl_seconds" -gt 86400 ]; then video_chat_token_ttl_seconds=86400; fi
video_chat_public_rooms=$(config-get "$blog_site_conf" video_chat_public_rooms 2>/dev/null || printf 'false')
case "$video_chat_public_rooms" in true|false) ;; *) video_chat_public_rooms=false ;; esac
video_chat_rooms=$(config-get "$blog_site_conf" video_chat_rooms 2>/dev/null || printf '')
video_chat_scheduled_rooms=$(config-get "$blog_site_conf" video_chat_scheduled_rooms 2>/dev/null || printf '')
video_chat_schedule_now=$(blog_video_chat_schedule_now_epoch)
video_chat_rooms_json=$(blog_video_chat_public_rooms_json "$video_chat_rooms" "$video_chat_scheduled_rooms" "$video_chat_schedule_now")
video_chat_manual_rooms_json=$(blog_video_chat_manual_rooms_json "$video_chat_rooms" "$video_chat_schedule_now")
video_chat_room_theme_images_json=$(blog_video_chat_room_theme_images_json "$video_chat_rooms" "$video_chat_scheduled_rooms" "$video_chat_schedule_now")
video_chat_janus_wss=$(config-get "$blog_site_conf" video_chat_janus_wss 2>/dev/null || printf '')
video_chat_signaling_wss=$(config-get "$blog_site_conf" video_chat_signaling_wss 2>/dev/null || printf '')
video_chat_json=$(jq -cn \
  --argjson participant_limit "$video_chat_participant_limit" \
  --argjson token_ttl_seconds "$video_chat_token_ttl_seconds" \
  --arg janus_wss "$video_chat_janus_wss" \
  --arg signaling_wss "$video_chat_signaling_wss" \
  --argjson public_rooms "$video_chat_public_rooms" \
  --argjson rooms "$video_chat_rooms_json" \
  --argjson manual_rooms "$video_chat_manual_rooms_json" \
  --arg room_settings "$(printf '%s\n' "$video_chat_rooms" | tr ';,' '\n\n')" \
  --arg scheduled_rooms "$(printf '%s\n' "$video_chat_scheduled_rooms" | tr ';' '\n')" \
  --argjson room_theme_images "$video_chat_room_theme_images_json" \
  '{participant_limit:$participant_limit,token_ttl_seconds:$token_ttl_seconds,janus_wss:$janus_wss,signaling_wss:$signaling_wss,public_rooms:$public_rooms,rooms:$rooms,manual_rooms:$manual_rooms,active_rooms:$rooms,room_settings:$room_settings,scheduled_rooms:$scheduled_rooms,room_theme_images:$room_theme_images,include_syntax:"{{video-chat}}"}')
navbar_json=$(blog_nostr_navbar_pages_json "$pages_json")
footer_json=$(blog_nostr_footer_pages_json "$pages_json")
navbar_pages_json=$(printf '%s\n' "$navbar_json" | jq -c '.pages // []' 2>/dev/null || printf '[]')
footer_pages_json=$(printf '%s\n' "$footer_json" | jq -c '.pages // []' 2>/dev/null || printf '[]')

[ -n "$site_title" ] || site_title='Site'
[ -n "$theme" ] || theme='archmage'
case "$append_site_title_to_page_title" in
  true|false) ;;
  *) append_site_title_to_page_title=false ;;
esac

site_bootstrap_dir="$blog_site_root/site/static"
build_bootstrap_dir="$blog_site_root/build/static"
navbar_json_path="$site_bootstrap_dir/navbar-pages.json"
footer_json_path="$site_bootstrap_dir/footer-pages.json"
site_bootstrap_path="$site_bootstrap_dir/site-bootstrap.js"
build_navbar_json_path="$build_bootstrap_dir/navbar-pages.json"
build_footer_json_path="$build_bootstrap_dir/footer-pages.json"
build_site_bootstrap_path="$build_bootstrap_dir/site-bootstrap.js"
mkdir -p "$site_bootstrap_dir"
mkdir -p "$build_bootstrap_dir"
navbar_json_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-navbar-pages-json.XXXXXX")
footer_json_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-footer-pages-json.XXXXXX")
site_bootstrap_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-site-bootstrap.XXXXXX")
printf '%s\n' "$navbar_json" > "$navbar_json_tmp"
mv "$navbar_json_tmp" "$navbar_json_path"
chmod 644 "$navbar_json_path" 2>/dev/null || true
cp "$navbar_json_path" "$build_navbar_json_path"
chmod 644 "$build_navbar_json_path" 2>/dev/null || true
printf '%s\n' "$footer_json" > "$footer_json_tmp"
mv "$footer_json_tmp" "$footer_json_path"
chmod 644 "$footer_json_path" 2>/dev/null || true
cp "$footer_json_path" "$build_footer_json_path"
chmod 644 "$build_footer_json_path" 2>/dev/null || true
cat > "$site_bootstrap_tmp" <<EOF
(function () {
  var bootstrap = {
    config: {
      site_title: "$(blog_json_escape "$site_title")",
      append_site_title_to_page_title: $append_site_title_to_page_title,
      theme: "$(blog_json_escape "$theme")",
      plugins: $plugins_json,
      video_chat: $video_chat_json
    },
    navbar_pages: $navbar_pages_json,
    footer_pages: $footer_pages_json
  };
  window.__wizardrySiteBootstrap = bootstrap;
  try {
    localStorage.setItem('wizardry_blog_site_title_v1', bootstrap.config.site_title || 'Site');
    localStorage.setItem('wizardry_blog_append_site_title_to_page_title_v1', bootstrap.config.append_site_title_to_page_title ? '1' : '0');
    localStorage.setItem('wizardry_blog_theme_v1', bootstrap.config.theme || 'archmage');
    localStorage.setItem('wizardry_plugins_v1', JSON.stringify(bootstrap.config.plugins || {}));
    localStorage.setItem('cached_navbar_pages_v1', JSON.stringify(bootstrap.navbar_pages || []));
    localStorage.setItem('cached_footer_pages_v1', JSON.stringify(bootstrap.footer_pages || []));
  } catch (_err) {
    // Ignore storage failures.
  }
})();
EOF
mv "$site_bootstrap_tmp" "$site_bootstrap_path"
chmod 644 "$site_bootstrap_path" 2>/dev/null || true
cp "$site_bootstrap_path" "$build_site_bootstrap_path"
chmod 644 "$build_site_bootstrap_path" 2>/dev/null || true

write_local_embed_bootstraps() {
  mkdir -p "$site_bootstrap_dir/nostr-page-bootstrap"
  printf '%s\n' "$pages_json" | jq -r '.pages[]? | select((.type // "") == "overworld") | (.slug // "")' 2>/dev/null | while IFS= read -r local_slug || [ -n "$local_slug" ]; do
    local_slug=$(blog_nostr_page_slug "$local_slug")
    [ -n "$local_slug" ] || continue
    local_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-local-embed-bootstrap.XXXXXX")
    {
      printf '%s\n' '(function () {'
      printf '%s\n' '  window.__wizardryNostrPageBootstrap = window.__wizardryNostrPageBootstrap || {};'
      printf '  window.__wizardryNostrPageBootstrap[%s] = {' "$(printf '%s\n' "$local_slug" | jq -R .)"
      printf 'success:true,slug:%s,page_type:"overworld",local_embed:true' "$(printf '%s\n' "$local_slug" | jq -R .)"
      printf '%s\n' '};'
      printf '%s\n' '})();'
    } > "$local_tmp"
    mv "$local_tmp" "$site_bootstrap_dir/nostr-page-bootstrap/$local_slug.js"
    chmod 644 "$site_bootstrap_dir/nostr-page-bootstrap/$local_slug.js" 2>/dev/null || true
  done
}

write_local_embed_bootstraps

if [ -x "$SCRIPT_DIR/blog-prerender-nostr-page-bootstraps" ]; then
  prerender_timeout=${BLOG_NOSTR_PAGE_PRERENDER_TIMEOUT_SECONDS-}
  [ -n "$prerender_timeout" ] || prerender_timeout=$(config-get "$blog_site_conf" nostr_page_prerender_timeout_seconds 2>/dev/null || printf '25')
  case "$prerender_timeout" in ''|*[!0-9]*) prerender_timeout=25 ;; esac
  if [ "$prerender_timeout" -lt 1 ]; then prerender_timeout=1; fi
  if [ "$prerender_timeout" -gt 300 ]; then prerender_timeout=300; fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$prerender_timeout" "$SCRIPT_DIR/blog-prerender-nostr-page-bootstraps" <<'PY' || true
import subprocess
import sys

timeout = int(sys.argv[1])
cmd = sys.argv[2:]
try:
    subprocess.run(cmd, timeout=timeout, check=False)
except subprocess.TimeoutExpired:
    pass
PY
  else
    "$SCRIPT_DIR/blog-prerender-nostr-page-bootstraps" || true
  fi
  if [ -d "$site_bootstrap_dir/nostr-page-bootstrap" ]; then
    rm -rf "$build_bootstrap_dir/nostr-page-bootstrap"
    mkdir -p "$build_bootstrap_dir"
    cp -R "$site_bootstrap_dir/nostr-page-bootstrap" "$build_bootstrap_dir/nostr-page-bootstrap"
    find "$build_bootstrap_dir/nostr-page-bootstrap" -type f -exec chmod 644 {} \; 2>/dev/null || true
  fi
fi
