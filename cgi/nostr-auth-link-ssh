#!/bin/sh
# Link an SSH public key to the currently logged-in Nostr-backed account.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/ssh-auth-lib.sh"
. "$SCRIPT_DIR/blog-overworld-common.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session false true; then
  exit 0
fi

pubkey=$(blog_get_nostr_pubkey "$BLOG_SESSION_USERNAME" 2>/dev/null || printf '')
if [ -z "$pubkey" ]; then
  blog_json_error "Account has no bound Nostr pubkey" "nostr_identity_required"
  exit 0
fi

ssh_public_key=$(blog_param ssh_public_key)
ssh_public_key=$(ssh_auth_normalize_public_key "$ssh_public_key" 2>/dev/null || printf '')
if [ -z "$ssh_public_key" ]; then
  blog_json_error "Invalid SSH public key format" "invalid_ssh_public_key"
  exit 0
fi

ssh_fingerprint=$(ssh_auth_compute_fingerprint "$ssh_public_key")
blog_set_user_ssh_key "$BLOG_SESSION_USERNAME" "$ssh_public_key" "$ssh_fingerprint"
overworld_account=$(blog_overworld_get_profile_value "$BLOG_SESSION_USERNAME" overworld_ssh_username)
if [ -n "$overworld_account" ] && blog_overworld_validate_account_name "$overworld_account" && blog_overworld_account_exists "$overworld_account"; then
  blog_overworld_sync_authorized_key "$BLOG_SESSION_USERNAME" "$overworld_account" >/dev/null 2>&1 || true
fi

printf '{"success":true,'
printf '"username":"%s",' "$(blog_json_escape "$BLOG_SESSION_USERNAME")"
printf '"nostr_pubkey":"%s",' "$(blog_json_escape "$pubkey")"
printf '"ssh_fingerprint":"%s"' "$(blog_json_escape "$ssh_fingerprint")"
printf '}\n'
