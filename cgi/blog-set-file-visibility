#!/bin/sh
# Set attachment public/private state (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

file_id=$(blog_param file_id)
make_public=$(blog_param make_public)
record_path=$(blog_file_record_path "$file_id" 2>/dev/null || printf '')
if [ -z "$file_id" ] || [ ! -f "$record_path" ]; then
  blog_json_error "File not found" "not_found"
  exit 0
fi

case "$make_public" in
  true|1|yes|on) explicit_public=true ;;
  false|0|no|off|'') explicit_public=false ;;
  *)
    blog_json_error "Invalid visibility value" "invalid_visibility"
    exit 0
    ;;
esac

config-set "$record_path" explicit_public "$explicit_public"
config-set "$record_path" updated_at "$(blog_now_iso)"
safe_name=$(config-get "$record_path" safe_name 2>/dev/null || printf '')
effective_public=false
if blog_file_is_public_effective "$file_id"; then
  effective_public=true
fi
printf '{"success":true,"file_id":"%s","explicit_public":%s,"effective_public":%s,"url":"%s"}\n' \
  "$(blog_json_escape "$file_id")" \
  "$explicit_public" \
  "$effective_public" \
  "$(blog_json_escape "$(blog_file_public_url_encoded "$file_id" "$safe_name")")"
