#!/bin/sh
# Save draft / queue / publish post (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

action=$(blog_param action)
draft_id=$(blog_param draft_id)
title=$(blog_param title)
tags=$(blog_param tags)
summary=$(blog_param summary)
content=$(blog_param content)
publish_mode=$(blog_param publish_mode)
scheduled_at=$(blog_param scheduled_at)
post_type=$(blog_param post_type)
visibility=$(blog_param visibility)
existing_publish_mode=""
existing_status=""
source_post_path=$(blog_param source_post_path)

if [ -z "$action" ]; then
  case "$visibility" in
    public) action=publish_now ;;
    *) action=save_draft ;;
  esac
fi

if [ -z "$publish_mode" ]; then
  case "$action" in
    queue_scheduled) publish_mode=scheduled ;;
    queue_drip) publish_mode=drip ;;
    publish_now) publish_mode=immediate ;;
    *) publish_mode=draft ;;
  esac
fi

if [ -n "$draft_id" ] && blog_draft_exists "$draft_id"; then
  draft_file=$(blog_draft_resolve_file_path "$draft_id" 2>/dev/null || printf '')
  if [ -z "$draft_file" ] || [ ! -f "$draft_file" ]; then
    blog_json_error "Draft not found" "not_found"
    exit 0
  fi
  if [ -z "$title" ]; then
    title=$(blog_read_front_matter_value "$draft_file" title 2>/dev/null || printf '')
  fi
  if [ -z "$tags" ]; then
    tags=$(blog_read_front_matter_value "$draft_file" tags 2>/dev/null || printf '')
  fi
  if [ -z "$summary" ]; then
    summary=$(blog_read_front_matter_value "$draft_file" summary 2>/dev/null || printf '')
  fi
  if [ -z "$content" ]; then
    content=$(blog_read_markdown_body "$draft_file" 2>/dev/null || printf '')
  fi
  if [ -z "$scheduled_at" ]; then
    scheduled_at=$(blog_read_front_matter_value "$draft_file" scheduled_at 2>/dev/null || printf '')
  fi
  if [ -z "$post_type" ]; then
    post_type=$(blog_read_front_matter_value "$draft_file" post_type 2>/dev/null || printf '')
  fi
  if [ -z "$post_type" ]; then
    post_type=$(blog_read_front_matter_value "$draft_file" type 2>/dev/null || printf '')
  fi
  if [ -z "$source_post_path" ]; then
    source_post_path=$(blog_read_front_matter_value "$draft_file" source_post_path 2>/dev/null || printf '')
  fi
  existing_publish_mode=$(blog_read_front_matter_value "$draft_file" publish_mode 2>/dev/null || printf '')
  existing_status=$(blog_read_front_matter_value "$draft_file" status 2>/dev/null || printf '')
fi

if [ -z "$title" ]; then
  title="Untitled Draft"
fi
if [ -z "$draft_id" ]; then
  draft_id=$(blog_new_draft_id)
fi

# Summary is generated automatically from content for now.
summary=$(blog_auto_summary_from_content "$content")

normalized_tags=$(blog_normalize_tags "$tags")
post_type=$(blog_normalize_post_type "$post_type")
author_name=$(blog_get_player_name "$BLOG_SESSION_USERNAME" 2>/dev/null || printf '%s' "$BLOG_SESSION_USERNAME")

case "$action" in
  publish_now)
    if [ -z "$content" ]; then
      blog_json_error "Content is required to publish" "content_required"
      exit 0
    fi

    if ! filename=$(blog_publish_content "$title" "$normalized_tags" "$summary" "$content" "$author_name" "$draft_id" immediate "" "$post_type" "$source_post_path"); then
      if blog_nostr_bridge_enabled; then
        reason=$(blog_nostr_publish_diagnostic 2>/dev/null || printf '')
        if [ -n "$reason" ]; then
          blog_json_error "Publish failed: $reason Disable Nostr Bridge in Site Settings if you want local-only publishing." "nostr_publish_failed"
        else
          blog_json_error "Publish failed. Check Nostr bridge key/relay configuration." "nostr_publish_failed"
        fi
      else
        blog_json_error "Publish failed." "publish_failed"
      fi
      exit 0
    fi
    if blog_draft_exists "$draft_id"; then
      blog_delete_draft "$draft_id"
    fi
    blog_run_build_async
    publish_message="Post published"
    if [ "${BLOG_PUBLISH_LAST_MODE-}" = "local_fallback" ]; then
      publish_message="Post published locally. Nostr bridge signing is not configured, so this post was not signed/pushed as a Nostr event."
    fi
    printf '{"success":true,"message":"%s","filename":"%s","draft_id":"%s","publish_mode_used":"%s"}\n' \
      "$(blog_json_escape "$publish_message")" \
      "$(blog_json_escape "$filename")" \
      "$(blog_json_escape "$draft_id")" \
      "$(blog_json_escape "${BLOG_PUBLISH_LAST_MODE-unknown}")"
    ;;

  queue_scheduled)
    if [ -z "$scheduled_at" ]; then
      blog_json_error "scheduled_at is required for scheduled posts" "scheduled_at_required"
      exit 0
    fi
    if [ -z "$content" ]; then
      blog_json_error "Content is required" "content_required"
      exit 0
    fi
    blog_save_draft "$draft_id" "$title" "$normalized_tags" "$summary" "$content" "$author_name" scheduled "$scheduled_at" scheduled "$post_type" "$source_post_path"
    printf '{"success":true,"message":"Draft scheduled","draft_id":"%s","status":"scheduled"}\n' "$(blog_json_escape "$draft_id")"
    ;;

  queue_drip)
    if [ -z "$content" ]; then
      blog_json_error "Content is required" "content_required"
      exit 0
    fi
    blog_save_draft "$draft_id" "$title" "$normalized_tags" "$summary" "$content" "$author_name" drip "" queued "$post_type" "$source_post_path"
    printf '{"success":true,"message":"Draft queued for drip","draft_id":"%s","status":"queued"}\n' "$(blog_json_escape "$draft_id")"
    ;;

  autosave|save_draft|save)
    status=draft
    if [ "$publish_mode" = "immediate" ]; then
      publish_mode=draft
    fi
    # Preserve existing queued/scheduled state during autosave so release mode does not silently downgrade.
    if [ "$action" = "autosave" ]; then
      if [ "$existing_publish_mode" = "drip" ] && [ "$existing_status" = "queued" ]; then
        publish_mode=drip
        status=queued
        scheduled_at=""
      elif [ "$existing_publish_mode" = "scheduled" ] && [ "$existing_status" = "scheduled" ]; then
        publish_mode=scheduled
        status=scheduled
      fi
    fi
    # Saving a normal draft should not queue/schedule until explicit publish action.
    if [ "$status" = "draft" ] && { [ "$publish_mode" = "scheduled" ] || [ "$publish_mode" = "drip" ]; }; then
      publish_mode=draft
    fi
    blog_save_draft "$draft_id" "$title" "$normalized_tags" "$summary" "$content" "$author_name" "$publish_mode" "$scheduled_at" "$status" "$post_type" "$source_post_path"
    printf '{"success":true,"message":"Draft saved","draft_id":"%s","status":"%s","autosaved":%s}\n' \
      "$(blog_json_escape "$draft_id")" "$status" "$( [ "$action" = "autosave" ] && printf true || printf false )"
    ;;

  *)
    blog_json_error "Unknown action" "invalid_action"
    ;;
esac
