#!/bin/sh
# List public blog posts for the Blog page filter UI.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_send_json_headers

static_catalog=$(blog_public_posts_catalog_static_path)
cache_file=$(blog_public_posts_catalog_cache_path)

if [ -f "$static_catalog" ]; then
  cat "$static_catalog"
  exit 0
fi

if [ -f "$cache_file" ]; then
  cat "$cache_file"
  exit 0
fi

catalog_json=$(blog_public_posts_catalog_build_json)
printf '%s\n' "$catalog_json"

cache_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-public-posts-cache.XXXXXX")
printf '%s\n' "$catalog_json" > "$cache_tmp"
mv "$cache_tmp" "$cache_file"
chmod 644 "$cache_file" 2>/dev/null || true
