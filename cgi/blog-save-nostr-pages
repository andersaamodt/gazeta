#!/bin/sh
# Save local Nostr page configuration (navbar/order/type/slug references).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi
if ! blog_plugin_enabled "nostr_posts"; then
  blog_json_error "Nostr-backed pages plugin is disabled for this site" "plugin_disabled"
  exit 0
fi

pages_json=$(blog_param pages_json)
if [ -z "$pages_json" ]; then
  blog_json_error "pages_json is required" "missing_pages_json"
  exit 0
fi

if ! printf '%s\n' "$pages_json" | jq -e 'type=="array" or type=="object"' >/dev/null 2>&1; then
  blog_json_error "pages_json must be JSON array/object" "invalid_pages_json"
  exit 0
fi

raw_cfg=$(jq -cn --argjson pages "$pages_json" '{pages: (if ($pages|type)=="array" then $pages else ($pages.pages // []) end)}')
normalized=$(blog_nostr_pages_normalize_json "$raw_cfg")

contact_count=$(printf '%s\n' "$normalized" | jq -r '[.pages[] | select(.type=="contact")] | length' 2>/dev/null || printf '0')
case "$contact_count" in
  ''|*[!0-9]*) contact_count=0 ;;
  *) ;;
esac
if [ "$contact_count" -gt 1 ]; then
  blog_json_error "Only one user metadata page is supported (kind 0 is replaceable by pubkey)" "contact_page_limit"
  exit 0
fi

blog_nostr_pages_sync_source_pages "$normalized"

blog_nostr_pages_save_json "$normalized"
blog_run_build_async

jq -cn --argjson cfg "$normalized" '{
  success: true,
  pages: ($cfg.pages // []),
  message: "Nostr page configuration saved locally. Site rebuild queued."
}'
printf '\n'
