#!/bin/sh
# List publish queue (scheduled + drip).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi


state=$(blog_scheduler_state)
last_drip=$(config-get "$state" last_drip_epoch 2>/dev/null || printf '0')
interval_hours=$(blog_drip_interval_hours)
interval_minutes=$(blog_drip_interval_minutes)
interval_seconds=$(blog_drip_interval_seconds)
randomness=$(blog_drip_randomness_minutes)
case "$last_drip" in ''|*[!0-9]*) last_drip=0 ;; esac

next_drip_epoch=$((last_drip + interval_seconds))
if [ "$last_drip" -eq 0 ]; then
  next_drip_epoch=0
fi

schedule_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-queue.XXXXXX")
blog_find_draft_files | while IFS= read -r draft_file; do
  draft_id=$(blog_read_front_matter_value "$draft_file" draft_id 2>/dev/null || printf '')
  [ -n "$draft_id" ] || continue
  title=$(blog_read_front_matter_value "$draft_file" title 2>/dev/null || printf '')
  post_type=$(blog_read_front_matter_value "$draft_file" post_type 2>/dev/null || printf '')
  if [ -z "$post_type" ]; then
    post_type=$(blog_read_front_matter_value "$draft_file" type 2>/dev/null || printf '')
  fi
  post_type=$(blog_normalize_post_type "$post_type")
  mode=$(blog_read_front_matter_value "$draft_file" publish_mode 2>/dev/null || printf 'draft')
  status=$(blog_read_front_matter_value "$draft_file" status 2>/dev/null || printf 'draft')
  created_at=$(blog_read_front_matter_value "$draft_file" created_at 2>/dev/null || printf '')
  scheduled_at=$(blog_read_front_matter_value "$draft_file" scheduled_at 2>/dev/null || printf '')
  content=$(blog_read_markdown_body "$draft_file" 2>/dev/null || printf '')
  content_excerpt=$(blog_auto_summary_from_content "$content")
  title=$(blog_effective_post_title "$title" "$content" "$post_type")

  case "$mode:$status" in
    scheduled:scheduled)
      sort_key=$(blog_iso_to_epoch "$scheduled_at")
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$sort_key" "$draft_id" "$title" "$mode" "$status" "$scheduled_at" "$content_excerpt"
      ;;
    drip:queued)
      sort_key=$(blog_iso_to_epoch "$created_at")
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$sort_key" "$draft_id" "$title" "$mode" "$status" "" "$content_excerpt"
      ;;
  esac
done | sort -n > "$schedule_tmp"

tab=$(printf '\t')
printf '{"success":true,'
printf '"drip_interval_hours":%s,' "$interval_hours"
printf '"drip_interval_minutes":%s,' "$interval_minutes"
printf '"drip_randomness_minutes":%s,' "$randomness"
printf '"drip_jitter_minutes":%s,' "$randomness"
printf '"next_drip_epoch":%s,' "$next_drip_epoch"
printf '"queue":['

first=1
while IFS="$tab" read -r _ draft_id title mode status scheduled_at content_excerpt; do
  [ -n "$draft_id" ] || continue
  if [ "$first" -eq 0 ]; then
    printf ','
  fi
  first=0
  printf '{'
  printf '"draft_id":"%s",' "$(blog_json_escape "$draft_id")"
  printf '"title":"%s",' "$(blog_json_escape "$title")"
  printf '"publish_mode":"%s",' "$(blog_json_escape "$mode")"
  printf '"status":"%s",' "$(blog_json_escape "$status")"
  printf '"scheduled_at":"%s",' "$(blog_json_escape "$scheduled_at")"
  printf '"content_excerpt":"%s"' "$(blog_json_escape "$content_excerpt")"
  printf '}'
done < "$schedule_tmp"

printf ']}\n'
rm -f "$schedule_tmp"
