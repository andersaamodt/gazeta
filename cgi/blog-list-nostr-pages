#!/bin/sh
# List configured Nostr-backed pages for admin management.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi
if ! blog_plugin_enabled "nostr_posts"; then
  blog_json_error "Nostr-backed pages plugin is disabled for this site" "plugin_disabled"
  exit 0
fi

cfg=$(blog_nostr_pages_load_json)
if ! printf '%s\n' "$cfg" | jq -e '.pages | type=="array"' >/dev/null 2>&1; then
  cfg=$(blog_nostr_pages_default_json 2>/dev/null || printf '{"pages":[]}')
fi
rows_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-pages-rows.XXXXXX")
if ! printf '%s\n' "$cfg" | jq -c '.pages[]?' > "$rows_tmp" 2>/dev/null; then
  : > "$rows_tmp"
fi
blog_posts_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-page-posts.XXXXXX")
blog_tags_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-page-tags.XXXXXX")
blog_collect_public_posts "$blog_posts_tmp" 2>/dev/null || : > "$blog_posts_tmp"
connected_posts_total=$(wc -l < "$blog_posts_tmp" | tr -d ' ')
case "$connected_posts_total" in
  ''|*[!0-9]*) connected_posts_total=0 ;;
esac
while IFS= read -r file || [ -n "$file" ]; do
  [ -n "$file" ] || continue
  [ -f "$file" ] || continue
  tags_raw=$(blog_read_front_matter_value "$file" tags 2>/dev/null || printf '')
  tags_csv=$(printf '%s' "$tags_raw" | sed "s/^\\[//;s/\\]$//;s/\\\"//g;s/'//g")
  tags=$(blog_normalize_tags "$tags_csv")
  if [ -n "$tags" ]; then
    printf '%s\n' "$tags" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | awk 'NF { print }' >> "$blog_tags_tmp"
  fi
done < "$blog_posts_tmp"

available_tags_json='[]'
if [ -s "$blog_tags_tmp" ]; then
  available_tags_json=$(LC_ALL=C sort -fu "$blog_tags_tmp" | jq -Rcs 'split("\n") | map(select(length > 0))' 2>/dev/null || printf '[]')
fi

printf '{"success":true,"available_tags":'
printf '%s' "$available_tags_json"
printf ',"pages":['
first=1
while IFS= read -r row || [ -n "$row" ]; do
  [ -n "$row" ] || continue
  slug=$(printf '%s\n' "$row" | jq -r '.slug // ""' 2>/dev/null || printf '')
  page_type=$(printf '%s\n' "$row" | jq -r '.type // "list"' 2>/dev/null || printf 'list')
  kind=$(printf '%s\n' "$row" | jq -r '.kind // 30004' 2>/dev/null || printf '30004')
  path=$(printf '%s\n' "$row" | jq -r '.path // (if .slug=="index" then "/" else ("/" + .slug) end)' 2>/dev/null || { [ "$slug" = "index" ] && printf "/" || printf "/%s" "$slug"; })
  show_in_nav=$(printf '%s\n' "$row" | jq -r 'if (if has("show_in_nav") then .show_in_nav else true end) then "true" else "false" end' 2>/dev/null || printf 'true')
  default_tag=$(printf '%s\n' "$row" | jq -r '.default_tag // ""' 2>/dev/null || printf '')
  placeholder_title=$(printf '%s\n' "$row" | jq -r '.placeholder_title // ""' 2>/dev/null || printf '')
  draft_title=''
  draft_differs=false
  draft_state_json=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || printf '')
  if [ -n "$draft_state_json" ]; then
    draft_title=$(printf '%s\n' "$draft_state_json" | jq -r '.title // ""' 2>/dev/null || printf '')
  fi

  canonical_state_json=''
  canonical_title=''
  canonical_exists=false
  connected_posts=0
  case "$page_type" in
  contact)
    canonical_event=$(blog_nostr_contact_latest_event_json 2>/dev/null || printf '')
    if [ -n "$canonical_event" ]; then
      canonical_exists=true
      canonical_title=$(printf '%s\n' "$canonical_event" | jq -r 'try (.content | fromjson | .title // "") catch ""' 2>/dev/null || printf '')
      canonical_state_json=$(blog_contact_state_from_event_json "$slug" "$canonical_event")
    else
      canonical_state_json=$(blog_contact_default_state_json "$slug")
    fi
    ;;
  nip23)
    canonical_event=$(blog_nostr_nip23_latest_event_json "$slug" 2>/dev/null || printf '')
    if [ -n "$canonical_event" ]; then
      canonical_exists=true
      canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      canonical_state_json=$(blog_nip23_state_from_event_json "$slug" "$canonical_event" "$page_type")
    else
      canonical_state_json=$(blog_nip23_default_state_json "$slug" "$page_type")
    fi
    ;;
  public-ranking)
    canonical_event=$(blog_nostr_public_ranking_latest_event_json "$slug" 2>/dev/null || printf '')
    if [ -n "$canonical_event" ]; then
      canonical_exists=true
      canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      canonical_state_json=$(blog_public_ranking_state_from_event_json "$slug" "$canonical_event")
    else
      canonical_state_json=$(blog_public_ranking_default_state_json "$slug")
    fi
    ;;
  blog)
    connected_posts=$connected_posts_total
    canonical_event=$(blog_nostr_nip23_latest_event_json "$slug" 2>/dev/null || printf '')
    if [ -n "$canonical_event" ]; then
      canonical_exists=true
      canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      canonical_state_json=$(blog_nip23_state_from_event_json "$slug" "$canonical_event" "$page_type")
    else
      canonical_state_json=$(blog_nip23_default_state_json "$slug" "$page_type")
    fi
    ;;
  *)
    canonical_event=$(blog_nostr_list_latest_event_json "$slug" 2>/dev/null || printf '')
    if [ -n "$canonical_event" ]; then
      canonical_exists=true
      canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      canonical_state_json=$(blog_list_state_from_event_json "$slug" "$canonical_event")
    else
      canonical_state_json=$(blog_list_default_state_json "$slug")
    fi
    ;;
  esac

  if [ -n "$draft_state_json" ]; then
    draft_sig=''
    canonical_sig=''
    case "$page_type" in
      contact)
        draft_sig=$(blog_contact_state_signature_json "$draft_state_json" 2>/dev/null || printf '')
        canonical_sig=$(blog_contact_state_signature_json "$canonical_state_json" 2>/dev/null || printf '')
        ;;
      public-ranking)
        draft_sig=$(blog_public_ranking_state_signature_json "$draft_state_json" 2>/dev/null || printf '')
        canonical_sig=$(blog_public_ranking_state_signature_json "$canonical_state_json" 2>/dev/null || printf '')
        ;;
      nip23|blog)
        draft_sig=$(blog_nip23_state_signature_json "$draft_state_json" 2>/dev/null || printf '')
        canonical_sig=$(blog_nip23_state_signature_json "$canonical_state_json" 2>/dev/null || printf '')
        ;;
      *)
        draft_sig=$(blog_list_state_signature_json "$draft_state_json" 2>/dev/null || printf '')
        canonical_sig=$(blog_list_state_signature_json "$canonical_state_json" 2>/dev/null || printf '')
        ;;
    esac
    if [ -n "$draft_sig" ] && [ "$draft_sig" != "$canonical_sig" ]; then
      draft_differs=true
    fi
  fi

  title=$draft_title
  if [ -z "$title" ]; then
    title=$canonical_title
  fi
  if [ -z "$title" ]; then
    title=$placeholder_title
  fi
  if [ -z "$title" ]; then
    title=$(blog_nostr_page_titleize_slug "$slug")
  fi

  if [ "$first" -eq 0 ]; then
    printf ','
  fi
  first=0
  row_json=$(jq -cn \
    --arg slug "$slug" \
    --arg page_type "$page_type" \
    --arg path "$path" \
    --arg title "$title" \
    --arg placeholder_title "$placeholder_title" \
    --arg default_tag "$default_tag" \
    --arg kind "$kind" \
    --arg connected_posts "$connected_posts" \
    --arg show_in_nav "$show_in_nav" \
    --arg canonical_exists "$canonical_exists" \
    --arg draft_differs "$draft_differs" \
    '{
      slug: $slug,
      type: $page_type,
      kind: ($kind | tonumber? // 30004),
      path: $path,
      title: $title,
      placeholder_title: $placeholder_title,
      default_tag: $default_tag,
      connected_posts: ($connected_posts | tonumber? // 0),
      show_in_nav: ($show_in_nav == "true"),
      canonical_exists: ($canonical_exists == "true"),
      draft_differs: ($draft_differs == "true")
    }' 2>/dev/null || printf '')
  if [ -z "$row_json" ]; then
    row_json=$(printf '{"slug":"%s","type":"%s","kind":30004,"path":"%s","title":"%s","placeholder_title":"%s","default_tag":"%s","connected_posts":0,"show_in_nav":true,"canonical_exists":false,"draft_differs":false}' \
      "$(blog_json_escape "$slug")" \
      "$(blog_json_escape "$page_type")" \
      "$(blog_json_escape "$path")" \
      "$(blog_json_escape "$title")" \
      "$(blog_json_escape "$placeholder_title")" \
      "$(blog_json_escape "$default_tag")")
  fi
  printf '%s' "$row_json"
done < "$rows_tmp"
printf ']}'
printf '\n'

rm -f "$rows_tmp" "$blog_posts_tmp" "$blog_tags_tmp"
