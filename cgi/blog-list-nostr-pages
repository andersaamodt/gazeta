#!/bin/sh
# List configured Nostr-backed pages for admin management.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi

cfg=$(blog_nostr_pages_load_json)
rows_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-pages-rows.XXXXXX")
printf '%s\n' "$cfg" | jq -c '.pages[]' > "$rows_tmp"
blog_posts_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-page-posts.XXXXXX")
blog_tags_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-page-tags.XXXXXX")
blog_collect_public_posts "$blog_posts_tmp"
connected_posts_total=$(wc -l < "$blog_posts_tmp" | tr -d ' ')
case "$connected_posts_total" in
  ''|*[!0-9]*) connected_posts_total=0 ;;
esac
while IFS= read -r file || [ -n "$file" ]; do
  [ -n "$file" ] || continue
  [ -f "$file" ] || continue
  tags_raw=$(blog_read_front_matter_value "$file" tags 2>/dev/null || printf '')
  tags_csv=$(printf '%s' "$tags_raw" | sed "s/^\\[//;s/\\]$//;s/\\\"//g;s/'//g")
  tags=$(blog_normalize_tags "$tags_csv")
  if [ -n "$tags" ]; then
    printf '%s\n' "$tags" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | awk 'NF { print }' >> "$blog_tags_tmp"
  fi
done < "$blog_posts_tmp"

available_tags_json='[]'
if [ -s "$blog_tags_tmp" ]; then
  available_tags_json=$(LC_ALL=C sort -fu "$blog_tags_tmp" | jq -Rcs 'split("\n") | map(select(length > 0))' 2>/dev/null || printf '[]')
fi

printf '{"success":true,"available_tags":'
printf '%s' "$available_tags_json"
printf ',"pages":['
first=1
while IFS= read -r row || [ -n "$row" ]; do
  [ -n "$row" ] || continue
  slug=$(printf '%s\n' "$row" | jq -r '.slug // ""' 2>/dev/null || printf '')
  page_type=$(printf '%s\n' "$row" | jq -r '.type // "list"' 2>/dev/null || printf 'list')
  kind=$(printf '%s\n' "$row" | jq -r '.kind // 30004' 2>/dev/null || printf '30004')
  path=$(printf '%s\n' "$row" | jq -r '.path // (if .slug=="index" then "/" else ("/" + .slug) end)' 2>/dev/null || { [ "$slug" = "index" ] && printf "/" || printf "/%s" "$slug"; })
  show_in_nav=$(printf '%s\n' "$row" | jq -r 'if (if has("show_in_nav") then .show_in_nav else true end) then "true" else "false" end' 2>/dev/null || printf 'true')
  default_tag=$(printf '%s\n' "$row" | jq -r '.default_tag // ""' 2>/dev/null || printf '')
  placeholder_title=$(printf '%s\n' "$row" | jq -r '.placeholder_title // ""' 2>/dev/null || printf '')
  draft_title=''
  draft_state_json=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || printf '')
  if [ -n "$draft_state_json" ]; then
    draft_title=$(printf '%s\n' "$draft_state_json" | jq -r '.title // ""' 2>/dev/null || printf '')
  fi

  canonical_title=''
  canonical_exists=false
  connected_posts=0
  case "$page_type" in
    contact)
      canonical_event=$(blog_nostr_contact_latest_event_json 2>/dev/null || printf '')
      if [ -n "$canonical_event" ]; then
        canonical_exists=true
        canonical_title=$(printf '%s\n' "$canonical_event" | jq -r 'try (.content | fromjson | .title // "") catch ""' 2>/dev/null || printf '')
      fi
      ;;
    nip23)
      canonical_event=$(blog_nostr_nip23_latest_event_json "$slug" 2>/dev/null || printf '')
      if [ -n "$canonical_event" ]; then
        canonical_exists=true
        canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      fi
      ;;
    public-ranking)
      canonical_event=$(blog_nostr_public_ranking_latest_event_json "$slug" 2>/dev/null || printf '')
      if [ -n "$canonical_event" ]; then
        canonical_exists=true
        canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      fi
      ;;
    blog)
      connected_posts=$connected_posts_total
      ;;
    *)
      canonical_event=$(blog_nostr_list_latest_event_json "$slug" 2>/dev/null || printf '')
      if [ -n "$canonical_event" ]; then
        canonical_exists=true
        canonical_title=$(printf '%s\n' "$canonical_event" | jq -r '([.tags[]? | select(type=="array" and length>=2 and .[0]=="title") | .[1]] | first) // ""' 2>/dev/null || printf '')
      fi
      ;;
  esac

  title=$draft_title
  if [ -z "$title" ]; then
    title=$canonical_title
  fi
  if [ -z "$title" ]; then
    title=$placeholder_title
  fi
  if [ -z "$title" ]; then
    title=$(blog_nostr_page_titleize_slug "$slug")
  fi

  if [ "$first" -eq 0 ]; then
    printf ','
  fi
  first=0
  jq -cn \
    --arg slug "$slug" \
    --arg page_type "$page_type" \
    --arg path "$path" \
    --arg title "$title" \
    --arg placeholder_title "$placeholder_title" \
    --arg default_tag "$default_tag" \
    --argjson kind "$kind" \
    --argjson connected_posts "$connected_posts" \
    --argjson show_in_nav "$( [ "$show_in_nav" = "true" ] && printf true || printf false )" \
    --argjson canonical_exists "$( [ "$canonical_exists" = "true" ] && printf true || printf false )" \
    '{
      slug: $slug,
      type: $page_type,
      kind: $kind,
      path: $path,
      title: $title,
      placeholder_title: $placeholder_title,
      default_tag: $default_tag,
      connected_posts: $connected_posts,
      show_in_nav: $show_in_nav,
      canonical_exists: $canonical_exists
    }'
done < "$rows_tmp"
printf ']}'
printf '\n'

rm -f "$rows_tmp" "$blog_posts_tmp" "$blog_tags_tmp"
