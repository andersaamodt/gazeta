#!/bin/sh
# Public list of Nostr-backed pages shown in navbar.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_send_json_headers

cfg=$(blog_nostr_pages_load_json)
all_rows_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-all-pages.XXXXXX")
printf '%s\n' "$cfg" | jq -c '.pages[]' > "$all_rows_tmp"
rows_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-navbar-pages.XXXXXX")
printf '%s\n' "$cfg" | jq -c '.pages[] | select((if has("show_in_nav") then .show_in_nav else true end) == true)' > "$rows_tmp"

needs_build=false
while IFS= read -r row || [ -n "$row" ]; do
  [ -n "$row" ] || continue
  slug=$(printf '%s\n' "$row" | jq -r '.slug // ""' 2>/dev/null || printf '')
  page_type=$(printf '%s\n' "$row" | jq -r '.type // "list"' 2>/dev/null || printf 'list')
  blog_nostr_page_ensure_source_page "$slug" "$page_type" >/dev/null 2>&1 || true
  case "$slug" in
    index) html_file="$blog_site_root/build/pages/index.html" ;;
    *) html_file="$blog_site_root/build/pages/$slug.html" ;;
  esac
  if [ ! -f "$html_file" ]; then
    needs_build=true
  fi
done < "$all_rows_tmp"

printf '{"success":true,"pages":['
first=1
while IFS= read -r row || [ -n "$row" ]; do
  [ -n "$row" ] || continue
  slug=$(printf '%s\n' "$row" | jq -r '.slug // ""' 2>/dev/null || printf '')
  page_type=$(printf '%s\n' "$row" | jq -r '.type // "list"' 2>/dev/null || printf 'list')
  kind=$(printf '%s\n' "$row" | jq -r '.kind // 30004' 2>/dev/null || printf '30004')
  path=$(blog_nostr_page_public_path "$slug")
  placeholder_title=$(printf '%s\n' "$row" | jq -r '.placeholder_title // ""' 2>/dev/null || printf '')

  title=$placeholder_title
  if [ -z "$title" ]; then
    title=$(blog_nostr_page_canonical_title "$slug" "$page_type" 2>/dev/null || printf '')
  fi
  if [ -z "$title" ]; then
    title=$(blog_nostr_page_default_title "$slug" "$page_type")
  fi

  if [ "$first" -eq 0 ]; then
    printf ','
  fi
  first=0
  jq -cn \
    --arg slug "$slug" \
    --arg title "$title" \
    --arg path "$path" \
    --arg page_type "$page_type" \
    --argjson kind "$kind" \
    '{
      slug: $slug,
      title: $title,
      path: $path,
      type: $page_type,
      kind: $kind
    }'
done < "$rows_tmp"
printf ']}'
printf '\n'

if [ "$needs_build" = "true" ]; then
  blog_run_build_async
fi

rm -f "$all_rows_tmp"
rm -f "$rows_tmp"
