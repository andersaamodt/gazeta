#!/bin/sh
# Public list of Nostr-backed pages shown in navbar.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_send_json_headers

cache_file="$blog_state_dir/navbar-pages-cache.json"
cache_ttl_seconds=120
now_epoch=$(date +%s 2>/dev/null || printf '0')
cache_mtime=0
cache_is_fresh=false

file_mtime_epoch() {
  file_path=$1
  mtime=$(stat -c '%Y' "$file_path" 2>/dev/null || printf '')
  case "$mtime" in
    ''|*[!0-9]*) mtime=$(stat -f '%m' "$file_path" 2>/dev/null || printf '') ;;
  esac
  mtime=$(printf '%s\n' "$mtime" | sed -n '1p')
  case "$mtime" in
    ''|*[!0-9]*) mtime=0 ;;
  esac
  printf '%s\n' "$mtime"
}

if [ -f "$cache_file" ]; then
  cache_mtime=$(file_mtime_epoch "$cache_file")
fi
if [ -f "$cache_file" ] && [ -n "$cache_mtime" ] && [ "$cache_mtime" -gt 0 ] && [ $((now_epoch - cache_mtime)) -le "$cache_ttl_seconds" ]; then
  cache_is_fresh=true
fi

cfg=$(blog_nostr_pages_load_json)

trigger_maintenance_async() {
  trigger_stamp="$blog_state_dir/navbar-build-trigger.epoch"
  now_trigger=$(date +%s 2>/dev/null || printf '0')
  last_epoch=$(sed -n '1p' "$trigger_stamp" 2>/dev/null | tr -cd '0-9' || printf '0')
  if [ -z "$last_epoch" ]; then
    last_epoch=0
  fi
  # Throttle expensive sync/build maintenance while keeping responses fast.
  if [ $((now_trigger - last_epoch)) -lt 30 ]; then
    return 0
  fi
  printf '%s\n' "$now_trigger" > "$trigger_stamp" 2>/dev/null || true
  (
    blog_nostr_pages_sync_source_pages "$cfg" >/dev/null 2>&1 || true
    blog_run_build_async >/dev/null 2>&1 || true
  ) >/dev/null 2>&1 &
}

if [ "$cache_is_fresh" = "true" ]; then
  cat "$cache_file"
  trigger_maintenance_async
else
  nav_pages_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-navbar-pages.XXXXXX")
  printf '%s\n' "$cfg" | jq -r '.pages[]? | [(.slug // ""), (.type // "list"), (.placeholder_title // ""), (if has("show_in_nav") then .show_in_nav else true end)] | @tsv' 2>/dev/null > "$nav_pages_tmp"
  nav_items_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-navbar-items.XXXXXX")
  while IFS="$(printf '\t')" read -r raw_slug raw_type raw_title raw_show || [ -n "$raw_slug" ]; do
    slug=$(blog_nostr_page_slug "$raw_slug")
    [ -n "$slug" ] || continue
    page_type=$(printf '%s' "$raw_type" | tr '[:upper:]' '[:lower:]')
    case "$raw_show" in
      false|FALSE|False|0) continue ;;
      *) ;;
    esac

    if [ "$slug" = "index" ] && [ "$page_type" = "nip23" ]; then
      index_event=$(blog_nostr_nip23_latest_event_json "$slug" 2>/dev/null || printf '')
      index_draft=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || printf '')
      if [ -z "$index_event" ] && [ -z "$index_draft" ]; then
        continue
      fi
    fi

    placeholder_title=$(printf '%s' "$raw_title" | tr -d '\r')
    if [ -n "$placeholder_title" ]; then
      title=$placeholder_title
    else
      title=$(blog_nostr_page_titleize_slug "$slug")
    fi
    if [ "$slug" = "index" ]; then
      path='/'
    else
      path="/$slug"
    fi
    kind=$(blog_nostr_page_kind_for_type "$page_type")
    jq -cn \
      --arg slug "$slug" \
      --arg title "$title" \
      --arg path "$path" \
      --arg type "$page_type" \
      --argjson kind "$kind" \
      '{slug:$slug,title:$title,path:$path,type:$type,kind:$kind}' >> "$nav_items_tmp"
  done < "$nav_pages_tmp"

  nav_json=$(jq -cn --slurpfile pages "$nav_items_tmp" '{success:true,pages: ($pages // [])}')
  rm -f "$nav_pages_tmp" "$nav_items_tmp"
  if [ -z "$nav_json" ]; then
    nav_json='{"success":true,"pages":[]}'
  fi
  printf '%s\n' "$nav_json"

  cache_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-navbar-cache.XXXXXX")
  printf '%s\n' "$nav_json" > "$cache_tmp"
  mv "$cache_tmp" "$cache_file"
  chmod 644 "$cache_file" 2>/dev/null || true
  trigger_maintenance_async
fi
