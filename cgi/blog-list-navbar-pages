#!/bin/sh
# Public list of Nostr-backed pages shown in navbar.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_send_json_headers

cache_file="$blog_state_dir/navbar-pages-cache.json"
cache_ttl_seconds=120
now_epoch=$(date +%s 2>/dev/null || printf '0')
cache_mtime=0
if [ -f "$cache_file" ]; then
  cache_mtime=$(stat -f '%m' "$cache_file" 2>/dev/null || stat -c '%Y' "$cache_file" 2>/dev/null || printf '0')
fi
if [ -f "$cache_file" ] && [ -n "$cache_mtime" ] && [ "$cache_mtime" -gt 0 ] && [ $((now_epoch - cache_mtime)) -le "$cache_ttl_seconds" ]; then
  cat "$cache_file"
  exit 0
fi

cfg=$(blog_nostr_pages_load_json)
all_slugs_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-all-slugs.XXXXXX")
printf '%s\n' "$cfg" | jq -r '.pages[]? | (.slug // "")' 2>/dev/null > "$all_slugs_tmp"

needs_build=false
while IFS= read -r raw_slug || [ -n "$raw_slug" ]; do
  slug=$(blog_nostr_page_slug "$raw_slug")
  [ -n "$slug" ] || continue
  case "$slug" in
    index) html_file="$blog_site_root/build/pages/index.html" ;;
    *) html_file="$blog_site_root/build/pages/$slug.html" ;;
  esac
  if [ ! -f "$html_file" ]; then
    needs_build=true
    break
  fi
done < "$all_slugs_tmp"

nav_json=$(printf '%s\n' "$cfg" | jq -c '
  def title_from_slug($s):
    (($s // "") | tostring | gsub("-"; " ")) as $t
    | if ($t | length) == 0 then
        "Untitled"
      else
        (($t[0:1] | ascii_upcase) + ($t[1:]))
      end;
  {
    success: true,
    pages: [
      .pages[]?
      | (.slug // "" | tostring) as $slug
      | select(($slug | length) > 0)
      | select((if has("show_in_nav") then .show_in_nav else true end) == true)
      | {
          slug: $slug,
          title: (
            (.placeholder_title // "" | tostring) as $placeholder
            | if ($placeholder | length) > 0 then
                $placeholder
              elif $slug == "index" then
                "Home"
              else
                title_from_slug($slug)
              end
          ),
          path: (if $slug == "index" then "/" else ("/" + $slug) end),
          type: (.type // "list" | tostring),
          kind: ((.kind // 30004) | tonumber? // 30004)
        }
    ]
  }
' 2>/dev/null || printf '{"success":true,"pages":[]}')
printf '%s\n' "$nav_json"

cache_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-navbar-cache.XXXXXX")
printf '%s\n' "$nav_json" > "$cache_tmp"
mv "$cache_tmp" "$cache_file"
chmod 644 "$cache_file" 2>/dev/null || true

if [ "$needs_build" = "true" ]; then
  trigger_stamp="$blog_state_dir/navbar-build-trigger.epoch"
  now_epoch=$(date +%s 2>/dev/null || printf '0')
  last_epoch=$(sed -n '1p' "$trigger_stamp" 2>/dev/null | tr -cd '0-9' || printf '0')
  if [ -z "$last_epoch" ]; then
    last_epoch=0
  fi
  # Avoid hot-loop build spawning from public traffic when output is temporarily missing.
  if [ $((now_epoch - last_epoch)) -ge 30 ]; then
    printf '%s\n' "$now_epoch" > "$trigger_stamp" 2>/dev/null || true
    (
      blog_nostr_pages_sync_source_pages "$cfg" >/dev/null 2>&1 || true
      blog_run_build_async >/dev/null 2>&1 || true
    ) >/dev/null 2>&1 &
  fi
fi

rm -f "$all_slugs_tmp"
