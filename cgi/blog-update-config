#!/bin/sh
# Update blog configuration (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"
. "$SCRIPT_DIR/blog-overworld-common.sh"
. "$SCRIPT_DIR/blog-video-chat-schedule-common.sh"

blog_init
blog_overworld_setup
blog_read_request_body
blog_send_json_headers
config_before=$(cat "$blog_site_conf" 2>/dev/null || printf '')
zaps_config_changed=false

if ! blog_require_session true true; then
  exit 0
fi

registration_enabled=$(blog_param registration_enabled)
site_title=$(blog_param site_title)
theme=$(blog_param theme)
drip_interval_hours=$(blog_param drip_interval_hours)
drip_interval_minutes_legacy=$(blog_param drip_interval_minutes)
drip_randomness=$(blog_param drip_randomness_minutes)
drip_jitter_legacy=$(blog_param drip_jitter_minutes)
feed_full_text=$(blog_param feed_full_text)
feed_items=$(blog_param feed_items)
append_site_title_to_page_title=$(blog_param append_site_title_to_page_title)
nostr_bridge_enabled=$(blog_param nostr_bridge_enabled)
new_users_are_admins=$(blog_param new_users_are_admins)
zaps_enabled=$(blog_param zaps_enabled)
zap_lud16=$(blog_param zap_lud16)
zap_default_amount_sats=$(blog_param zap_default_amount_sats)
nostr_lists_update=$(blog_param nostr_lists_update)
nostr_authors=$(blog_param nostr_authors)
nostr_relays=$(blog_param nostr_relays)
nostr_blocklist=$(blog_param nostr_blocklist)
plugin_nostr_support=$(blog_param plugin_nostr_support)
plugin_nostr_login=$(blog_param plugin_nostr_login)
plugin_nostr_bridge=$(blog_param plugin_nostr_bridge)
plugin_nostr_posts=$(blog_param plugin_nostr_posts)
plugin_zaps=$(blog_param plugin_zaps)
plugin_btcpay=$(blog_param plugin_btcpay)
plugin_video_chat=$(blog_param plugin_video_chat)
plugin_overworld=$(blog_param plugin_overworld)
video_chat_participant_limit=$(blog_param video_chat_participant_limit)
video_chat_token_ttl_seconds=$(blog_param video_chat_token_ttl_seconds)
video_chat_janus_wss=$(blog_param video_chat_janus_wss)
video_chat_signaling_wss=$(blog_param video_chat_signaling_wss)
video_chat_public_rooms=$(blog_param video_chat_public_rooms)
video_chat_rooms=$(blog_param video_chat_rooms)
video_chat_scheduled_rooms=$(blog_param video_chat_scheduled_rooms)
overworld_anonymous_enabled=$(blog_param overworld_anonymous_enabled)
overworld_anonymous_time_limit_seconds=$(blog_param overworld_anonymous_time_limit_seconds)
overworld_show_hidden=$(blog_param overworld_show_hidden)
overworld_start_path=$(blog_param overworld_start_path)
overworld_access_mode=$(blog_param overworld_access_mode)
overworld_max_entries=$(blog_param overworld_max_entries)
origin_enabled_platforms=$(blog_param origin_enabled_platforms)
origin_default_platforms=$(blog_param origin_default_platforms)

write_nostr_lines_file() {
  target_file=$1
  raw_value=$2
  tmp_file=$(mktemp "${TMPDIR:-/tmp}/blog-nostr-list-write.XXXXXX")
  printf '%s' "$raw_value" | tr '\r' '\n' | sed -e 's/#.*$//' -e 's/[[:space:]]\+$//' -e 's/^[[:space:]]*//' | awk 'NF { if (!seen[$0]++) print $0; }' > "$tmp_file"
  mv "$tmp_file" "$target_file"
  chmod 644 "$target_file" 2>/dev/null || true
}

if [ -n "$registration_enabled" ]; then
  case "$registration_enabled" in
    true|false) config-set "$blog_site_conf" registration_enabled "$registration_enabled" ;;
  esac
fi

case "$BLOG_REQUEST_BODY" in
  *site_title=*)
    if [ -n "$site_title" ]; then
      config-set "$blog_site_conf" site_title "$site_title"
    else
      config-set "$blog_site_conf" site_title "Site"
    fi
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *zaps_enabled=*|*zap_lud16=*|*plugin_zaps=*|*plugin_nostr_support=*)
    zaps_config_changed=true
    ;;
esac

if [ -n "$theme" ]; then
  case "$theme" in
    adept|alchemist|archmage|chronomancer|conjurer|druid|empath|enchanter|geomancer|hermeticist|hierophant|illusionist|lapidarist|lich|necromancer|pyromancer|seer|shaman|sorcerer|sorceress|technomancer|thaumaturge|thelemite|theurgist|wadjet|warlock|wizard)
      config-set "$blog_site_conf" theme "$theme"
      ;;
  esac
fi

if [ -n "$drip_interval_hours" ] || [ -n "$drip_interval_minutes_legacy" ]; then
  interval_hours_value=
  if [ -n "$drip_interval_hours" ]; then
    if blog_is_positive_decimal "$drip_interval_hours"; then
      interval_hours_value=$drip_interval_hours
    fi
  elif [ -n "$drip_interval_minutes_legacy" ]; then
    case "$drip_interval_minutes_legacy" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$drip_interval_minutes_legacy" -lt 1 ]; then
          drip_interval_minutes_legacy=1
        fi
        interval_hours_value=$(awk -v m="$drip_interval_minutes_legacy" 'BEGIN { printf "%.4f", m / 60 }')
        ;;
    esac
  fi

  if [ -n "$interval_hours_value" ]; then
    normalized_hours=$(awk -v h="$interval_hours_value" 'BEGIN { min_h = 1.0 / 60.0; x = h + 0; if (x < min_h) x = min_h; printf "%.4f", x }')
    normalized_hours=$(blog_format_decimal "$normalized_hours")
    interval_minutes=$(awk -v h="$normalized_hours" 'BEGIN { m = int(h * 60 + 0.5); if (m < 1) m = 1; print m }')
    config-set "$blog_site_conf" drip_interval_hours "$normalized_hours"
    config-set "$blog_site_conf" drip_interval_minutes "$interval_minutes"
  fi
fi

if [ -n "$drip_randomness" ] || [ -n "$drip_jitter_legacy" ]; then
  randomness_value=$drip_randomness
  if [ -z "$randomness_value" ]; then
    randomness_value=$drip_jitter_legacy
  fi
  case "$randomness_value" in
    ''|*[!0-9]*) ;;
    *)
      config-set "$blog_site_conf" drip_randomness_minutes "$randomness_value"
      config-set "$blog_site_conf" drip_jitter_minutes "$randomness_value"
      ;;
  esac
fi

if [ -n "$feed_full_text" ]; then
  case "$feed_full_text" in
    true|false) config-set "$blog_site_conf" feed_full_text "$feed_full_text" ;;
  esac
fi

if [ -n "$feed_items" ]; then
  case "$feed_items" in
    ''|*[!0-9]*) ;;
    *)
      if [ "$feed_items" -lt 1 ]; then
        feed_items=1
      fi
      config-set "$blog_site_conf" feed_items "$feed_items"
      ;;
  esac
fi

if [ -n "$append_site_title_to_page_title" ]; then
  case "$append_site_title_to_page_title" in
    true|false) config-set "$blog_site_conf" append_site_title_to_page_title "$append_site_title_to_page_title" ;;
  esac
fi

if [ -n "$nostr_bridge_enabled" ]; then
  case "$nostr_bridge_enabled" in
    true|false)
      config-set "$blog_site_conf" nostr_bridge_enabled "$nostr_bridge_enabled"
      if [ "$nostr_bridge_enabled" = "true" ]; then
        blog_nostr_rebuild_derived >/dev/null 2>&1 || true
      fi
      ;;
  esac
fi

if [ -n "$new_users_are_admins" ]; then
  case "$new_users_are_admins" in
    true|false) config-set "$blog_site_conf" new_users_are_admins "$new_users_are_admins" ;;
  esac
fi

if [ -n "$zaps_enabled" ]; then
  case "$zaps_enabled" in
    true|false) config-set "$blog_site_conf" zaps_enabled "$zaps_enabled" ;;
  esac
fi

set_plugin_flag() {
  key=$1
  value=$2
  case "$value" in
    true|false)
      config-set "$blog_site_conf" "plugin_$key" "$value"
      ;;
  esac
}

set_plugin_flag "nostr_support" "$plugin_nostr_support"
set_plugin_flag "nostr_login" "$plugin_nostr_login"
set_plugin_flag "nostr_bridge" "$plugin_nostr_bridge"
set_plugin_flag "nostr_posts" "$plugin_nostr_posts"
set_plugin_flag "zaps" "$plugin_zaps"
set_plugin_flag "btcpay" "$plugin_btcpay"
set_plugin_flag "video_chat" "$plugin_video_chat"
set_plugin_flag "overworld" "$plugin_overworld"

case "$BLOG_REQUEST_BODY" in
  *video_chat_participant_limit=*)
    case "$video_chat_participant_limit" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$video_chat_participant_limit" -lt 2 ]; then
          video_chat_participant_limit=2
        fi
        if [ "$video_chat_participant_limit" -gt 24 ]; then
          video_chat_participant_limit=24
        fi
        config-set "$blog_site_conf" video_chat_participant_limit "$video_chat_participant_limit"
        ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *video_chat_token_ttl_seconds=*)
    case "$video_chat_token_ttl_seconds" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$video_chat_token_ttl_seconds" -lt 60 ]; then
          video_chat_token_ttl_seconds=60
        fi
        if [ "$video_chat_token_ttl_seconds" -gt 86400 ]; then
          video_chat_token_ttl_seconds=86400
        fi
        config-set "$blog_site_conf" video_chat_token_ttl_seconds "$video_chat_token_ttl_seconds"
        ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *video_chat_janus_wss=*)
    case "$video_chat_janus_wss" in
      ''|wss://*|ws://*) config-set "$blog_site_conf" video_chat_janus_wss "$video_chat_janus_wss" ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *video_chat_signaling_wss=*)
    case "$video_chat_signaling_wss" in
      ''|wss://*|ws://*) config-set "$blog_site_conf" video_chat_signaling_wss "$video_chat_signaling_wss" ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *video_chat_public_rooms=*)
    case "$video_chat_public_rooms" in
      true|false) config-set "$blog_site_conf" video_chat_public_rooms "$video_chat_public_rooms" ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *video_chat_rooms=*)
    manual_rooms=$(blog_video_chat_sanitize_manual_rooms "$video_chat_rooms")
    config-set "$blog_site_conf" video_chat_rooms "$manual_rooms"
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *video_chat_scheduled_rooms=*)
    scheduled_rooms=$(blog_video_chat_sanitize_scheduled_rooms "$video_chat_scheduled_rooms")
    config-set "$blog_site_conf" video_chat_scheduled_rooms "$scheduled_rooms"
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *overworld_anonymous_enabled=*)
    case "$overworld_anonymous_enabled" in
      true|false) config-set "$blog_site_conf" overworld_anonymous_enabled "$overworld_anonymous_enabled" ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *overworld_anonymous_time_limit_seconds=*)
    case "$overworld_anonymous_time_limit_seconds" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$overworld_anonymous_time_limit_seconds" -lt 60 ]; then
          overworld_anonymous_time_limit_seconds=60
        fi
        if [ "$overworld_anonymous_time_limit_seconds" -gt 86400 ]; then
          overworld_anonymous_time_limit_seconds=86400
        fi
        config-set "$blog_site_conf" overworld_anonymous_time_limit_seconds "$overworld_anonymous_time_limit_seconds"
        ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *overworld_show_hidden=*)
    case "$overworld_show_hidden" in
      true|false) config-set "$blog_site_conf" overworld_show_hidden "$overworld_show_hidden" ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *overworld_access_mode=*)
    case "$overworld_access_mode" in
      player|web) config-set "$blog_site_conf" overworld_access_mode "$overworld_access_mode" ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *overworld_max_entries=*)
    case "$overworld_max_entries" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$overworld_max_entries" -lt 8 ]; then
          overworld_max_entries=8
        fi
        if [ "$overworld_max_entries" -gt 300 ]; then
          overworld_max_entries=300
        fi
        config-set "$blog_site_conf" overworld_max_entries "$overworld_max_entries"
        ;;
    esac
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *overworld_start_path=*)
    clean_overworld_start_path=$(printf '%s' "$overworld_start_path" | tr -d '\r\n')
    if [ "$clean_overworld_start_path" != "$overworld_start_path" ]; then
      :
    elif [ -z "$clean_overworld_start_path" ]; then
      config-set "$blog_site_conf" overworld_start_path ''
    else
      canonical_overworld_start=$(blog_overworld_canonical_path "$clean_overworld_start_path" 2>/dev/null || printf '')
      if [ -n "$canonical_overworld_start" ] && [ -d "$canonical_overworld_start" ]; then
        config-set "$blog_site_conf" overworld_start_path "$canonical_overworld_start"
      fi
    fi
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *origin_enabled_platforms=*)
    available_json=$(blog_origin_platforms_json)
    normalized_json=$(blog_origin_normalize_platforms_json "$origin_enabled_platforms" "$available_json")
    config-set "$blog_site_conf" origin_enabled_platforms "$normalized_json"
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *origin_default_platforms=*)
    enabled_json=$(blog_origin_enabled_platforms_json)
    normalized_json=$(blog_origin_normalize_platforms_json "$origin_default_platforms" "$enabled_json")
    config-set "$blog_site_conf" origin_default_platforms "$normalized_json"
    ;;
esac

nostr_support_raw=$(blog_plugin_raw_enabled "nostr_support")
if [ "$nostr_support_raw" != "true" ]; then
  config-set "$blog_site_conf" "plugin_nostr_login" "false"
  config-set "$blog_site_conf" "plugin_nostr_bridge" "false"
  config-set "$blog_site_conf" "plugin_nostr_posts" "false"
  config-set "$blog_site_conf" "plugin_zaps" "false"
fi

case "$BLOG_REQUEST_BODY" in
  *zap_lud16=*)
    clean_lud16=$(printf '%s' "$zap_lud16" | tr -d '\r\n[:space:]')
    config-set "$blog_site_conf" zap_lud16 "$clean_lud16"
    ;;
esac

case "$BLOG_REQUEST_BODY" in
  *zap_default_amount_sats=*)
    case "$zap_default_amount_sats" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$zap_default_amount_sats" -lt 1 ]; then
          zap_default_amount_sats=1
        fi
        config-set "$blog_site_conf" zap_default_amount_sats "$zap_default_amount_sats"
        ;;
    esac
    ;;
esac

if [ "$nostr_lists_update" = "true" ]; then
  case "$BLOG_REQUEST_BODY" in
    *nostr_authors=*) write_nostr_lines_file "$blog_nostr_authors_file" "$nostr_authors" ;;
  esac
  write_nostr_lines_file "$blog_nostr_relays_file" "$nostr_relays"
  write_nostr_lines_file "$blog_nostr_blocklist_file" "$nostr_blocklist"
  if blog_nostr_bridge_enabled; then
    blog_nostr_rebuild_derived >/dev/null 2>&1 || true
  fi
fi

config_after=$(cat "$blog_site_conf" 2>/dev/null || printf '')
if [ "$config_after" != "$config_before" ]; then
  if [ "$zaps_config_changed" = "true" ] && blog_plugin_enabled "nostr_support"; then
    blog_nostr_sync_contact_metadata >/dev/null 2>&1 || true
  fi
  blog_run_build_async >/dev/null 2>&1 || true
fi

printf '{"success":true,"message":"Configuration updated"}\n'
