#!/bin/sh
# Report direct Lightning node + zap endpoint status for a site managed in Headquarters.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

action=$(printf '%s' "$(blog_param action)" | tr '[:upper:]' '[:lower:]')
[ -n "$action" ] || action=status

bool_json_value() {
  case "${1-}" in
    true|1|yes|on|ok) printf 'true' ;;
    *) printf 'false' ;;
  esac
}

http_head_ok() {
  url=${1-}
  [ -n "$url" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsSI --max-time 8 "$url" >/dev/null 2>&1
}

lud16_localpart() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  case "$value" in
    *@*) printf '%s\n' "${value%@*}" ;;
    *) return 1 ;;
  esac
}

lud16_domain() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  case "$value" in
    *@*) printf '%s\n' "${value#*@}" | tr '[:upper:]' '[:lower:]' ;;
    *) return 1 ;;
  esac
}

lightning_public_host() {
  host=$(config-get "$blog_site_conf" lightning_public_host 2>/dev/null || printf '')
  host=$(blog_normalize_public_host "$host")
  if blog_valid_public_host "$host"; then
    printf '%s\n' "$host"
    return 0
  fi
  effective=$(blog_zap_effective_lud16 2>/dev/null || printf '')
  domain=$(lud16_domain "$effective" 2>/dev/null || printf '')
  if blog_valid_public_host "$domain"; then
    printf '%s\n' "$domain"
    return 0
  fi
  printf '%s\n' "$(blog_normalize_public_host "${HTTP_HOST:-${SERVER_NAME:-}}")"
}

lightning_public_port() {
  port=$(config-get "$blog_site_conf" lightning_public_port 2>/dev/null || printf '')
  port=$(printf '%s' "$port" | tr -d '\r\n[:space:]')
  case "$port" in
    ''|*[!0-9]*) checksum=$(printf '%s\n' "$blog_site_name" | cksum | awk '{print $1}'); port=$((19000 + ((checksum % 1000) * 2))) ;;
  esac
  printf '%s\n' "$port"
}

lightning_public_address() {
  host=$(lightning_public_host)
  port=$(lightning_public_port)
  if [ -n "$host" ] && [ -n "$port" ]; then
    printf '%s:%s\n' "$host" "$port"
    return 0
  fi
  printf '\n'
}

lightning_dir() {
  printf '%s/lightning\n' "$blog_site_data"
}

lightning_cli_bin() {
  managed_cli="$blog_site_data/zaps/bin/lightning-cli"
  if [ -x "$managed_cli" ]; then
    printf '%s\n' "$managed_cli"
    return 0
  fi
  command -v lightning-cli 2>/dev/null || return 1
}

lightning_cli_json() {
  bin=$(lightning_cli_bin) || return 1
  "$bin" --lightning-dir="$(lightning_dir)" "$@" 2>/dev/null
}

site_pubkey() {
  pubkey=$(sed -n '1p' "$blog_nostr_state_dir/site_pubkey" 2>/dev/null | tr -d '\r\n[:space:]' | tr 'A-F' 'a-f')
  case "$pubkey" in
    ??????*) printf '%s\n' "$pubkey" ;;
    *) return 1 ;;
  esac
}

zap_endpoint_url_for_lud16() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  localpart=$(lud16_localpart "$value" 2>/dev/null || printf '')
  domain=$(lud16_domain "$value" 2>/dev/null || printf '')
  if [ -z "$localpart" ] || ! blog_valid_public_host "$domain"; then
    printf '\n'
    return 0
  fi
  printf 'https://%s/.well-known/lnurlp/%s\n' "$domain" "$localpart"
}

zap_endpoint_live() {
  endpoint_url=${1-}
  [ -n "$endpoint_url" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsS --max-time 8 "$endpoint_url" 2>/dev/null | grep -Eq '"callback"|"allowsNostr"|"nostrPubkey"'
}

runtime_json() {
  configured_lud16=$(blog_zap_lud16 2>/dev/null || printf '')
  effective_lud16=$(blog_zap_effective_lud16 2>/dev/null || printf '')
  endpoint_url=$(zap_endpoint_url_for_lud16 "$effective_lud16")
  endpoint_ready=false
  if zap_endpoint_live "$endpoint_url"; then
    endpoint_ready=true
  fi

  host=$(lightning_public_host)
  port=$(lightning_public_port)
  public_address=$(lightning_public_address)
  node_id=''
  node_alias=''
  num_peers=0
  num_active_channels=0
  num_pending_channels=0
  inbound_liquidity_sats=0
  outbound_liquidity_sats=0
  lightning_online=false

  if getinfo_json=$(lightning_cli_json getinfo); then
    lightning_online=true
    node_id=$(printf '%s\n' "$getinfo_json" | jq -r '.id // ""' 2>/dev/null || printf '')
    node_alias=$(printf '%s\n' "$getinfo_json" | jq -r '.alias // ""' 2>/dev/null || printf '')
    num_peers=$(printf '%s\n' "$getinfo_json" | jq -r '.num_peers // 0' 2>/dev/null || printf '0')
    num_active_channels=$(printf '%s\n' "$getinfo_json" | jq -r '.num_active_channels // 0' 2>/dev/null || printf '0')
    num_pending_channels=$(printf '%s\n' "$getinfo_json" | jq -r '.num_pending_channels // 0' 2>/dev/null || printf '0')
  fi

  if listfunds_json=$(lightning_cli_json listfunds); then
    inbound_liquidity_sats=$(printf '%s\n' "$listfunds_json" | jq -r '
      def msat: ((. // "0msat") | tostring | sub("msat$"; "") | tonumber? // 0);
      [(.channels // [])[]? | ((.amount_msat | msat) - (.our_amount_msat | msat))] | add // 0 | floor / 1000 | floor
    ' 2>/dev/null || printf '0')
    outbound_liquidity_sats=$(printf '%s\n' "$listfunds_json" | jq -r '
      def msat: ((. // "0msat") | tostring | sub("msat$"; "") | tonumber? // 0);
      [(.channels // [])[]? | (.our_amount_msat | msat)] | add // 0 | floor / 1000 | floor
    ' 2>/dev/null || printf '0')
  fi

  can_receive=false
  if [ "$endpoint_ready" = true ] && [ "$lightning_online" = true ] && [ "${inbound_liquidity_sats:-0}" -gt 0 ]; then
    can_receive=true
  fi

  signer_ready=false
  if site_pubkey >/dev/null 2>&1; then
    signer_ready=true
  fi

  printf '{'
  printf '"headquarters_managed":true,'
  printf '"lightning_configured":%s,' "$(bool_json_value "$(test -n "$host" && test -n "$port" && printf true || printf false)")"
  printf '"lightning_online":%s,' "$(bool_json_value "$lightning_online")"
  printf '"lightning_host":"%s",' "$(blog_json_escape "$host")"
  printf '"lightning_port":%s,' "$(printf '%s' "${port:-0}" | tr -dc '0-9')"
  printf '"public_address":"%s",' "$(blog_json_escape "$public_address")"
  printf '"node_id":"%s",' "$(blog_json_escape "$node_id")"
  printf '"node_alias":"%s",' "$(blog_json_escape "$node_alias")"
  printf '"num_peers":%s,' "$(printf '%s' "${num_peers:-0}" | tr -dc '0-9')"
  printf '"num_active_channels":%s,' "$(printf '%s' "${num_active_channels:-0}" | tr -dc '0-9')"
  printf '"num_pending_channels":%s,' "$(printf '%s' "${num_pending_channels:-0}" | tr -dc '0-9')"
  printf '"inbound_liquidity_sats":%s,' "$(printf '%s' "${inbound_liquidity_sats:-0}" | tr -dc '0-9')"
  printf '"outbound_liquidity_sats":%s,' "$(printf '%s' "${outbound_liquidity_sats:-0}" | tr -dc '0-9')"
  printf '"can_receive_zaps":%s,' "$(bool_json_value "$can_receive")"
  printf '"configured_lud16":"%s",' "$(blog_json_escape "$configured_lud16")"
  printf '"effective_lud16":"%s",' "$(blog_json_escape "$effective_lud16")"
  printf '"zap_endpoint_url":"%s",' "$(blog_json_escape "$endpoint_url")"
  printf '"zap_endpoint_ready":%s,' "$(bool_json_value "$endpoint_ready")"
  printf '"site_signer_ready":%s' "$(bool_json_value "$signer_ready")"
  printf '}\n'
}

emit_success() {
  message=${1-OK}
  log_text=${2-}
  printf '{"success":true,"message":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

emit_failure() {
  message=${1-Request failed}
  code=${2-lightning_failed}
  log_text=${3-}
  printf '{"success":false,"error":"%s","code":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(blog_json_escape "$code")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

case "$action" in
  status)
    emit_success "Lightning runtime loaded."
    exit 0
    ;;
  install_btcpay|uninstall_btcpay|install_lightning|install_bitcoin)
    emit_failure "Bitcoin, Core Lightning, and the Lightning Address endpoint are provisioned in Headquarters." "managed_externally"
    exit 0
    ;;
  *)
    emit_failure "Unknown action" "invalid_action"
    exit 0
    ;;
esac
