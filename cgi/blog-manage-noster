#!/bin/sh
# Manage Nostr runtime and Stonr install/start/stop/config actions.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

action=$(printf '%s' "$(blog_param action)" | tr '[:upper:]' '[:lower:]')
if [ -z "$action" ]; then
  action=status
fi

wizardry_dir=${WIZARDRY_DIR:-${HOME:-}/.wizardry}
home_dir=${HOME:-}
noster_state_dir="$blog_state_dir/noster"
stonr_pid_file="$noster_state_dir/stonr.pid"
stonr_log_file="$noster_state_dir/stonr.log"
stonr_config_file="$noster_state_dir/stonr-config.json"
legacy_pid_file="$noster_state_dir/stoner.pid"
stonr_control_pref_dir="${XDG_CONFIG_HOME:-$home_dir/.config}/stonr-control"
stonr_control_prefs_file="$stonr_control_pref_dir/ui-prefs.env"

mkdir -p "$noster_state_dir"

bool_or_default() {
  raw=$(printf '%s' "${1-}" | tr '[:upper:]' '[:lower:]')
  default=$(printf '%s' "${2-false}" | tr '[:upper:]' '[:lower:]')
  case "$raw" in
    true|1|yes|on) printf 'true\n' ;;
    false|0|no|off) printf 'false\n' ;;
    *)
      case "$default" in
        true|1|yes|on) printf 'true\n' ;;
        *) printf 'false\n' ;;
      esac
      ;;
  esac
}

stonr_control_pref_get() {
  key=${1-}
  [ -n "$key" ] || return 1
  [ -f "$stonr_control_prefs_file" ] || return 1
  awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); found = 1 } END { exit found ? 0 : 1 }' "$stonr_control_prefs_file"
}

stonr_control_pref_set() {
  key=${1-}
  value=${2-}
  [ -n "$key" ] || return 1
  mkdir -p "$stonr_control_pref_dir"
  tmp_file=$(mktemp "${TMPDIR:-/tmp}/stonr-control-pref.XXXXXX")
  if [ -f "$stonr_control_prefs_file" ]; then
    awk -v key="$key" -v value="$value" '
      BEGIN { done = 0 }
      $0 ~ ("^" key "=") {
        print key "=" value
        done = 1
        next
      }
      { print }
      END {
        if (!done) {
          print key "=" value
        }
      }
    ' "$stonr_control_prefs_file" > "$tmp_file"
  else
    printf '%s=%s\n' "$key" "$value" > "$tmp_file"
  fi
  mv "$tmp_file" "$stonr_control_prefs_file"
}

setting_bool() {
  key=$1
  default=$2
  value=$(config-get "$blog_site_conf" "$key" 2>/dev/null || printf '')
  bool_or_default "$value" "$default"
}

setting_general_relay() {
  setting_bool nostr_stonr_general_relay false
}

setting_mirror_posts() {
  setting_bool nostr_stonr_mirror_posts true
}

setting_mirror_comments() {
  setting_bool nostr_stonr_mirror_comments true
}

setting_auto_start() {
  relay_auto_start=$(stonr_control_pref_get relay_auto_start 2>/dev/null || printf '')
  if [ -n "$relay_auto_start" ]; then
    bool_or_default "$relay_auto_start" false
    return 0
  fi
  setting_bool nostr_stonr_auto_start false
}

setting_one_site_mirror() {
  if [ "$(setting_general_relay)" = "true" ]; then
    printf 'false\n'
  else
    printf 'true\n'
  fi
}

settings_json() {
  general_relay=$(setting_general_relay)
  mirror_posts=$(setting_mirror_posts)
  mirror_comments=$(setting_mirror_comments)
  auto_start=$(setting_auto_start)
  one_site_mirror=$(setting_one_site_mirror)
  printf '{'
  printf '"one_site_mirror_mode":%s,' "$one_site_mirror"
  printf '"general_relay":%s,' "$general_relay"
  printf '"mirror_posts":%s,' "$mirror_posts"
  printf '"mirror_comments":%s,' "$mirror_comments"
  printf '"auto_start":%s' "$auto_start"
  printf '}'
}

stonr_bin_path() {
  for name in stonr stoner; do
    bin=$(command -v "$name" 2>/dev/null || printf '')
    if [ -n "$bin" ] && [ -x "$bin" ]; then
      printf '%s\n' "$bin"
      return 0
    fi
  done

  local_root=${STONR_LOCAL_COPY:-${home_dir}/git/stonr}
  for candidate in \
    "/Applications/Stonr.app/Contents/MacOS/stonr" \
    "/Applications/Stonr & Relay.app/Contents/MacOS/stonr" \
    "$home_dir/Applications/Stonr.app/Contents/MacOS/stonr" \
    "$home_dir/Applications/Stonr & Relay.app/Contents/MacOS/stonr" \
    "$home_dir/.local/bin/stonr" \
    "$local_root/stonr" \
    "$local_root/bin/stonr" \
    "$local_root/target/release/stonr" \
    "$local_root/dist/stonr" \
    "$local_root/stoner" \
    "$local_root/bin/stoner" \
    "$local_root/target/release/stoner" \
    "$local_root/dist/stoner"; do
    if [ -n "$candidate" ] && [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  printf '\n'
}

stonr_installed() {
  [ -n "$(stonr_bin_path)" ]
}

web_wizardry_has_cmd() {
  cmd_name=$1
  if ! command -v web-wizardry >/dev/null 2>&1; then
    return 1
  fi
  web-wizardry --help 2>/dev/null | grep -Eq "^[[:space:]]+$cmd_name([[:space:]]|$)"
}

web_wizardry_run_cmd() {
  cmd_name=$1
  action_log=$2
  set +e
  env STONR_CONFIG="$stonr_config_file" web-wizardry "$cmd_name" >> "$action_log" 2>&1
  status=$?
  set -e
  return "$status"
}

run_wizardry_spell() {
  spell_path=$1
  action_log=$2
  input_file=$(mktemp "${TMPDIR:-/tmp}/blog-noster-input.XXXXXX")
  i=0
  while [ "$i" -lt 8 ]; do
    printf '\n' >> "$input_file"
    i=$((i + 1))
  done
  set +e
  sh -c 'WIZARDRY_DIR="$1" HOME="$2" STONR_CONFIG="$3" "$4" < "$5"' sh "$wizardry_dir" "$home_dir" "$stonr_config_file" "$spell_path" "$input_file" >> "$action_log" 2>&1
  status=$?
  set -e
  rm -f "$input_file"
  return "$status"
}

stonr_pid() {
  for pid_file in "$stonr_pid_file" "$legacy_pid_file"; do
    if [ -f "$pid_file" ]; then
      pid=$(tr -cd '0-9' < "$pid_file" 2>/dev/null || printf '')
      if [ -n "$pid" ] && kill -0 "$pid" >/dev/null 2>&1; then
        printf '%s\n' "$pid"
        return 0
      fi
    fi
  done

  if command -v pgrep >/dev/null 2>&1; then
    pid=$(pgrep -f '[ /](stonr|stoner)([[:space:]]|$)' 2>/dev/null | head -n 1 || printf '')
    if [ -n "$pid" ] && kill -0 "$pid" >/dev/null 2>&1; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi

  printf '\n'
}

stonr_running() {
  [ -n "$(stonr_pid)" ]
}

stonr_supports_config_flag() {
  bin=$1
  [ -n "$bin" ] || return 1
  set +e
  help_text=$("$bin" --help 2>/dev/null)
  status=$?
  set -e
  if [ "$status" -ne 0 ]; then
    return 1
  fi
  printf '%s' "$help_text" | grep -Eq -- '--config([=[:space:]]|$)'
}

relay_connected() {
  if ! stonr_running; then
    return 1
  fi

  bin=$(stonr_bin_path)
  if [ -z "$bin" ]; then
    return 1
  fi

  set +e
  status_json=$(STONR_CONFIG="$stonr_config_file" "$bin" status --json 2>/dev/null)
  status_code=$?
  set -e
  if [ "$status_code" -eq 0 ] && [ -n "$status_json" ]; then
    if printf '%s' "$status_json" | grep -Eiq '"(relay_)?connected"[[:space:]]*:[[:space:]]*true'; then
      return 0
    fi
  fi

  set +e
  status_text=$(STONR_CONFIG="$stonr_config_file" "$bin" status 2>/dev/null)
  status_code=$?
  set -e
  if [ "$status_code" -eq 0 ] && printf '%s' "$status_text" | grep -Eiq 'connected|relay connected'; then
    return 0
  fi

  return 1
}

bool_json() {
  if "$@"; then
    printf 'true'
  else
    printf 'false'
  fi
}

write_stonr_config() {
  action_log=$1

  general_relay=$(setting_general_relay)
  one_site_mirror=$(setting_one_site_mirror)
  mirror_posts=$(setting_mirror_posts)
  mirror_comments=$(setting_mirror_comments)
  auto_start=$(setting_auto_start)

  relay_scope=site_only
  relay_write=false
  if [ "$general_relay" = "true" ]; then
    relay_scope=global
    relay_write=true
  fi

  tmp_file=$(mktemp "${TMPDIR:-/tmp}/blog-stonr-config.XXXXXX")
  {
    printf '{\n'
    printf '  "mode": "%s",\n' "$( [ "$one_site_mirror" = "true" ] && printf 'one_site_mirror' || printf 'general_relay' )"
    printf '  "one_site_mirror_mode": %s,\n' "$one_site_mirror"
    printf '  "relay": {\n'
    printf '    "general": %s,\n' "$general_relay"
    printf '    "accept_public_write": %s,\n' "$relay_write"
    printf '    "scope": "%s"\n' "$relay_scope"
    printf '  },\n'
    printf '  "mirror": {\n'
    printf '    "posts": %s,\n' "$mirror_posts"
    printf '    "comments": %s,\n' "$mirror_comments"
    printf '    "scope": "%s"\n' "$relay_scope"
    printf '  },\n'
    printf '  "runtime": {\n'
    printf '    "auto_start": %s\n' "$auto_start"
    printf '  },\n'
    printf '  "site": {\n'
    printf '    "name": "%s",\n' "$(blog_json_escape "$blog_site_name")"
    printf '    "root": "%s"\n' "$(blog_json_escape "$blog_site_root")"
    printf '  }\n'
    printf '}\n'
  } > "$tmp_file"

  mv "$tmp_file" "$stonr_config_file"
  chmod 644 "$stonr_config_file" 2>/dev/null || true

  if [ -n "$home_dir" ]; then
    mkdir -p "$home_dir/.config/stonr" "$home_dir/.stonr"
    cp "$stonr_config_file" "$home_dir/.config/stonr/config.json" 2>/dev/null || true
    cp "$stonr_config_file" "$home_dir/.stonr/config.json" 2>/dev/null || true
  fi

  printf 'Wrote Stonr config: %s\n' "$stonr_config_file" >> "$action_log"
}

save_settings_from_request() {
  action_log=$1

  general_relay=$(bool_or_default "$(blog_param general_relay)" "$(setting_general_relay)")
  mirror_posts=$(bool_or_default "$(blog_param mirror_posts)" "$(setting_mirror_posts)")
  mirror_comments=$(bool_or_default "$(blog_param mirror_comments)" "$(setting_mirror_comments)")
  auto_start=$(bool_or_default "$(blog_param auto_start)" "$(setting_auto_start)")

  config-set "$blog_site_conf" nostr_stonr_general_relay "$general_relay"
  config-set "$blog_site_conf" nostr_stonr_mirror_posts "$mirror_posts"
  config-set "$blog_site_conf" nostr_stonr_mirror_comments "$mirror_comments"
  config-set "$blog_site_conf" nostr_stonr_auto_start "$auto_start"
  stonr_control_pref_set relay_auto_start "$( [ "$auto_start" = "true" ] && printf '1' || printf '0' )"

  if [ "$mirror_posts" = "true" ] || [ "$mirror_comments" = "true" ]; then
    config-set "$blog_site_conf" nostr_bridge_enabled true
  fi

  write_stonr_config "$action_log"
}

runtime_json() {
  pid=$(stonr_pid)
  path=$(stonr_bin_path)
  printf '{'
  printf '"stonr_installed":%s,' "$(bool_json stonr_installed)"
  printf '"stonr_running":%s,' "$(bool_json stonr_running)"
  printf '"relay_connected":%s,' "$(bool_json relay_connected)"
  printf '"stonr_path":"%s",' "$(blog_json_escape "$path")"
  printf '"config_path":"%s",' "$(blog_json_escape "$stonr_config_file")"
  printf '"pid":"%s",' "$(blog_json_escape "$pid")"
  printf '"settings":%s,' "$(settings_json)"
  # Backward-compatible keys for existing UI code paths.
  printf '"stoner_installed":%s,' "$(bool_json stonr_installed)"
  printf '"stoner_running":%s,' "$(bool_json stonr_running)"
  printf '"stoner_path":"%s"' "$(blog_json_escape "$path")"
  printf '}'
}

emit_success() {
  message=${1-OK}
  log_text=${2-}
  printf '{"success":true,"message":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

emit_failure() {
  message=${1-Request failed}
  code=${2-noster_failed}
  log_text=${3-}
  printf '{"success":false,"error":"%s","code":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(blog_json_escape "$code")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

install_stonr_from_local_copy() {
  action_log=$1
  local_root=${STONR_LOCAL_COPY:-${home_dir}/git/stonr}
  if [ ! -d "$local_root" ]; then
    return 1
  fi

  for candidate in \
    "$local_root/stonr" \
    "$local_root/bin/stonr" \
    "$local_root/target/release/stonr" \
    "$local_root/dist/stonr" \
    "$local_root/stoner" \
    "$local_root/bin/stoner" \
    "$local_root/target/release/stoner" \
    "$local_root/dist/stoner"; do
    if [ -x "$candidate" ]; then
      if [ -n "$home_dir" ]; then
        mkdir -p "$home_dir/.local/bin"
        ln -sf "$candidate" "$home_dir/.local/bin/stonr"
        chmod +x "$home_dir/.local/bin/stonr" 2>/dev/null || true
        printf 'Installed Stonr from local copy: %s -> %s\n' "$candidate" "$home_dir/.local/bin/stonr" >> "$action_log"
      else
        printf 'Using local Stonr binary: %s\n' "$candidate" >> "$action_log"
      fi
      return 0
    fi
  done

  printf 'Local Stonr copy found at %s but no executable binary was detected.\n' "$local_root" >> "$action_log"
  return 1
}

is_macos() {
  [ "$(uname -s 2>/dev/null || printf '')" = "Darwin" ]
}

macos_stonr_app_target() {
  if ! is_macos; then
    return 1
  fi
  if [ -d "/Applications" ] && [ -w "/Applications" ]; then
    printf '/Applications/Stonr.app\n'
    return 0
  fi
  if [ -n "$home_dir" ]; then
    mkdir -p "$home_dir/Applications"
    printf '%s\n' "$home_dir/Applications/Stonr.app"
    return 0
  fi
  return 1
}

install_macos_stonr_app() {
  action_log=$1
  app_target=$(macos_stonr_app_target 2>/dev/null || printf '')
  if [ -z "$app_target" ]; then
    printf 'macOS app install target unavailable.\n' >> "$action_log"
    return 1
  fi

  local_root=${STONR_LOCAL_COPY:-${home_dir}/git/stonr}
  app_source=''
  for candidate in \
    "$local_root/dist/Stonr.app" \
    "$local_root/dist/Stonr & Relay.app" \
    "$local_root/target/release/bundle/macos/Stonr.app" \
    "$local_root/target/release/bundle/macos/Stonr & Relay.app"; do
    if [ -d "$candidate/Contents/MacOS" ]; then
      app_source=$candidate
      break
    fi
  done

  rm -rf "$app_target"
  if [ -n "$app_source" ]; then
    cp -R "$app_source" "$app_target"
    printf 'Installed Stonr app bundle: %s -> %s\n' "$app_source" "$app_target" >> "$action_log"
  else
    bin=$(stonr_bin_path)
    if [ -z "$bin" ] || [ ! -x "$bin" ]; then
      printf 'Cannot create Stonr.app because no stonr binary is available.\n' >> "$action_log"
      return 1
    fi
    mkdir -p "$app_target/Contents/MacOS" "$app_target/Contents/Resources"
    cat > "$app_target/Contents/MacOS/stonr" <<'SH'
#!/bin/sh
set -eu
exec "${STONR_BIN:-stonr}" "$@"
SH
    chmod +x "$app_target/Contents/MacOS/stonr"
    cat > "$app_target/Contents/Info.plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>stonr</string>
  <key>CFBundleIdentifier</key>
  <string>dev.stonr.relay</string>
  <key>CFBundleName</key>
  <string>Stonr</string>
  <key>CFBundleDisplayName</key>
  <string>Stonr</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
</dict>
</plist>
PLIST
    printf 'Created Stonr app bundle at %s using existing stonr binary.\n' "$app_target" >> "$action_log"
  fi

  if [ -n "$home_dir" ] && [ -x "$app_target/Contents/MacOS/stonr" ]; then
    mkdir -p "$home_dir/.local/bin"
    ln -sf "$app_target/Contents/MacOS/stonr" "$home_dir/.local/bin/stonr"
    chmod +x "$home_dir/.local/bin/stonr" 2>/dev/null || true
    printf 'Linked ~/.local/bin/stonr -> %s\n' "$app_target/Contents/MacOS/stonr" >> "$action_log"
  fi
  printf 'Stonr macOS app install location: %s\n' "$app_target" >> "$action_log"
  [ -d "$app_target" ]
}

finalize_stonr_install() {
  action_log=$1
  if ! stonr_installed; then
    return 1
  fi
  if is_macos; then
    install_macos_stonr_app "$action_log" || return 1
  fi
  return 0
}

install_stonr() {
  action_log=$1
  if stonr_installed; then
    finalize_stonr_install "$action_log"
    return $?
  fi

  if web_wizardry_has_cmd install-stonr; then
    if web_wizardry_run_cmd install-stonr "$action_log"; then
      finalize_stonr_install "$action_log"
      return $?
    fi
    return 1
  fi
  if web_wizardry_has_cmd install-stoner; then
    if web_wizardry_run_cmd install-stoner "$action_log"; then
      finalize_stonr_install "$action_log"
      return $?
    fi
    return 1
  fi

  for spell in \
    "$wizardry_dir/spells/.arcana/nostr/install-stonr" \
    "$wizardry_dir/spells/.arcana/nostr/install-stoner" \
    "$wizardry_dir/spells/.arcana/stonr/install-stonr" \
    "$wizardry_dir/spells/.arcana/stoner/install-stoner"; do
    if [ -x "$spell" ]; then
      if run_wizardry_spell "$spell" "$action_log"; then
        finalize_stonr_install "$action_log"
        return $?
      fi
      return 1
    fi
  done

  if install_stonr_from_local_copy "$action_log"; then
    finalize_stonr_install "$action_log"
    return $?
  fi

  if command -v brew >/dev/null 2>&1; then
    set +e
    brew install stonr >> "$action_log" 2>&1
    status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      finalize_stonr_install "$action_log"
      return $?
    fi

    set +e
    brew install stoner >> "$action_log" 2>&1
    status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      finalize_stonr_install "$action_log"
      return $?
    fi
  fi

  printf 'No supported Stonr installer was found.\n' >> "$action_log"
  return 1
}

start_stonr() {
  action_log=$1
  if stonr_running; then
    return 0
  fi
  if ! stonr_installed; then
    printf 'Stonr is not installed.\n' >> "$action_log"
    return 1
  fi

  write_stonr_config "$action_log"

  if web_wizardry_has_cmd start-stonr; then
    web_wizardry_run_cmd start-stonr "$action_log"
    return $?
  fi
  if web_wizardry_has_cmd start-stoner; then
    web_wizardry_run_cmd start-stoner "$action_log"
    return $?
  fi

  for spell in \
    "$wizardry_dir/spells/.arcana/nostr/start-stonr" \
    "$wizardry_dir/spells/.arcana/nostr/start-stoner" \
    "$wizardry_dir/spells/.arcana/stonr/start-stonr" \
    "$wizardry_dir/spells/.arcana/stoner/start-stoner"; do
    if [ -x "$spell" ]; then
      run_wizardry_spell "$spell" "$action_log"
      return $?
    fi
  done

  bin=$(stonr_bin_path)
  if [ -z "$bin" ]; then
    printf 'stonr executable not found.\n' >> "$action_log"
    return 1
  fi

  set +e
  if stonr_supports_config_flag "$bin"; then
    nohup "$bin" --config "$stonr_config_file" >> "$stonr_log_file" 2>&1 </dev/null &
  else
    STONR_CONFIG="$stonr_config_file" nohup "$bin" >> "$stonr_log_file" 2>&1 </dev/null &
  fi
  pid=$!
  sleep 1
  if kill -0 "$pid" >/dev/null 2>&1; then
    printf '%s\n' "$pid" > "$stonr_pid_file"
    printf '%s\n' "$pid" > "$legacy_pid_file"
    printf 'Started stonr (pid %s)\n' "$pid" >> "$action_log"
    status=0
  else
    status=1
  fi
  set -e
  return "$status"
}

stop_stonr() {
  action_log=$1
  if web_wizardry_has_cmd stop-stonr; then
    set +e
    env STONR_CONFIG="$stonr_config_file" web-wizardry stop-stonr >> "$action_log" 2>&1
    status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      rm -f "$stonr_pid_file" "$legacy_pid_file"
      return 0
    fi
  fi
  if web_wizardry_has_cmd stop-stoner; then
    set +e
    env STONR_CONFIG="$stonr_config_file" web-wizardry stop-stoner >> "$action_log" 2>&1
    status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      rm -f "$stonr_pid_file" "$legacy_pid_file"
      return 0
    fi
  fi

  for spell in \
    "$wizardry_dir/spells/.arcana/nostr/stop-stonr" \
    "$wizardry_dir/spells/.arcana/nostr/stop-stoner" \
    "$wizardry_dir/spells/.arcana/stonr/stop-stonr" \
    "$wizardry_dir/spells/.arcana/stoner/stop-stoner"; do
    if [ -x "$spell" ]; then
      run_wizardry_spell "$spell" "$action_log" || return 1
      rm -f "$stonr_pid_file" "$legacy_pid_file"
      return 0
    fi
  done

  pid=$(stonr_pid)
  if [ -n "$pid" ]; then
    set +e
    kill "$pid" >/dev/null 2>&1
    status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      rm -f "$stonr_pid_file" "$legacy_pid_file"
      printf 'Stopped stonr (pid %s)\n' "$pid" >> "$action_log"
      return 0
    fi
  fi

  if command -v pkill >/dev/null 2>&1; then
    set +e
    pkill -f '[ /](stonr|stoner)([[:space:]]|$)' >/dev/null 2>&1
    status=$?
    set -e
    rm -f "$stonr_pid_file" "$legacy_pid_file"
    [ "$status" -eq 0 ] && return 0
  fi

  printf 'Stonr was not running.\n' >> "$action_log"
  return 0
}

configure_stonr() {
  action_log=$1
  write_stonr_config "$action_log"

  if ! stonr_running; then
    return 0
  fi

  bin=$(stonr_bin_path)
  if [ -z "$bin" ]; then
    return 0
  fi

  set +e
  STONR_CONFIG="$stonr_config_file" "$bin" reload --config "$stonr_config_file" >> "$action_log" 2>&1
  status=$?
  set -e
  if [ "$status" -eq 0 ]; then
    printf 'Reloaded running Stonr process with updated config.\n' >> "$action_log"
    return 0
  fi

  printf 'Saved config. Restart Stonr to guarantee config application.\n' >> "$action_log"
  return 0
}

case "$action" in
  status|install|start|stop|save_settings|configure) ;;
  *)
    emit_failure "Unknown action" "invalid_action"
    exit 0
    ;;
esac

if [ ! -f "$stonr_config_file" ]; then
  boot_log=$(mktemp "${TMPDIR:-/tmp}/blog-noster-boot.XXXXXX")
  write_stonr_config "$boot_log" >/dev/null 2>&1 || true
  rm -f "$boot_log"
fi

if [ "$action" = "status" ]; then
  emit_success ""
  exit 0
fi

action_log=$(mktemp "${TMPDIR:-/tmp}/blog-noster-log.XXXXXX")
trap 'rm -f "$action_log"' EXIT HUP INT TERM

set +e
case "$action" in
  install)
    install_stonr "$action_log"
    action_status=$?
    if [ "$action_status" -eq 0 ]; then
      configure_stonr "$action_log" || true
      auto_start=$(setting_auto_start)
      if [ "$auto_start" = "true" ] && ! stonr_running; then
        start_stonr "$action_log" || true
      fi
    fi
    action_message='Stonr installed and configured.'
    action_error='Stonr install failed.'
    action_code='stonr_install_failed'
    ;;
  start)
    start_stonr "$action_log"
    action_status=$?
    action_message='Stonr started.'
    action_error='Could not start Stonr.'
    action_code='stonr_start_failed'
    ;;
  stop)
    stop_stonr "$action_log"
    action_status=$?
    action_message='Stonr stopped.'
    action_error='Could not stop Stonr.'
    action_code='stonr_stop_failed'
    ;;
  save_settings)
    save_settings_from_request "$action_log"
    action_status=$?
    if [ "$action_status" -eq 0 ]; then
      configure_stonr "$action_log" || true
    fi
    action_message='Nostr settings saved.'
    action_error='Could not save Nostr settings.'
    action_code='nostr_settings_save_failed'
    ;;
  configure)
    configure_stonr "$action_log"
    action_status=$?
    action_message='Stonr configured for this site.'
    action_error='Could not configure Stonr.'
    action_code='stonr_config_failed'
    ;;
esac
set -e

log_tail=$(tail -n 160 "$action_log" 2>/dev/null || printf '')
if [ "$action_status" -eq 0 ]; then
  emit_success "$action_message" "$log_tail"
else
  emit_failure "$action_error" "$action_code" "$log_tail"
fi
