#!/bin/sh
# Send an Owl Native reply through the local Secure Chat owner profile.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
case "${REQUEST_METHOD-}" in
  '')
    : "${WIZARDRY_SITE_NAME:=site}"
    : "${WIZARDRY_SITES_DIR:=$HOME}"
    export WIZARDRY_SITE_NAME
    export WIZARDRY_SITES_DIR
    ;;
esac
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-secure-chat-common.sh"

blog_init

npub=${1-}
body_b64=${2-}

case "${REQUEST_METHOD-}" in
  '')
    ;;
  *)
    blog_read_request_body
    blog_send_json_headers
    if ! blog_require_session true false; then
      exit 0
    fi
    npub=$(blog_param npub)
    body_b64=$(blog_param body_b64)
    ;;
esac

case "$npub" in
  npub1*) ;;
  *)
    printf '%s\n' '{"success":false,"error":"npub is required","code":"npub_required"}'
    exit 2
    ;;
esac

body_file=$(mktemp "${TMPDIR:-/tmp}/secure-chat-owl-send-body.XXXXXX")
payload_file=$(mktemp "${TMPDIR:-/tmp}/secure-chat-owl-send.XXXXXX")
trap 'rm -f "$body_file" "$payload_file"' EXIT HUP INT TERM

if printf '%s' "$body_b64" | base64 --decode > "$body_file" 2>/dev/null; then
  :
elif printf '%s' "$body_b64" | base64 -D > "$body_file" 2>/dev/null; then
  :
else
  printf '%s\n' '{"success":false,"error":"invalid base64 body","code":"body_invalid"}'
  exit 2
fi

text=$(cat "$body_file")
jq -cn --arg npub "$npub" --arg text "$text" '{action:"owl-send",npub:$npub,text:$text}' > "$payload_file"

response=$(
  SECURE_CHAT_STORE_DIR=$(blog_secure_chat_store_dir) \
  "$(blog_secure_chat_node_binary)" "$SCRIPT_DIR/blog-secure-chat-fast-owl-send.js" "$payload_file" 2>/dev/null || printf ''
)
if [ -z "$response" ]; then
  printf '%s\n' '{"success":false,"error":"Secure Chat Owl send is unavailable","code":"owl_send_unavailable"}'
  exit 1
fi

printf '%s\n' "$response"
