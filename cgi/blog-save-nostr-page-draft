#!/bin/sh
# Save local working state for a Nostr-backed page.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi
if ! blog_plugin_enabled "nostr_posts"; then
  blog_json_error "Nostr-backed pages plugin is disabled for this site" "plugin_disabled"
  exit 0
fi

page_slug=$(blog_nostr_page_slug "$(blog_param page_slug)")
if [ -z "$page_slug" ]; then
  page_slug=$(blog_nostr_page_slug "$(blog_param list_slug)")
fi
if [ -z "$page_slug" ]; then
  blog_json_error "page_slug is required" "missing_page_slug"
  exit 0
fi

page_type=$(blog_nostr_page_type_for_slug "$page_slug" 2>/dev/null || printf '')
if [ -z "$page_type" ]; then
  blog_json_error "Unknown Nostr page slug" "unknown_page"
  exit 0
fi

state_json=$(blog_param state_json)

if [ -z "$state_json" ]; then
  case "$page_type" in
    contact)
      title=$(blog_param title)
      description=$(blog_param description)
      publish_intro_to_nostr=$(blog_param publish_intro_to_nostr)
      extras_before=$(blog_param extras_before)
      extras_before_format=$(blog_param extras_before_format)
      extras_after=$(blog_param extras_after)
      extras_after_format='markdown'
      rows_json=$(blog_param rows_json)
      if [ -z "$rows_json" ]; then
        rows_json='[]'
      fi
      if ! printf '%s\n' "$rows_json" | jq -e 'type=="array"' >/dev/null 2>&1; then
        blog_json_error "rows_json must be a JSON array" "invalid_rows"
        exit 0
      fi
      state_json=$(jq -cn --arg slug "$page_slug" --arg title "$title" --arg description "$description" --arg publish_intro_to_nostr "$publish_intro_to_nostr" --arg extras_before "$extras_before" --arg extras_before_format "$extras_before_format" --arg extras_after "$extras_after" --arg extras_after_format "$extras_after_format" --argjson rows "$rows_json" '{
        slug: $slug,
        type: "contact",
        title: $title,
        description: $description,
        publish_intro_to_nostr: (($publish_intro_to_nostr | ascii_downcase) == "true"),
        extras_before: $extras_before,
        extras_before_format: $extras_before_format,
        extras_after: $extras_after,
        extras_after_format: $extras_after_format,
        rows: $rows
      }')
      ;;
    public-ranking)
      title=$(blog_param title)
      description=$(blog_param description)
      content=$(blog_param content)
      vote_cooldown_seconds=$(blog_param vote_cooldown_seconds)
      submission_mode=$(blog_param submission_mode)
      show_marker_filters=$(blog_param show_marker_filters)
      default_metric=$(blog_param default_metric)
      blacklist_pubkeys_json=$(blog_param blacklist_pubkeys_json)
      root_refs_json=$(blog_param root_refs_json)
      extras_after=$(blog_param extras_after)
      extras_after_format='markdown'
      [ -n "$blacklist_pubkeys_json" ] || blacklist_pubkeys_json='[]'
      [ -n "$root_refs_json" ] || root_refs_json='[]'
      if ! printf '%s\n' "$blacklist_pubkeys_json" | jq -e 'type=="array"' >/dev/null 2>&1; then
        blog_json_error "blacklist_pubkeys_json must be a JSON array" "invalid_blacklist"
        exit 0
      fi
      if ! printf '%s\n' "$root_refs_json" | jq -e 'type=="array"' >/dev/null 2>&1; then
        blog_json_error "root_refs_json must be a JSON array" "invalid_root_refs"
        exit 0
      fi
      state_json=$(jq -cn \
        --arg slug "$page_slug" \
        --arg title "$title" \
        --arg description "$description" \
        --arg content "$content" \
        --arg vote_cooldown_seconds "$vote_cooldown_seconds" \
        --arg submission_mode "$submission_mode" \
        --arg show_marker_filters "$show_marker_filters" \
        --arg default_metric "$default_metric" \
        --arg extras_after "$extras_after" \
        --arg extras_after_format "$extras_after_format" \
        --argjson blacklist_pubkeys "$blacklist_pubkeys_json" \
        --argjson root_refs "$root_refs_json" \
        '{
          slug: $slug,
          type: "public-ranking",
          title: $title,
          description: $description,
          content: $content,
          vote_cooldown_seconds: ($vote_cooldown_seconds | tonumber? // 86400),
          submission_mode: $submission_mode,
          show_marker_filters: (($show_marker_filters | ascii_downcase) == "true"),
          default_metric: $default_metric,
          blacklist_pubkeys: $blacklist_pubkeys,
          root_refs: $root_refs,
          extras_after: $extras_after,
          extras_after_format: $extras_after_format
        }')
      ;;
    nip23|blog)
      title=$(blog_param title)
      content=$(blog_param content)
      product_enabled=$(blog_param product_enabled)
      product_type=$(blog_param product_type)
      price=$(blog_param price)
      currency=$(blog_param currency)
      crypto_discount_percent=$(blog_param crypto_discount_percent)
      purchase_endpoint=$(blog_param purchase_endpoint)
      repo=$(blog_param repo)
      tag=$(blog_param tag)
      extras_after=$(blog_param extras_after)
      extras_after_format='markdown'
      state_json=$(jq -cn \
        --arg slug "$page_slug" \
        --arg page_type "$page_type" \
        --arg title "$title" \
        --arg content "$content" \
        --arg product_enabled "$product_enabled" \
        --arg product_type "$product_type" \
        --arg price "$price" \
        --arg currency "$currency" \
        --arg crypto_discount_percent "$crypto_discount_percent" \
        --arg purchase_endpoint "$purchase_endpoint" \
        --arg repo "$repo" \
        --arg tag "$tag" \
        --arg extras_after "$extras_after" \
        --arg extras_after_format "$extras_after_format" \
        '{
          slug: $slug,
          type: $page_type,
          title: $title,
          content: $content,
          product_enabled: (($product_enabled | ascii_downcase) == "true"),
          product_type: $product_type,
          price: $price,
          currency: $currency,
          crypto_discount_percent: ($crypto_discount_percent | tonumber? // 0),
          purchase_endpoint: $purchase_endpoint,
          repo: $repo,
          tag: $tag,
          extras_after: $extras_after,
          extras_after_format: $extras_after_format
        }')
      ;;
    *)
      title=$(blog_param title)
      description=$(blog_param description)
      publish_intro_to_nostr=$(blog_param publish_intro_to_nostr)
      show_marker_filters=$(blog_param show_marker_filters)
      show_markers=$(blog_param show_markers)
      alphabetize_markers=$(blog_param alphabetize_markers)
      default_markers=$(blog_param default_markers)
      group_by=$(blog_param group_by)
      view_mode=$(blog_param view_mode)
      content=$(blog_param content)
      extras_before=$(blog_param extras_before)
      extras_before_format=$(blog_param extras_before_format)
      extras_after=$(blog_param extras_after)
      extras_after_format='markdown'
      entries_json=$(blog_param entries_json)
      elements_json=$(blog_param elements_json)
      if [ -z "$elements_json" ]; then
        elements_json='[]'
      fi
      if [ -z "$entries_json" ]; then
        entries_json='[]'
      fi
      if ! printf '%s\n' "$elements_json" | jq -e 'type=="array"' >/dev/null 2>&1; then
        blog_json_error "elements_json must be a JSON array" "invalid_elements"
        exit 0
      fi
      if ! printf '%s\n' "$entries_json" | jq -e 'type=="array"' >/dev/null 2>&1; then
        blog_json_error "entries_json must be a JSON array" "invalid_entries"
        exit 0
      fi
      state_json=$(jq -cn \
        --arg slug "$page_slug" \
        --arg title "$title" \
        --arg description "$description" \
        --arg publish_intro_to_nostr "$publish_intro_to_nostr" \
        --arg show_marker_filters "$show_marker_filters" \
        --arg show_markers "$show_markers" \
        --arg alphabetize_markers "$alphabetize_markers" \
        --arg default_markers "$default_markers" \
        --arg group_by "$group_by" \
        --arg view_mode "$view_mode" \
        --arg content "$content" \
        --arg extras_before "$extras_before" \
        --arg extras_before_format "$extras_before_format" \
        --arg extras_after "$extras_after" \
        --arg extras_after_format "$extras_after_format" \
        --argjson elements "$elements_json" \
        --argjson entries "$entries_json" \
        '{
          slug: $slug,
          title: $title,
          description: $description,
          publish_intro_to_nostr: (($publish_intro_to_nostr | ascii_downcase) == "true"),
          show_marker_filters: (($show_marker_filters | ascii_downcase) == "true"),
          show_markers: (($show_markers | ascii_downcase) == "true"),
          alphabetize_markers: (($alphabetize_markers | ascii_downcase) == "true"),
          default_markers: $default_markers,
          group_by: $group_by,
          view_mode: $view_mode,
          content: $content,
          extras_before: $extras_before,
          extras_before_format: $extras_before_format,
          extras_after: $extras_after,
          extras_after_format: $extras_after_format,
          elements: (if ($elements | length) > 0 then $elements else ($entries | map(. + {type:"entry"})) end),
          entries: $entries
        }')
      ;;
  esac
fi

case "$page_type" in
  contact)
    normalized=$(blog_contact_normalize_state_json "$page_slug" "$state_json")
    blog_nostr_page_save_draft_state_json "$page_slug" "$page_type" "$normalized"
    validation_json=$(blog_contact_validate_and_enrich_state_json "$normalized" false)
    enriched=$(printf '%s\n' "$normalized" | jq -c --argjson validation "$validation_json" '. + {rows: $validation.rows, content_json: $validation.content_json}')
    ;;
  public-ranking)
    normalized=$(blog_public_ranking_normalize_state_json "$page_slug" "$state_json")
    blog_nostr_page_save_draft_state_json "$page_slug" "$page_type" "$normalized"
    validation_json=$(blog_public_ranking_validate_and_enrich_state_json "$normalized" false)
    enriched=$normalized
    ;;
  nip23|blog)
    normalized=$(blog_nip23_normalize_state_json "$page_slug" "$state_json" "$page_type")
    blog_nostr_page_save_draft_state_json "$page_slug" "$page_type" "$normalized"
    validation_json=$(blog_nip23_validate_and_enrich_state_json "$normalized" false)
    enriched=$normalized
    ;;
  *)
    normalized=$(blog_list_normalize_state_json "$page_slug" "$state_json")
    blog_nostr_page_save_draft_state_json "$page_slug" "$page_type" "$normalized"
    # Draft saves should acknowledge the durable write quickly. Full list
    # validation can resolve every referenced event/post, which is too costly
    # for large pages such as oeuvre and can make Done look like a failed save.
    validation_json='{"errors":[],"warnings":[],"can_publish":true}'
    enriched=$normalized
    ;;
esac

jq -cn \
  --arg slug "$page_slug" \
  --arg page_type "$page_type" \
  --argjson state "$enriched" \
  --argjson validation "$validation_json" \
  '{
    success: true,
    slug: $slug,
    page_type: $page_type,
    state: $state,
    validation: {
      errors: $validation.errors,
      warnings: $validation.warnings,
      can_publish: $validation.can_publish
    },
    message: "Draft saved."
  }'
printf '\n'
