#!/bin/sh
# Export recent Secure Chat messages for local Owl Native sync.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
case "${REQUEST_METHOD-}" in
  '')
    : "${WIZARDRY_SITE_NAME:=site}"
    : "${WIZARDRY_SITES_DIR:=$HOME}"
    export WIZARDRY_SITE_NAME
    export WIZARDRY_SITES_DIR
    ;;
esac
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-secure-chat-common.sh"

blog_init

since_seq=${1:-0}

case "${REQUEST_METHOD-}" in
  '')
    ;;
  *)
    blog_read_request_body
    blog_send_json_headers
    if ! blog_require_session true false; then
      exit 0
    fi
    since_seq=$(blog_param since_seq)
    ;;
esac

case "$since_seq" in
  ''|*[!0123456789]*) since_seq=0 ;;
esac

response=$(
  SECURE_CHAT_STORE_DIR=$(blog_secure_chat_store_dir) \
  "$(blog_secure_chat_node_binary)" "$SCRIPT_DIR/blog-secure-chat-fast-owl-export.js" "$since_seq" 2>/dev/null || printf ''
)
if [ -z "$response" ]; then
  printf '%s\n' '{"success":false,"error":"Secure Chat Owl export is unavailable","code":"export_unavailable"}'
  exit 1
fi

printf '%s\n' "$response"
