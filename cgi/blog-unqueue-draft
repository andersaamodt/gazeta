#!/bin/sh
# Move a queued/scheduled draft back to normal draft state.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

draft_id=$(blog_param draft_id)
if [ -z "$draft_id" ]; then
  blog_json_error "draft_id is required" "invalid_request"
  exit 0
fi

draft_file=$(blog_draft_resolve_file_path "$draft_id" 2>/dev/null || printf '')
if [ -z "$draft_file" ] || [ ! -f "$draft_file" ]; then
  blog_json_error "Draft not found" "not_found"
  exit 0
fi

title=$(blog_read_front_matter_value "$draft_file" title 2>/dev/null || printf 'Untitled Draft')
tags=$(blog_read_front_matter_value "$draft_file" tags 2>/dev/null || printf '')
summary=$(blog_read_front_matter_value "$draft_file" summary 2>/dev/null || printf '')
author=$(blog_read_front_matter_value "$draft_file" author 2>/dev/null || printf '')
content=$(blog_read_markdown_body "$draft_file" 2>/dev/null || printf '')
post_type=$(blog_read_front_matter_value "$draft_file" post_type 2>/dev/null || printf '')
source_post_path=$(blog_read_front_matter_value "$draft_file" source_post_path 2>/dev/null || printf '')
post_filename=$(blog_read_front_matter_value "$draft_file" post_filename 2>/dev/null || printf '')
origin_platforms_raw=$(blog_read_front_matter_value "$draft_file" origin_platforms 2>/dev/null || printf '')
if [ -z "$post_type" ]; then
  post_type=$(blog_read_front_matter_value "$draft_file" type 2>/dev/null || printf '')
fi
post_type=$(blog_normalize_post_type "$post_type")
origin_platforms_json=$(blog_origin_normalize_platforms_json "$origin_platforms_raw" "$(blog_origin_enabled_platforms_json)")
if [ "$origin_platforms_json" = '[]' ] && [ -z "$origin_platforms_raw" ]; then
  origin_platforms_json=$(blog_origin_default_platforms_json)
fi
blog_save_draft "$draft_id" "$title" "$tags" "$summary" "$content" "$author" draft "" draft "$post_type" "$source_post_path" "$post_filename" "$origin_platforms_json"

printf '{"success":true,"message":"Draft moved back to drafts","draft_id":"%s"}\n' "$(blog_json_escape "$draft_id")"
