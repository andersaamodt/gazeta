#!/bin/sh
# Render public blog index with pagination.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_html_headers

page=$(blog_param page)
case "$page" in ''|*[!0-9]*) page=1 ;; esac
if [ "$page" -lt 1 ]; then
  page=1
fi

posts_per_page=10
catalog_file=$(blog_public_posts_catalog_static_path)
cache_file=$(blog_public_posts_catalog_cache_path)
if [ ! -f "$catalog_file" ] && [ -f "$cache_file" ]; then
  catalog_file=$cache_file
fi
if [ ! -f "$catalog_file" ]; then
  blog_public_posts_catalog_write_artifacts
  catalog_file=$(blog_public_posts_catalog_static_path)
fi

total_posts=$(jq '.posts | length' "$catalog_file" 2>/dev/null || printf '0')
case "$total_posts" in ''|*[!0-9]*) total_posts=0 ;; esac
total_pages=$(( (total_posts + posts_per_page - 1) / posts_per_page ))
if [ "$total_pages" -lt 1 ]; then
  total_pages=1
fi
if [ "$page" -gt "$total_pages" ]; then
  page=$total_pages
fi

start=$(( (page - 1) * posts_per_page + 1 ))
end=$(( start + posts_per_page - 1 ))

printf '<div class="post-list">\n'
if [ "$total_posts" -eq 0 ]; then
  printf '<p>No posts to show yet.</p>\n'
else
  jq -c \
    --argjson start_index $((start - 1)) \
    --argjson end_index "$end" \
    '.posts[$start_index:$end_index][]' \
    "$catalog_file" 2>/dev/null | while IFS= read -r post_json || [ -n "$post_json" ]; do
    url=$(printf '%s\n' "$post_json" | jq -r '.url // ""')
    title=$(printf '%s\n' "$post_json" | jq -r '.title // ""')
    author=$(printf '%s\n' "$post_json" | jq -r '.author // ""')
    reading_minutes=$(printf '%s\n' "$post_json" | jq -r '(.reading_minutes // 1) | tostring')
    published_timestamp=$(printf '%s\n' "$post_json" | jq -r '.published_timestamp // ""')
    pub_date=$(printf '%s\n' "$post_json" | jq -r '.pub_date // ""')
    comment_count=$(printf '%s\n' "$post_json" | jq -r '(.comment_count // 0) | tostring')
    summary=$(printf '%s\n' "$post_json" | jq -r '.summary // ""')
    summary_truncated=$(printf '%s\n' "$post_json" | jq -r '(.summary_truncated // false) | tostring')
    tags_csv=$(printf '%s\n' "$post_json" | jq -r '(.tags // []) | join(",")')
    if [ -z "$pub_date" ]; then
      pub_date="Unknown date"
    fi
    if [ -z "$author" ]; then
      author="Blog Author"
    fi
    post_header_meta_html=$(blog_post_header_meta_html "$author" "$reading_minutes" "$pub_date" "$published_timestamp")

    printf '<article class="post-item">\n'
    printf '  <div class="post-head">\n'
    printf '    <div class="post-head-main">\n'
    printf '      <h2 class="post-title"><a href="%s">%s</a></h2>\n' \
      "$(blog_html_escape "$url")" "$(blog_html_escape "$title")"
    printf '      %s' "$post_header_meta_html"
    printf '    </div>\n'
    printf '    <div class="post-meta">'
    if [ "$comment_count" -gt 0 ]; then
      printf ' <span class="post-comments-count">%s comments</span>' "$(blog_html_escape "$comment_count")"
    else
      printf ' <span class="post-comments-count">0 comments</span>'
    fi
    printf '</div>\n'
    printf '  </div>\n'

    if [ -n "$summary" ]; then
      printf '  <div class="post-summary">%s' "$(blog_html_escape "$summary")"
      if [ "$summary_truncated" = "true" ]; then
        printf ' <a class="post-summary-read-more" href="%s">Read more</a>' "$(blog_html_escape "$url")"
      fi
      printf '</div>\n'
    fi

    if [ -n "$tags_csv" ]; then
      printf '  <div class="tags">\n'
      printf '%s\n' "$tags_csv" | tr ',' '\n' | while IFS= read -r tag; do
        clean=$(printf '%s' "$tag" | sed 's/^ *//;s/ *$//')
        [ -n "$clean" ] || continue
        printf '    <a href="/tags#%s" class="tag">%s</a>\n' \
          "$(blog_html_escape "$clean")" "$(blog_html_escape "$clean")"
      done
      printf '  </div>\n'
    fi

    printf '</article>\n\n'
  done
fi
printf '</div>\n'

if [ "$total_posts" -gt 0 ] && [ "$total_pages" -gt 1 ]; then
  printf '<div class="pagination">\n'
  if [ "$page" -gt 1 ]; then
    prev=$((page - 1))
    printf '  <a class="page-link" href="?page=%s">&laquo; Previous</a>\n' "$prev"
  else
    printf '  <span class="page-link disabled">&laquo; Previous</span>\n'
  fi

  printf '  <span class="page-info">Page %s of %s</span>\n' "$page" "$total_pages"

  if [ "$page" -lt "$total_pages" ]; then
    next=$((page + 1))
    printf '  <a class="page-link" href="?page=%s">Next &raquo;</a>\n' "$next"
  else
    printf '  <span class="page-link disabled">Next &raquo;</span>\n'
  fi
  printf '</div>\n'
fi
