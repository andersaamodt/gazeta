#!/bin/sh
# Manage site zap settings runtime and Wizardry-backed Bitcoin/Lightning installs.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi
if ! blog_plugin_enabled "zaps"; then
  blog_json_error "Zaps plugin is disabled for this site" "plugin_disabled"
  exit 0
fi

action=$(printf '%s' "$(blog_param action)" | tr '[:upper:]' '[:lower:]')
if [ -z "$action" ]; then
  action=status
fi

wizardry_dir=${WIZARDRY_DIR:-${HOME:-}/.wizardry}
wizardry_install_url=$(config-get "$blog_site_conf" wizardry_install_url 2>/dev/null || printf '')
[ -n "$wizardry_install_url" ] || wizardry_install_url=${WIZARDRY_INSTALL_URL:-}
wizardry_repo_url=${WIZARDRY_REMOTE_REPO:-https://github.com/andersaamodt/wizardry.git}
wizardry_remote_cache_ttl=${WIZARDRY_REMOTE_CACHE_TTL:-900}

find_web_wizardry_bin() {
  bin=$(command -v web-wizardry 2>/dev/null || printf '')
  if [ -n "$bin" ] && [ -x "$bin" ]; then
    printf '%s\n' "$bin"
    return 0
  fi
  for candidate in /usr/local/bin/web-wizardry /opt/homebrew/bin/web-wizardry /usr/bin/web-wizardry /bin/web-wizardry; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

resolve_wizardry_dir() {
  configured=${WIZARDRY_DIR-}
  if [ -n "$configured" ] && [ -x "$configured/spells/web/build" ]; then
    printf '%s\n' "$configured"
    return 0
  fi
  resolved=$(blog_resolve_wizardry_dir 2>/dev/null || printf '')
  if [ -n "$resolved" ] && [ -x "$resolved/spells/web/build" ]; then
    printf '%s\n' "$resolved"
    return 0
  fi
  if [ -n "${HOME-}" ] && [ -x "$HOME/.wizardry/spells/web/build" ]; then
    printf '%s\n' "$HOME/.wizardry"
    return 0
  fi
  for candidate in /usr/local/share/wizardry /opt/homebrew/share/wizardry /usr/share/wizardry; do
    if [ -x "$candidate/spells/web/build" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  web_wizardry_bin=$(find_web_wizardry_bin 2>/dev/null || printf '')
  if [ -n "$web_wizardry_bin" ]; then
    resolved=$(CDPATH= cd -- "$(dirname "$web_wizardry_bin")/../.." 2>/dev/null && pwd -P)
    if [ -n "$resolved" ] && [ -x "$resolved/spells/web/build" ]; then
      printf '%s\n' "$resolved"
      return 0
    fi
  fi
  return 1
}

refresh_wizardry_runtime() {
  resolved=$(resolve_wizardry_dir 2>/dev/null || printf '')
  if [ -n "$resolved" ]; then
    wizardry_dir=$resolved
  fi
  wizardry_bin=$(find_web_wizardry_bin 2>/dev/null || printf '')
  if [ ! -x "$wizardry_dir/spells/web/build" ] && [ -n "$wizardry_bin" ]; then
    inferred_dir=$(CDPATH= cd -- "$(dirname "$wizardry_bin")/../.." 2>/dev/null && pwd -P)
    if [ -n "$inferred_dir" ]; then
      wizardry_dir=$inferred_dir
    fi
  fi
}

wizardry_installed() {
  refresh_wizardry_runtime
  if [ -x "$wizardry_dir/spells/web/build" ]; then
    return 0
  fi
  [ -n "$wizardry_bin" ]
}

bitcoin_installed() {
  refresh_wizardry_runtime
  if [ -x "$wizardry_dir/spells/.arcana/bitcoin/is-bitcoin-installed" ]; then
    wizardry_path=$(blog_wizardry_exec_path "$wizardry_dir")
    PATH="$wizardry_path" WIZARDRY_DIR="$wizardry_dir" HOME="${HOME-}" "$wizardry_dir/spells/.arcana/bitcoin/is-bitcoin-installed" >/dev/null 2>&1
    return $?
  fi
  command -v bitcoin-cli >/dev/null 2>&1
}

lightning_installed() {
  refresh_wizardry_runtime
  if [ -x "$wizardry_dir/spells/.arcana/lightning/is-lightning-installed" ]; then
    wizardry_path=$(blog_wizardry_exec_path "$wizardry_dir")
    PATH="$wizardry_path" WIZARDRY_DIR="$wizardry_dir" HOME="${HOME-}" "$wizardry_dir/spells/.arcana/lightning/is-lightning-installed" >/dev/null 2>&1
    return $?
  fi
  command -v lightning-cli >/dev/null 2>&1
}

wizardry_git_repo() {
  refresh_wizardry_runtime
  command -v git >/dev/null 2>&1 || return 1
  git -C "$wizardry_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

wizardry_local_revision() {
  wizardry_git_repo || return 1
  git -C "$wizardry_dir" rev-parse HEAD 2>/dev/null
}

wizardry_remote_cache_file() {
  printf '%s/zaps-wizardry-remote-main.sha\n' "$blog_state_dir"
}

wizardry_remote_revision() {
  command -v git >/dev/null 2>&1 || return 1
  cache_file=$(wizardry_remote_cache_file)
  now_epoch=$(date +%s 2>/dev/null || printf '')
  if [ -n "$now_epoch" ] && [ -f "$cache_file" ]; then
    cache_mtime=$(stat -f %m "$cache_file" 2>/dev/null || stat -c %Y "$cache_file" 2>/dev/null || printf '')
    if [ -n "$cache_mtime" ]; then
      cache_age=$((now_epoch - cache_mtime))
      if [ "$cache_age" -ge 0 ] && [ "$cache_age" -lt "$wizardry_remote_cache_ttl" ]; then
        sed -n '1p' "$cache_file"
        return 0
      fi
    fi
  fi
  remote_sha=$(git ls-remote "$wizardry_repo_url" refs/heads/main 2>/dev/null | awk 'NR == 1 { print $1 }')
  case "$remote_sha" in
    ''|*[!0-9a-f]*) return 1 ;;
  esac
  mkdir -p "$blog_state_dir" >/dev/null 2>&1 || true
  tmp_cache_file="$cache_file.tmp.$$"
  if printf '%s\n' "$remote_sha" > "$tmp_cache_file" 2>/dev/null; then
    mv "$tmp_cache_file" "$cache_file" 2>/dev/null || rm -f "$tmp_cache_file"
  fi
  printf '%s\n' "$remote_sha"
}

wizardry_update_available() {
  local_sha=$(wizardry_local_revision 2>/dev/null || printf '')
  remote_sha=$(wizardry_remote_revision 2>/dev/null || printf '')
  [ -n "$local_sha" ] || return 1
  [ -n "$remote_sha" ] || return 1
  [ "$local_sha" != "$remote_sha" ]
}

bool_json() {
  if "$@"; then
    printf 'true'
  else
    printf 'false'
  fi
}

runtime_json() {
  refresh_wizardry_runtime
  printf '{'
  printf '"wizardry_installed":%s,' "$(bool_json wizardry_installed)"
  printf '"wizardry_path":"%s",' "$(blog_json_escape "$wizardry_dir")"
  printf '"wizardry_update_available":%s,' "$(bool_json wizardry_update_available)"
  printf '"bitcoin_installed":%s,' "$(bool_json bitcoin_installed)"
  printf '"lightning_installed":%s' "$(bool_json lightning_installed)"
  printf '}'
}

emit_success() {
  message=${1-OK}
  log_text=${2-}
  printf '{"success":true,"message":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

emit_failure() {
  message=${1-Request failed}
  code=${2-zaps_failed}
  log_text=${3-}
  printf '{"success":false,"error":"%s","code":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(blog_json_escape "$code")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

log_has_sudo_tty_failure() {
  log_path=${1-}
  [ -n "$log_path" ] || return 1
  [ -f "$log_path" ] || return 1
  if rg -q 'sudo: a terminal is required to read the password|sudo: a password is required' "$log_path" 2>/dev/null; then
    return 0
  fi
  grep -q 'sudo: a terminal is required to read the password' "$log_path" 2>/dev/null && return 0
  grep -q 'sudo: a password is required' "$log_path" 2>/dev/null
}

ensure_wizardry() {
  if wizardry_installed; then
    return 0
  fi

  if [ -z "$wizardry_install_url" ]; then
    printf 'Wizardry install URL is not configured. Set wizardry_install_url in site.conf or WIZARDRY_INSTALL_URL.\n' >&2
    return 1
  fi

  tmp_installer=$(mktemp "${TMPDIR:-/tmp}/wizardry-install.XXXXXX")
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$wizardry_install_url" -o "$tmp_installer"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$tmp_installer" "$wizardry_install_url"
  else
    rm -f "$tmp_installer"
    printf 'curl or wget is required to bootstrap Wizardry.\n' >&2
    return 1
  fi

  sh "$tmp_installer"
  rm -f "$tmp_installer"
  refresh_wizardry_runtime
  wizardry_installed
}

run_install_spell() {
  spell_path=$1
  newline_count=$2
  log_file=$3
  wizardry_path=$(blog_wizardry_exec_path "$wizardry_dir")

  input_file=$(mktemp "${TMPDIR:-/tmp}/blog-zaps-input.XXXXXX")
  i=0
  while [ "$i" -lt "$newline_count" ]; do
    printf '\n' >> "$input_file"
    i=$((i + 1))
  done

  if command -v timeout >/dev/null 2>&1; then
    set +e
    timeout 1800 sh -c 'PATH="$1" WIZARDRY_DIR="$2" HOME="$3" "$4" < "$5"' sh "$wizardry_path" "$wizardry_dir" "$HOME" "$spell_path" "$input_file" >> "$log_file" 2>&1
    status=$?
    set -e
  else
    set +e
    sh -c 'PATH="$1" WIZARDRY_DIR="$2" HOME="$3" "$4" < "$5"' sh "$wizardry_path" "$wizardry_dir" "$HOME" "$spell_path" "$input_file" >> "$log_file" 2>&1
    status=$?
    set -e
  fi

  rm -f "$input_file"
  return "$status"
}

case "$action" in
  status)
    emit_success "Zap runtime loaded."
    exit 0
    ;;
  install_wizardry|install_bitcoin|install_lightning) ;;
  *)
    emit_failure "Unknown action" "invalid_action"
    exit 0
    ;;
esac

log_file=$(mktemp "${TMPDIR:-/tmp}/blog-zaps-log.XXXXXX")
trap 'rm -f "$log_file"' EXIT HUP INT TERM

wizardry_was_installed=0
if wizardry_installed; then
  wizardry_was_installed=1
fi

printf 'Ensuring Wizardry is installed at %s\n' "$wizardry_dir" >> "$log_file"
if ! ensure_wizardry >> "$log_file" 2>&1; then
  emit_failure "Could not install or locate Wizardry." "wizardry_bootstrap_failed" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
  exit 0
fi

case "$action" in
  install_wizardry)
    if [ "$wizardry_was_installed" -eq 0 ]; then
      emit_success "Wizardry install completed." "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
      exit 0
    fi
    if wizardry_update_available; then
      spell="$wizardry_dir/spells/.wizardry/update-wizardry"
      if [ ! -x "$spell" ]; then
        emit_failure "Wizardry updater was not found." "missing_wizardry_updater" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
        exit 0
      fi
      printf 'Running %s\n' "$spell" >> "$log_file"
      if ! run_install_spell "$spell" 0 "$log_file"; then
        emit_failure "Wizardry update failed. Check the log output." "wizardry_update_failed" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
        exit 0
      fi
      emit_success "Wizardry update completed." "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
      exit 0
    fi
    emit_success "Wizardry is already up to date." "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
    ;;
  install_bitcoin)
    spell="$wizardry_dir/spells/.arcana/bitcoin/install-bitcoin"
    if [ ! -x "$spell" ]; then
      emit_failure "Wizardry Bitcoin installer was not found." "missing_bitcoin_installer" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
      exit 0
    fi
    printf 'Running %s\n' "$spell" >> "$log_file"
    if ! run_install_spell "$spell" 6 "$log_file"; then
      if log_has_sudo_tty_failure "$log_file"; then
        emit_failure "Bitcoin install needs sudo on this server. Web installs cannot enter a password; run it in a terminal, grant passwordless sudo for the install account, or add a non-sudo install path in Wizardry." "bitcoin_install_requires_sudo" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
        exit 0
      fi
      emit_failure "Bitcoin install failed. Check the log output." "bitcoin_install_failed" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
      exit 0
    fi
    emit_success "Bitcoin install completed." "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
    ;;
  install_lightning)
    spell="$wizardry_dir/spells/.arcana/lightning/install-lightning"
    if [ ! -x "$spell" ]; then
      emit_failure "Wizardry Lightning installer was not found." "missing_lightning_installer" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
      exit 0
    fi
    printf 'Running %s\n' "$spell" >> "$log_file"
    if ! run_install_spell "$spell" 4 "$log_file"; then
      emit_failure "Lightning install failed. Check the log output." "lightning_install_failed" "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
      exit 0
    fi
    emit_success "Lightning install completed." "$(tail -n 120 "$log_file" 2>/dev/null || printf '')"
    ;;
esac
