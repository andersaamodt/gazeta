#!/bin/sh
# Report zap readiness for a site whose Lightning stack is managed in Headquarters.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi
if ! blog_plugin_enabled "zaps"; then
  blog_json_error "Zaps plugin is disabled for this site" "plugin_disabled"
  exit 0
fi

action=$(printf '%s' "$(blog_param action)" | tr '[:upper:]' '[:lower:]')
[ -n "$action" ] || action=status

bool_json_value() {
  case "${1-}" in
    true|1|yes|on|ok) printf 'true' ;;
    *) printf 'false' ;;
  esac
}

http_head_ok() {
  url=${1-}
  [ -n "$url" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsSI --max-time 8 "$url" >/dev/null 2>&1
}

lud16_localpart() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  case "$value" in
    *@*) printf '%s\n' "${value%@*}" ;;
    *) return 1 ;;
  esac
}

lud16_domain() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  case "$value" in
    *@*) printf '%s\n' "${value#*@}" | tr '[:upper:]' '[:lower:]' ;;
    *) return 1 ;;
  esac
}

zap_endpoint_url_for_lud16() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  localpart=$(lud16_localpart "$value" 2>/dev/null || printf '')
  domain=$(lud16_domain "$value" 2>/dev/null || printf '')
  if [ -z "$localpart" ] || ! blog_valid_public_host "$domain"; then
    printf '\n'
    return 0
  fi
  printf 'https://%s/.well-known/lnurlp/%s\n' "$domain" "$localpart"
}

zap_endpoint_live() {
  endpoint_url=${1-}
  [ -n "$endpoint_url" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsS --max-time 8 "$endpoint_url" 2>/dev/null | grep -Eq '"callback"|"allowsNostr"|"nostrPubkey"'
}

lightning_public_host() {
  host=$(config-get "$blog_site_conf" lightning_public_host 2>/dev/null || printf '')
  host=$(blog_normalize_public_host "$host")
  if blog_valid_public_host "$host"; then
    printf '%s\n' "$host"
    return 0
  fi
  effective=$(blog_zap_effective_lud16 2>/dev/null || printf '')
  domain=$(lud16_domain "$effective" 2>/dev/null || printf '')
  if blog_valid_public_host "$domain"; then
    printf '%s\n' "$domain"
    return 0
  fi
  printf '%s\n' "$(blog_normalize_public_host "${HTTP_HOST:-${SERVER_NAME:-}}")"
}

lightning_public_port() {
  port=$(config-get "$blog_site_conf" lightning_public_port 2>/dev/null || printf '')
  port=$(printf '%s' "$port" | tr -d '\r\n[:space:]')
  case "$port" in
    ''|*[!0-9]*) checksum=$(printf '%s\n' "$blog_site_name" | cksum | awk '{print $1}'); port=$((19000 + ((checksum % 1000) * 2))) ;;
  esac
  printf '%s\n' "$port"
}

lightning_public_address() {
  host=$(lightning_public_host)
  port=$(lightning_public_port)
  if [ -n "$host" ] && [ -n "$port" ]; then
    printf '%s:%s\n' "$host" "$port"
    return 0
  fi
  printf '\n'
}

lightning_dir() {
  printf '%s/lightning\n' "$blog_site_data"
}

zap_receipts_dir() {
  printf '%s/zaps/state/receipts\n' "$blog_site_data"
}

lightning_cli_json() {
  command -v lightning-cli >/dev/null 2>&1 || return 1
  lightning-cli --lightning-dir="$(lightning_dir)" "$@" 2>/dev/null
}

recent_zaps_json() {
  receipts_dir=$(zap_receipts_dir)
  if [ ! -d "$receipts_dir" ] || ! command -v jq >/dev/null 2>&1; then
    printf '[]\n'
    return 0
  fi
  find "$receipts_dir" -maxdepth 1 -type f -name '*.json' -print 2>/dev/null | while IFS= read -r receipt_file; do
    jq -c '
      def tag($name):
        (.event.tags // [])
        | map(select((.[0] // "") == $name))
        | first
        | if type == "array" then . else [] end;
      def tagv($name): (tag($name)[1] // "");
      def as_number: tonumber? // 0;
      (tagv("description") | fromjson? // {}) as $request
      | (tagv("amount") | as_number) as $amount_msat
      | {
          received_at: ((.event.created_at // .published_at // 0) | as_number),
          published_at: ((.published_at // 0) | as_number),
          event_id: ((.event.id // "") | tostring),
          amount_msat: $amount_msat,
          amount_sats: (($amount_msat / 1000) | floor),
          sender_pubkey: (tagv("P") | tostring),
          recipient_pubkey: (tagv("p") | tostring),
          post_event_id: (tagv("e") | tostring),
          post_address: (tagv("a") | tostring),
          post_kind: (tagv("k") | tostring),
          bolt11: (tagv("bolt11") | tostring),
          relay_count: ((.relay_count // 0) | as_number),
          note: (($request.content // "") | tostring),
          request_id: (($request.id // "") | tostring),
          request_pubkey: (($request.pubkey // "") | tostring)
        }
    ' "$receipt_file" 2>/dev/null || true
  done | jq -s 'sort_by(.received_at, .published_at) | reverse | .[:50]' 2>/dev/null || printf '[]\n'
}

runtime_json() {
  zaps_enabled=$(blog_zaps_enabled 2>/dev/null || printf 'false')
  configured_lud16=$(blog_zap_lud16 2>/dev/null || printf '')
  effective_lud16=$(blog_zap_effective_lud16 2>/dev/null || printf '')
  lud16_source=$(blog_zap_lud16_source 2>/dev/null || printf 'unavailable')
  demo_wallet_npub=$(blog_nostr_site_npub 2>/dev/null || printf '')
  lightning_online=false
  lightning_synced=false
  num_peers=0
  inbound_liquidity_sats=0
  public_address=$(lightning_public_address)
  zap_endpoint_url=$(zap_endpoint_url_for_lud16 "$effective_lud16")
  zap_endpoint_ready=false
  if getinfo_json=$(lightning_cli_json getinfo); then
    lightning_online=true
    lightning_synced=$(printf '%s\n' "$getinfo_json" | jq -r '
      if ((.warning_bitcoind_sync // "") | tostring | length) > 0 then
        "false"
      else
        "true"
      end
    ' 2>/dev/null || printf 'false')
    num_peers=$(printf '%s\n' "$getinfo_json" | jq -r '.num_peers // 0' 2>/dev/null || printf '0')
  fi
  if listfunds_json=$(lightning_cli_json listfunds); then
    inbound_liquidity_sats=$(printf '%s\n' "$listfunds_json" | jq -r '
      def msat: ((. // "0msat") | tostring | sub("msat$"; "") | tonumber? // 0);
      [(.channels // [])[]? | ((.amount_msat | msat) - (.our_amount_msat | msat))] | add // 0 | floor / 1000 | floor
    ' 2>/dev/null || printf '0')
  fi
  if zap_endpoint_live "$zap_endpoint_url"; then
    zap_endpoint_ready=true
  fi
  can_receive=false
  if [ "$lightning_online" = true ] && [ "$lightning_synced" = true ] && [ "$zap_endpoint_ready" = true ] && [ "${inbound_liquidity_sats:-0}" -gt 0 ]; then
    can_receive=true
  fi

  printf '{'
  printf '"headquarters_managed":true,'
  printf '"zaps_enabled":%s,' "$(bool_json_value "$zaps_enabled")"
  printf '"configured_lud16":"%s",' "$(blog_json_escape "$configured_lud16")"
  printf '"effective_lud16":"%s",' "$(blog_json_escape "$effective_lud16")"
  printf '"lud16_source":"%s",' "$(blog_json_escape "$lud16_source")"
  printf '"demo_wallet_available":%s,' "$(bool_json_value "$(test -n "$demo_wallet_npub" && printf true || printf false)")"
  printf '"demo_wallet_npub":"%s",' "$(blog_json_escape "$demo_wallet_npub")"
  printf '"site_signer_ready":%s,' "$(bool_json_value "$(test -n "$demo_wallet_npub" && printf true || printf false)")"
  printf '"lightning_online":%s,' "$(bool_json_value "$lightning_online")"
  printf '"lightning_synced":%s,' "$(bool_json_value "$lightning_synced")"
  printf '"num_peers":%s,' "$(printf '%s' "${num_peers:-0}" | tr -dc '0-9')"
  printf '"lightning_public_address":"%s",' "$(blog_json_escape "$public_address")"
  printf '"inbound_liquidity_sats":%s,' "$(printf '%s' "${inbound_liquidity_sats:-0}" | tr -dc '0-9')"
  printf '"can_receive_zaps":%s,' "$(bool_json_value "$can_receive")"
  printf '"zap_endpoint_url":"%s",' "$(blog_json_escape "$zap_endpoint_url")"
  printf '"zap_endpoint_ready":%s,' "$(bool_json_value "$zap_endpoint_ready")"
  printf '"recent_zaps":%s' "$(recent_zaps_json)"
  printf '}\n'
}

emit_success() {
  message=${1-OK}
  log_text=${2-}
  printf '{"success":true,"message":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

emit_failure() {
  message=${1-Request failed}
  code=${2-zaps_failed}
  log_text=${3-}
  printf '{"success":false,"error":"%s","code":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(blog_json_escape "$code")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

case "$action" in
  status)
    emit_success "Zap runtime loaded."
    exit 0
    ;;
  install_wizardry|install_bitcoin|install_lightning)
    emit_failure "Provision Bitcoin, Core Lightning, and the Lightning Address endpoint from the dedicated payments host in Headquarters." "managed_externally"
    exit 0
    ;;
  *)
    emit_failure "Unknown action" "invalid_action"
    exit 0
    ;;
esac
