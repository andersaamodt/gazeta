#!/bin/sh
# Report zap readiness for a site whose BTCPay + CLN stack is managed in Headquarters.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi
if ! blog_plugin_enabled "zaps"; then
  blog_json_error "Zaps plugin is disabled for this site" "plugin_disabled"
  exit 0
fi

action=$(printf '%s' "$(blog_param action)" | tr '[:upper:]' '[:lower:]')
[ -n "$action" ] || action=status

bool_json_value() {
  case "${1-}" in
    true|1|yes|on|ok) printf 'true' ;;
    *) printf 'false' ;;
  esac
}

http_head_ok() {
  url=${1-}
  [ -n "$url" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsSI --max-time 8 "$url" >/dev/null 2>&1
}

lud16_localpart() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  case "$value" in
    *@*) printf '%s\n' "${value%@*}" ;;
    *) return 1 ;;
  esac
}

lud16_domain() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  case "$value" in
    *@*) printf '%s\n' "${value#*@}" | tr '[:upper:]' '[:lower:]' ;;
    *) return 1 ;;
  esac
}

zap_endpoint_url_for_lud16() {
  value=$(printf '%s' "${1-}" | tr -d '\r\n[:space:]')
  localpart=$(lud16_localpart "$value" 2>/dev/null || printf '')
  domain=$(lud16_domain "$value" 2>/dev/null || printf '')
  if [ -z "$localpart" ] || ! blog_valid_public_host "$domain"; then
    printf '\n'
    return 0
  fi
  printf 'https://%s/.well-known/lnurlp/%s\n' "$domain" "$localpart"
}

zap_endpoint_live() {
  endpoint_url=${1-}
  [ -n "$endpoint_url" ] || return 1
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsS --max-time 8 "$endpoint_url" 2>/dev/null | grep -Eq '"callback"|"allowsNostr"'
}

runtime_json() {
  zaps_enabled=$(blog_zaps_enabled 2>/dev/null || printf 'false')
  configured_lud16=$(blog_zap_lud16 2>/dev/null || printf '')
  effective_lud16=$(blog_zap_effective_lud16 2>/dev/null || printf '')
  lud16_source=$(blog_zap_lud16_source 2>/dev/null || printf 'unavailable')
  demo_wallet_npub=$(blog_nostr_site_npub 2>/dev/null || printf '')
  btcpay_host=$(blog_resolve_btcpay_host)
  btcpay_url=$(blog_btcpay_url_for_host "$btcpay_host" "$(blog_resolve_btcpay_rootpath)")
  btcpay_online=false
  zap_endpoint_url=$(zap_endpoint_url_for_lud16 "$effective_lud16")
  zap_endpoint_ready=false
  if http_head_ok "$btcpay_url"; then
    btcpay_online=true
  fi
  if zap_endpoint_live "$zap_endpoint_url"; then
    zap_endpoint_ready=true
  fi

  printf '{'
  printf '"headquarters_managed":true,'
  printf '"zaps_enabled":%s,' "$(bool_json_value "$zaps_enabled")"
  printf '"configured_lud16":"%s",' "$(blog_json_escape "$configured_lud16")"
  printf '"effective_lud16":"%s",' "$(blog_json_escape "$effective_lud16")"
  printf '"lud16_source":"%s",' "$(blog_json_escape "$lud16_source")"
  printf '"demo_wallet_available":%s,' "$(bool_json_value "$(test -n "$demo_wallet_npub" && printf true || printf false)")"
  printf '"demo_wallet_npub":"%s",' "$(blog_json_escape "$demo_wallet_npub")"
  printf '"site_signer_ready":%s,' "$(bool_json_value "$(test -n "$demo_wallet_npub" && printf true || printf false)")"
  printf '"btcpay_host":"%s",' "$(blog_json_escape "$btcpay_host")"
  printf '"btcpay_url":"%s",' "$(blog_json_escape "$btcpay_url")"
  printf '"btcpay_online":%s,' "$(bool_json_value "$btcpay_online")"
  printf '"zap_endpoint_url":"%s",' "$(blog_json_escape "$zap_endpoint_url")"
  printf '"zap_endpoint_ready":%s' "$(bool_json_value "$zap_endpoint_ready")"
  printf '}\n'
}

emit_success() {
  message=${1-OK}
  log_text=${2-}
  printf '{"success":true,"message":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

emit_failure() {
  message=${1-Request failed}
  code=${2-zaps_failed}
  log_text=${3-}
  printf '{"success":false,"error":"%s","code":"%s","runtime":%s,"log":"%s"}\n' \
    "$(blog_json_escape "$message")" \
    "$(blog_json_escape "$code")" \
    "$(runtime_json)" \
    "$(blog_json_escape "$log_text")"
}

case "$action" in
  status)
    emit_success "Zap runtime loaded."
    exit 0
    ;;
  install_wizardry|install_bitcoin|install_lightning)
    emit_failure "Provision BTCPay + CLN and the Lightning Address endpoint from Headquarters." "managed_externally"
    exit 0
    ;;
  *)
    emit_failure "Unknown action" "invalid_action"
    exit 0
    ;;
esac
