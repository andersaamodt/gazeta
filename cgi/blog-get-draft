#!/bin/sh
# Load a single draft (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true; then
  exit 0
fi

draft_id=$(blog_param draft_id)
if [ -z "$draft_id" ]; then
  blog_json_error "draft_id is required" "invalid_request"
  exit 0
fi

draft_file=$(blog_draft_resolve_file_path "$draft_id" 2>/dev/null || printf '')
if [ -z "$draft_file" ] || [ ! -f "$draft_file" ]; then
  blog_json_error "Draft not found" "not_found"
  exit 0
fi

title=$(blog_read_front_matter_value "$draft_file" title 2>/dev/null || printf 'Untitled')
tags=$(blog_read_front_matter_value "$draft_file" tags 2>/dev/null || printf '')
summary=$(blog_read_front_matter_value "$draft_file" summary 2>/dev/null || printf '')
publish_mode=$(blog_read_front_matter_value "$draft_file" publish_mode 2>/dev/null || printf 'draft')
status=$(blog_read_front_matter_value "$draft_file" status 2>/dev/null || printf 'draft')
scheduled_at=$(blog_read_front_matter_value "$draft_file" scheduled_at 2>/dev/null || printf '')
created_at=$(blog_read_front_matter_value "$draft_file" created_at 2>/dev/null || printf '')
updated_at=$(blog_read_front_matter_value "$draft_file" updated_at 2>/dev/null || printf '')
content=$(blog_read_markdown_body "$draft_file" 2>/dev/null || printf '')

printf '{"success":true,"draft":{'
resolved_draft_id=$(blog_read_front_matter_value "$draft_file" draft_id 2>/dev/null || printf '')
[ -n "$resolved_draft_id" ] || resolved_draft_id="$draft_id"
printf '"draft_id":"%s",' "$(blog_json_escape "$resolved_draft_id")"
printf '"title":"%s",' "$(blog_json_escape "$title")"
printf '"tags":"%s",' "$(blog_json_escape "$tags")"
printf '"summary":"%s",' "$(blog_json_escape "$summary")"
printf '"publish_mode":"%s",' "$(blog_json_escape "$publish_mode")"
printf '"status":"%s",' "$(blog_json_escape "$status")"
printf '"scheduled_at":"%s",' "$(blog_json_escape "$scheduled_at")"
printf '"created_at":"%s",' "$(blog_json_escape "$created_at")"
printf '"updated_at":"%s",' "$(blog_json_escape "$updated_at")"
printf '"content":"%s"' "$(blog_json_escape "$content")"
printf '}}\n'
