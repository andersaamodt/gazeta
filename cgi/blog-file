#!/bin/sh
# Serve a private/public attachment.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body

resolve_file_id() {
  from_query=$(blog_param file_id)
  if [ -n "$from_query" ]; then
    printf '%s\n' "$from_query"
    return 0
  fi

  path_info=${PATH_INFO-}
  if [ -n "$path_info" ]; then
    from_path=$(printf '%s' "$path_info" | sed 's#^/##; s#/.*$##')
    if [ -n "$from_path" ]; then
      printf '%s\n' "$from_path"
      return 0
    fi
  fi

  uri=${REQUEST_URI-}
  case "$uri" in
    *'/files/'*)
      from_uri=$(printf '%s' "$uri" | sed 's/[?].*$//' | sed 's#.*\/files\/##' | sed 's#/.*$##')
      if [ -n "$from_uri" ]; then
        printf '%s\n' "$from_uri"
        return 0
      fi
      ;;
    *'/cgi/files/'*)
      from_uri=$(printf '%s' "$uri" | sed 's/[?].*$//' | sed 's#.*\/cgi\/files\/##' | sed 's#/.*$##')
      if [ -n "$from_uri" ]; then
        printf '%s\n' "$from_uri"
        return 0
      fi
      ;;
    *'/cgi/blog-file/'*)
      from_uri=$(printf '%s' "$uri" | sed 's/[?].*$//' | sed 's#.*\/cgi\/blog-file\/##' | sed 's#/.*$##')
      if [ -n "$from_uri" ]; then
        printf '%s\n' "$from_uri"
        return 0
      fi
      ;;
  esac
  printf '\n'
}

file_id=$(resolve_file_id)
file_id=$(printf '%s' "$file_id" | sed 's/[^A-Za-z0-9._~-]//g')
req_token=$(blog_param session_token)
req_csrf=$(blog_param csrf_token)
record_path=$(blog_file_record_path "$file_id" 2>/dev/null || printf '')
if [ -z "$file_id" ] || [ ! -f "$record_path" ]; then
  http-status 404 "Not Found"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'File not found\n'
  exit 0
fi

is_admin=false
if [ -n "$req_token" ] && blog_load_session "$req_token"; then
  if [ -n "$req_csrf" ] && [ "$req_csrf" = "$BLOG_SESSION_CSRF" ] && blog_user_is_admin "$BLOG_SESSION_USERNAME"; then
    is_admin=true
    blog_extend_session
  fi
fi

if [ "$is_admin" != "true" ] && ! blog_file_is_public_effective "$file_id"; then
  http-status 403 "Forbidden"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'File is private\n'
  exit 0
fi

file_path=$(blog_file_resolve_disk_path "$file_id" 2>/dev/null || printf '')
if [ -z "$file_path" ] || [ ! -f "$file_path" ]; then
  http-status 404 "Not Found"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'File not found\n'
  exit 0
fi

mime_type=$(config-get "$record_path" mime_type 2>/dev/null || printf '')
if [ -z "$mime_type" ]; then
  mime_type=$(blog_file_content_type "$file_path" application/octet-stream)
fi
safe_name=$(config-get "$record_path" safe_name 2>/dev/null || printf 'download.bin')
storage_rel=$(config-get "$record_path" storage_rel 2>/dev/null || printf '')
size_bytes=$(blog_file_size_bytes "$file_path" 2>/dev/null || printf '')
disposition='inline'
case "$mime_type" in
  image/*|audio/*|video/*|text/*|application/pdf) disposition='inline' ;;
  *) disposition='attachment' ;;
esac

http-status 200 "OK"
http-header "Content-Type" "$mime_type"
if blog_file_is_public_effective "$file_id"; then
  http-header "Cache-Control" "public, max-age=31536000, immutable"
else
  http-header "Cache-Control" "private, no-store"
fi
http-header "Content-Disposition" "$disposition; filename=\"$safe_name\""
if [ -n "$storage_rel" ]; then
  http-header "X-Accel-Redirect" "/__site-files/$storage_rel"
elif [ -n "$size_bytes" ]; then
  http-header "Content-Length" "$size_bytes"
fi
http-end-headers
if [ -z "$storage_rel" ]; then
  cat "$file_path"
fi
