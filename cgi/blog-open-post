#!/bin/sh
# Open a post safely: ensure built page exists, then redirect.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body

path=$(blog_param path)
if [ -z "$path" ]; then
  path=${PATH_INFO-}
fi
if [ -z "$path" ]; then
  uri=${REQUEST_URI-}
  case "$uri" in
    *'/cgi/blog-open-post/'*)
      path=${uri#*'/cgi/blog-open-post/'}
      path=${path%%\?*}
      ;;
  esac
fi
if [ -z "$path" ]; then
  http-status 400 "Bad Request"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'Missing post path\n'
  exit 0
fi

md_file=$(blog_resolve_post_markdown_file "$path" 2>/dev/null || printf '')
if [ -z "$md_file" ]; then
  http-status 400 "Bad Request"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'Invalid path\n'
  exit 0
fi
if [ ! -f "$md_file" ] && blog_nostr_bridge_enabled; then
  blog_nostr_rebuild_derived >/dev/null 2>&1 || true
  md_file=$(blog_resolve_post_markdown_file "$path" 2>/dev/null || printf '')
fi
if [ ! -f "$md_file" ]; then
  http-status 404 "Not Found"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'Post not found\n'
  exit 0
fi

visibility=$(blog_read_front_matter_value "$md_file" visibility 2>/dev/null || printf 'public')
if [ -z "$visibility" ]; then
  visibility=public
fi
if [ "$visibility" != "public" ]; then
  http-status 404 "Not Found"
  http-header "Content-Type" "text/plain; charset=utf-8"
  http-end-headers
  printf 'Post not found\n'
  exit 0
fi

post_nav_title() {
  file=${1-}
  if [ -z "$file" ] || [ ! -f "$file" ]; then
    printf ''
    return 0
  fi
  title=$(blog_read_front_matter_value "$file" title 2>/dev/null || printf '')
  post_type=$(blog_read_front_matter_value "$file" post_type 2>/dev/null || printf '')
  if [ -z "$post_type" ]; then
    post_type=$(blog_read_front_matter_value "$file" type 2>/dev/null || printf '')
  fi
  post_type=$(blog_normalize_post_type "$post_type")
  body=$(blog_read_markdown_body "$file" 2>/dev/null || printf '')
  blog_effective_post_title "$title" "$body" "$post_type"
}

post_nav_json() {
  file=${1-}
  label=${2-}
  cls=${3-}
  if [ -z "$file" ] || [ ! -f "$file" ]; then
    blog_post_nav_column_html "$label" "$cls"
    return 0
  fi
  title=$(post_nav_title "$file")
  url=$(blog_rel_post_html_url "$file")
  blog_post_nav_column_html "$label" "$cls" "$url" "$title"
}

blog_post_type_label() {
  printf '%s' "${1-post}" | sed 's/[_-]\{1,\}/ /g' | awk '
    {
      for (i = 1; i <= NF; i++) {
        $i = toupper(substr($i, 1, 1)) substr($i, 2)
      }
      print
    }
  '
}

post_end_tags_html=''
post_type=$(blog_read_front_matter_value "$md_file" post_type 2>/dev/null || printf '')
if [ -z "$post_type" ]; then
  post_type=$(blog_read_front_matter_value "$md_file" type 2>/dev/null || printf '')
fi
post_type=$(blog_normalize_post_type "$post_type")
published_at=$(blog_read_front_matter_value "$md_file" published_at 2>/dev/null || printf '')
post_year=$(printf '%s' "$published_at" | cut -c1-4)
case "$post_year" in ''|*[!0-9]*) post_year='' ;; esac
tags_raw=$(blog_read_front_matter_value "$md_file" tags 2>/dev/null || printf '')
tags_csv=$(printf '%s' "$tags_raw" | sed "s/^\[//;s/\]$//;s/\"//g;s/'//g")
tags_norm=$(blog_normalize_tags "$tags_csv")
if [ -n "$post_type$post_year$tags_norm" ]; then
  tags_buf=$(mktemp "${TMPDIR:-/tmp}/blog-open-post-tags.XXXXXX")
  {
    printf '<section class="post-end-tags">'
    printf '<div class="tags post-context-tags">'
    if [ -n "$post_type" ]; then
      printf '<a class="tag blog-type-pill" href="/blog">%s</a>' \
        "$(blog_html_escape "$(blog_post_type_label "$post_type")")"
    fi
    if [ -n "$post_year" ]; then
      printf '<a class="tag blog-year-pill" href="/blog">%s</a>' \
        "$(blog_html_escape "$post_year")"
    fi
    printf '%s\n' "$tags_norm" | tr ',' '\n' | while IFS= read -r tag; do
      clean=$(printf '%s' "$tag" | sed 's/^ *//;s/ *$//')
      [ -n "$clean" ] || continue
      clean_key=$(printf '%s' "$clean" | tr '[:upper:]' '[:lower:]')
      type_key=$(printf '%s' "$post_type" | tr '[:upper:]' '[:lower:]')
      type_label_key=$(blog_post_type_label "$post_type" | tr '[:upper:]' '[:lower:]')
      if [ "$clean_key" = "$type_key" ] || [ "$clean_key" = "$type_label_key" ] || { [ -n "$post_year" ] && [ "$clean_key" = "$post_year" ]; }; then
        continue
      fi
      printf '<a class="tag" href="/tags#%s">%s</a>' \
        "$(blog_html_escape "$clean")" \
        "$(blog_html_escape "$clean")"
    done
    printf '</div></section>'
  } > "$tags_buf"
  post_end_tags_html=$(cat "$tags_buf")
  rm -f "$tags_buf"
fi

posts_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-open-post-nav.XXXXXX")
blog_collect_public_posts "$posts_tmp"
found=0
newer_file=''
older_file=''
prev_file=''
while IFS= read -r post_file; do
  [ -n "$post_file" ] || continue
  if [ "$post_file" = "$md_file" ]; then
    found=1
    newer_file=$prev_file
    continue
  fi
  if [ "$found" -eq 1 ]; then
    older_file=$post_file
    break
  fi
  prev_file=$post_file
done < "$posts_tmp"
rm -f "$posts_tmp"

post_nav_html=$(blog_post_nav_html "$(post_nav_json "$newer_file" "Newer" "post-nav-prev")" "$(post_nav_json "$older_file" "Older" "post-nav-next")")

post_menu_html=$(blog_post_page_menu_html)

rel=$(blog_post_rel_path_for_file "$md_file" 2>/dev/null || printf '')
rel=${rel#posts/}
rel_html=${rel%.md}.html
html_file="$blog_site_root/build/pages/posts/$rel_html"

if [ -f "$html_file" ]; then
  tmp_injected=$(mktemp "${TMPDIR:-/tmp}/blog-open-post-html.XXXXXX")
  awk -v menu="$post_menu_html" -v extras="$post_end_tags_html$post_nav_html" '
    BEGIN { inserted_menu = 0; inserted_extras = 0 }
    {
      line = $0
      if (inserted_extras == 0 && index(line, "</article>") > 0) {
        print extras
        inserted_extras = 1
      }
      print line
      if (inserted_menu == 0 && index(line, "<div class=\"post-head\">") > 0) {
        print menu
        inserted_menu = 1
      }
    }
    END {
      if (inserted_extras == 0) {
        print extras
      }
    }
  ' "$html_file" > "$tmp_injected"
  http-status 200 "OK"
  http-header "Content-Type" "text/html; charset=utf-8"
  http-end-headers
  cat "$tmp_injected"
  rm -f "$tmp_injected"
  exit 0
fi

# Fallback: render page on-demand via CGI so links remain functional and
# already match the final post-card structure on first paint.
if command -v pandoc >/dev/null 2>&1; then
  tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/blog-open-post.XXXXXX")
  trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM

  includes_dir="$blog_site_root/site/includes"
  nav_file="$includes_dir/nav.md"
  footer_file="$includes_dir/footer.md"
  head_file="$includes_dir/head.html"
  body_md="$tmp_dir/body.md"
  body_html_file="$tmp_dir/body.html"
  blog_read_markdown_body "$md_file" > "$body_md"

  pandoc \
    --from markdown+raw_html \
    --to html5 \
    --output="$body_html_file" \
    "$body_md" >/dev/null 2>&1 || true

  if [ -f "$body_html_file" ]; then
    title=$(blog_read_front_matter_value "$md_file" title 2>/dev/null || printf '')
    author=$(blog_post_author_display_for_file "$md_file")
    if [ -z "$author" ]; then
      author='Blog Author'
    fi
    published_at=$(blog_read_front_matter_value "$md_file" published_at 2>/dev/null || printf '')
    published_date=$(blog_iso_to_human_date "$published_at")
    published_timestamp=$(blog_iso_to_human_timestamp "$published_at")
    post_type=$(blog_read_front_matter_value "$md_file" post_type 2>/dev/null || printf '')
    if [ -z "$post_type" ]; then
      post_type=$(blog_read_front_matter_value "$md_file" type 2>/dev/null || printf '')
    fi
    post_type=$(blog_normalize_post_type "$post_type")
    body_plain=$(blog_read_markdown_body "$md_file" 2>/dev/null || printf '')
    title=$(blog_effective_post_title "$title" "$body_plain" "$post_type")
    word_count=$(blog_word_count "$body_plain")
    reading_minutes=$(blog_estimated_read_minutes "$word_count")

    safe_title=$(blog_html_escape "$title")
    post_header_meta_html=$(blog_post_header_meta_html "$author" "$reading_minutes" "$published_date" "$published_timestamp")

    http-status 200 "OK"
    http-header "Content-Type" "text/html; charset=utf-8"
    http-end-headers
    cat <<HTML
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>$safe_title</title>
  <style>html{background:#f3e9d7;}body{background:transparent;color:#2f2517;}</style>
  <link rel="stylesheet" href="/static/style.css?v=20260408-stylev1">
  <script src="/static/js/htmx.min.js"></script>
  <script src="/static/js/idiomorph-ext.min.js"></script>
HTML
    if [ -f "$head_file" ]; then
      cat "$head_file"
    fi
    cat <<HTML
</head>
<body>
HTML
    if [ -f "$nav_file" ]; then
      cat "$nav_file"
    fi
    cat <<HTML
  <article class="post-item post-single-item">
    <div class="post-head">
      $post_menu_html
      <div class="post-head-main">
        <h1 id="main-content" class="post-title">$safe_title</h1>
        $post_header_meta_html
      </div>
    </div>
    <div class="post-single-body">
HTML
    cat "$body_html_file"
    cat <<HTML
    </div>
    $post_end_tags_html
    $post_nav_html
  </article>
HTML
    if [ -f "$footer_file" ]; then
      cat "$footer_file"
    fi
    cat <<HTML
</body>
</html>
HTML
    exit 0
  fi
fi

# Final fallback: render a minimal HTML page without pandoc/build so
# post links never break while markdown exists.
title=$(blog_read_front_matter_value "$md_file" title 2>/dev/null || printf '')
post_type=$(blog_read_front_matter_value "$md_file" post_type 2>/dev/null || printf '')
if [ -z "$post_type" ]; then
  post_type=$(blog_read_front_matter_value "$md_file" type 2>/dev/null || printf '')
fi
post_type=$(blog_normalize_post_type "$post_type")
body=$(blog_read_markdown_body "$md_file" 2>/dev/null || printf '')
title=$(blog_effective_post_title "$title" "$body" "$post_type")
safe_title=$(printf '%s' "$title" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g')
safe_body=$(printf '%s' "$body" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g')

http-status 200 "OK"
http-header "Content-Type" "text/html; charset=utf-8"
http-end-headers
cat <<HTML
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>$safe_title</title>
  <style>html{background:#f3e9d7;}body{background:transparent;color:#2f2517;}</style>
  <link rel="stylesheet" href="/static/style.css?v=20260408-stylev1">
</head>
<body>
  <main id="main-content" style="max-width: 56rem; margin: 1.5rem auto; padding: 0 1rem;">
    <article class="post-item post-single-item">
      <div class="post-head">$post_menu_html</div>
      <h1>$safe_title</h1>
      <div class="post-single-body"><pre style="white-space: pre-wrap; line-height: 1.55; background: transparent; border: 0; padding: 0;">$safe_body</pre></div>
      $post_end_tags_html
      $post_nav_html
    </article>
  </main>
</body>
</html>
HTML
