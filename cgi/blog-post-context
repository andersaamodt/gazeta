#!/bin/sh
# Return JSON context for a post page (metadata + older/newer links).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_send_json_headers

requested_path=$(blog_param path)
if [ -z "$requested_path" ]; then
  requested_path=$(blog_param slug)
fi
if [ -z "$requested_path" ]; then
  blog_json_error "path is required" "invalid_request"
  exit 0
fi

current_file=$(blog_resolve_post_markdown_file "$requested_path" 2>/dev/null || printf '')
if [ -z "$current_file" ]; then
  blog_json_error "Invalid path" "invalid_path"
  exit 0
fi
if [ ! -f "$current_file" ] && blog_nostr_bridge_enabled; then
  blog_nostr_rebuild_derived >/dev/null 2>&1 || true
  current_file=$(blog_resolve_post_markdown_file "$requested_path" 2>/dev/null || printf '')
fi
if [ ! -f "$current_file" ]; then
  blog_json_error "Post not found" "not_found"
  exit 0
fi

visibility=$(blog_read_front_matter_value "$current_file" visibility 2>/dev/null || printf 'public')
if [ -z "$visibility" ]; then
  visibility=public
fi
if [ "$visibility" != "public" ]; then
  blog_json_error "Post not found" "not_found"
  exit 0
fi

post_json() {
  file=${1-}
  if [ -z "$file" ] || [ ! -f "$file" ]; then
    printf 'null'
    return 0
  fi

  title=$(blog_read_front_matter_value "$file" title 2>/dev/null || printf '')
  post_type=$(blog_read_front_matter_value "$file" post_type 2>/dev/null || printf '')
  if [ -z "$post_type" ]; then
    post_type=$(blog_read_front_matter_value "$file" type 2>/dev/null || printf '')
  fi
  post_type=$(blog_normalize_post_type "$post_type")
  author=$(blog_post_author_display_for_file "$file")
  if [ -z "$author" ]; then
    author='Blog Author'
  fi
  published_at=$(blog_read_front_matter_value "$file" published_at 2>/dev/null || printf '')
  published_date=$(blog_iso_to_human_date "$published_at")
  summary=$(blog_read_front_matter_value "$file" summary 2>/dev/null || printf '')
  tags_raw=$(blog_read_front_matter_value "$file" tags 2>/dev/null || printf '')
  tags_csv=$(printf '%s' "$tags_raw" | sed "s/^\[//;s/\]$//;s/\"//g;s/'//g")
  tags_norm=$(blog_normalize_tags "$tags_csv")
  tags_json=$(blog_tags_to_json_array "$tags_norm")
  nostr_event_id=$(blog_read_front_matter_value "$file" nostr_event_id 2>/dev/null || printf '')
  nostr_pubkey=$(blog_read_front_matter_value "$file" nostr_pubkey 2>/dev/null || printf '')
  nostr_kind=$(blog_read_front_matter_value "$file" nostr_kind 2>/dev/null || printf '')
  nostr_d=$(blog_read_front_matter_value "$file" nostr_d 2>/dev/null || printf '')
  nostr_uri=$(blog_read_front_matter_value "$file" nostr_uri 2>/dev/null || printf '')
  if [ -z "$nostr_event_id$nostr_pubkey$nostr_kind$nostr_d$nostr_uri" ] && blog_nostr_bridge_enabled; then
    existing_nostr_event=$(blog_nostr_post_existing_event_json_for_file "$file" 2>/dev/null || printf '')
    if [ -n "$existing_nostr_event" ]; then
      nostr_event_id=$(printf '%s\n' "$existing_nostr_event" | jq -r '.id // empty' 2>/dev/null || printf '')
      nostr_pubkey=$(printf '%s\n' "$existing_nostr_event" | jq -r '.pubkey // empty' 2>/dev/null || printf '')
      nostr_kind=$(printf '%s\n' "$existing_nostr_event" | jq -r '.kind // empty' 2>/dev/null || printf '')
      nostr_d=$(printf '%s\n' "$existing_nostr_event" | jq -r '[.tags[]? | select(type=="array" and length>=2 and .[0]=="d") | .[1]] | first // empty' 2>/dev/null || printf '')
    fi
  fi
  nostr_address=''
  nostr_relays_json='[]'
  if [ -n "$nostr_pubkey" ] && [ -n "$nostr_kind" ] && [ -n "$nostr_d" ]; then
    nostr_address=$(blog_nostr_event_address "$nostr_kind" "$nostr_pubkey" "$nostr_d")
  fi
  if [ -n "$nostr_event_id$nostr_pubkey$nostr_kind$nostr_d$nostr_uri" ]; then
    nostr_relays_json=$(blog_nostr_list_file_to_json_array "$blog_nostr_relays_file" 2>/dev/null || printf '[]')
  fi
  if [ -z "$nostr_uri" ] && [ -n "$nostr_address" ]; then
    nostr_uri="nostr:$nostr_address"
  fi
  body=$(blog_read_markdown_body "$file")
  title=$(blog_effective_post_title "$title" "$body" "$post_type")
  word_count=$(blog_word_count "$body")
  reading_minutes=$(blog_estimated_read_minutes "$word_count")
  url=$(blog_rel_post_html_url "$file")
  rel=${file#"$blog_posts_dir/"}
  rel_slug_raw=${rel%.md}
  rel_slug=$(blog_public_post_slug_from_rel "$rel_slug_raw" 2>/dev/null || printf '%s' "$rel_slug_raw")
  rel_path="posts/${rel_slug}"

  printf '{'
  printf '"title":"%s",' "$(blog_json_escape "$title")"
  printf '"author":"%s",' "$(blog_json_escape "$author")"
  printf '"url":"%s",' "$(blog_json_escape "$url")"
  printf '"path":"%s",' "$(blog_json_escape "$rel_path")"
  printf '"published_at":"%s",' "$(blog_json_escape "$published_at")"
  printf '"published_date":"%s",' "$(blog_json_escape "$published_date")"
  printf '"summary":"%s",' "$(blog_json_escape "$summary")"
  printf '"word_count":%s,' "$word_count"
  printf '"reading_minutes":%s,' "$reading_minutes"
  printf '"tags":%s,' "$tags_json"
  if [ -n "$nostr_event_id$nostr_pubkey$nostr_kind$nostr_d$nostr_uri" ]; then
    printf '"nostr":{'
    printf '"id":"%s",' "$(blog_json_escape "$nostr_event_id")"
    printf '"pubkey":"%s",' "$(blog_json_escape "$nostr_pubkey")"
    printf '"kind":"%s",' "$(blog_json_escape "$nostr_kind")"
    printf '"d":"%s",' "$(blog_json_escape "$nostr_d")"
    printf '"address":"%s",' "$(blog_json_escape "$nostr_address")"
    printf '"uri":"%s",' "$(blog_json_escape "$nostr_uri")"
    printf '"relays":%s' "$nostr_relays_json"
    printf '}'
  else
    printf '"nostr":null'
  fi
  printf '}'
}

posts_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-post-context.XXXXXX")
blog_collect_public_posts "$posts_tmp"

found=0
newer=""
older=""
prev=""
while IFS= read -r post_file; do
  [ -n "$post_file" ] || continue
  if [ "$post_file" = "$current_file" ]; then
    found=1
    newer=$prev
    continue
  fi
  if [ "$found" -eq 1 ]; then
    older=$post_file
    break
  fi
  prev=$post_file
done < "$posts_tmp"

if [ "$found" -ne 1 ]; then
  rm -f "$posts_tmp"
  blog_json_error "Post not found" "not_found"
  exit 0
fi

printf '{"success":true,'
printf '"current":'
post_json "$current_file"
printf ','
printf '"zap_config":%s,' "$(blog_zaps_config_json)"
printf '"newer":'
post_json "$newer"
printf ','
printf '"older":'
post_json "$older"
printf '}\n'

rm -f "$posts_tmp"
