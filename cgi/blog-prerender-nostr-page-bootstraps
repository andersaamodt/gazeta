#!/bin/sh
# Build-time prerender of canonical Nostr page payloads for first-paint bootstrap.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
if [ -z "${WIZARDRY_SITES_DIR:-}" ] || [ -z "${WIZARDRY_SITE_NAME:-}" ]; then
  script_site_root=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
  : "${WIZARDRY_SITES_DIR:=$(dirname "$script_site_root")}"
  : "${WIZARDRY_SITE_NAME:=$(basename "$script_site_root")}"
  export WIZARDRY_SITES_DIR WIZARDRY_SITE_NAME
fi
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init

bootstrap_dir="$blog_site_root/site/static/nostr-page-bootstrap"
mkdir -p "$bootstrap_dir"

sites_dir=${WIZARDRY_SITES_DIR:-$blog_sites_dir}
site_name=${WIZARDRY_SITE_NAME:-$blog_site_name}

manifest_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-manifest.XXXXXX")
trap 'rm -f "$manifest_tmp"' EXIT HUP INT TERM
: > "$manifest_tmp"

is_prerender_type() {
  case "$1" in
    list|icon-gallery|nip23|blog|contact|public-ranking)
      return 0
      ;;
  esac
  return 1
}

is_local_embed_type() {
  case "$1" in
    overworld)
      return 0
      ;;
  esac
  return 1
}

render_payload_json() {
  slug_in=${1-}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1

  raw_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-raw.XXXXXX")
  body_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-body.XXXXXX")
  (
    env \
      "REQUEST_METHOD=GET" \
      "CONTENT_LENGTH=0" \
      "QUERY_STRING=page_slug=$slug" \
      "WIZARDRY_SITES_DIR=$sites_dir" \
      "WIZARDRY_SITE_NAME=$site_name" \
      "$SCRIPT_DIR/blog-get-nostr-page"
  ) > "$raw_tmp" 2>/dev/null || {
    rm -f "$raw_tmp" "$body_tmp"
    return 1
  }

  awk '
    BEGIN { in_body = 0 }
    {
      line = $0
      sub(/\r$/, "", line)
      if (in_body == 1) {
        print line
      } else if (line == "") {
        in_body = 1
      }
    }
  ' "$raw_tmp" > "$body_tmp"
  if [ ! -s "$body_tmp" ]; then
    cp "$raw_tmp" "$body_tmp"
  fi
  payload=$(cat "$body_tmp")
  rm -f "$raw_tmp" "$body_tmp"

  if ! printf '%s\n' "$payload" | jq -e --arg slug "$slug" '
    (.success == true) and
    ((.slug // "") | tostring == $slug) and
    ((.page_type // "") | tostring | ascii_downcase | IN("list", "icon-gallery", "nip23", "blog", "contact", "public-ranking"))
  ' >/dev/null 2>&1; then
    return 1
  fi

  printf '%s\n' "$payload"
}

render_blog_posts_json() {
  raw_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-posts-raw.XXXXXX")
  body_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-posts-body.XXXXXX")
  (
    env \
      "REQUEST_METHOD=GET" \
      "CONTENT_LENGTH=0" \
      "WIZARDRY_SITES_DIR=$sites_dir" \
      "WIZARDRY_SITE_NAME=$site_name" \
      "$SCRIPT_DIR/blog-list-public-posts"
  ) > "$raw_tmp" 2>/dev/null || {
    rm -f "$raw_tmp" "$body_tmp"
    return 1
  }

  awk '
    BEGIN { in_body = 0 }
    {
      line = $0
      sub(/\r$/, "", line)
      if (in_body == 1) {
        print line
      } else if (line == "") {
        in_body = 1
      }
    }
  ' "$raw_tmp" > "$body_tmp"
  if [ ! -s "$body_tmp" ]; then
    cp "$raw_tmp" "$body_tmp"
  fi
  payload=$(cat "$body_tmp")
  rm -f "$raw_tmp" "$body_tmp"

  if ! printf '%s\n' "$payload" | jq -e '
    (.success == true) and ((.posts // null) != null) and ((.posts | type) == "array")
  ' >/dev/null 2>&1; then
    return 1
  fi

  printf '%s\n' "$payload"
}

write_bootstrap_js() {
  slug_in=${1-}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1
  payload_json=${2-}
  [ -n "$payload_json" ] || return 1

  js_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-js.XXXXXX")
  {
    printf '%s\n' '(function () {'
    printf '%s\n' '  window.__wizardryNostrPageBootstrap = window.__wizardryNostrPageBootstrap || {};'
    printf '  var slug = %s;' "$(printf '%s\n' "$slug" | jq -R .)"
    printf '%s\n' ''
    printf '%s\n' '  var payload = '
    printf '%s' "$payload_json"
    printf '%s\n' ';'
    printf '%s\n' '  window.__wizardryNostrPageBootstrap[slug] = payload;'
    cat <<'EOBOOT'

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function markdownInline(value) {
    var text = escapeHtml(value || '');
    return text.replace(/\*([^*\n]+)\*/g, '<em>$1</em>');
  }

  function voteArrow(direction) {
    var path = String(direction || '') === 'down'
      ? 'M12 20 4.5 10.8h4.25V4h6.5v6.8h4.25L12 20Z'
      : 'M12 4 19.5 13.2h-4.25V20h-6.5v-6.8H4.5L12 4Z';
    return '<svg class="list-entry-vote-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="' + path + '" fill="currentColor"/></svg>';
  }

  function overflowMenuIcon() {
    return '<svg class="overflow-menu-icon-svg" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="5.5" r="1.9" fill="currentColor"/><circle cx="12" cy="12" r="1.9" fill="currentColor"/><circle cx="12" cy="18.5" r="1.9" fill="currentColor"/></svg>';
  }

  function hasLikelyAuthenticatedSession() {
    try {
      return !!(localStorage.getItem('session_token') && localStorage.getItem('csrf_token'));
    } catch (_err) {
      return false;
    }
  }

  function paintListFirstFrame() {
    if (!payload || !payload.state || (payload.page_type !== 'list' && payload.page_type !== 'icon-gallery')) {
      return false;
    }
    var root = document.getElementById('list-page-root') || document.getElementById('icon-gallery-root');
    if (!root) {
      return false;
    }
    var content = document.getElementById('list-page-content');
    if (!content || content.children.length) {
      return false;
    }
    var state = payload.state || {};
    var elements = Array.isArray(state.elements) ? state.elements : (Array.isArray(state.entries) ? state.entries : []);
    var allowSubmissions = !!state.allow_signed_in_submissions;
    var allowVotes = !!state.allow_signed_in_votes;
    var signedIn = hasLikelyAuthenticatedSession();
    var html = '';
    if (allowSubmissions) {
      html += '<section class="list-public-submit" aria-label="Add list entry"><div class="list-public-submit-inline"><input type="text" id="list-public-submit-title" placeholder="New entry"><button type="button" class="list-admin-primary-btn list-public-submit-add" data-list-public-action="submit">Add</button></div></section>';
    }
    if (elements.length) {
      html += '<ul class="list-entries">';
      elements.forEach(function (entry) {
        var line = String(entry && entry.markdown || '').trim();
        if (!line) {
          return;
        }
        var entryId = String(entry && entry._list_entry_id || '');
        var voteControls = '';
        if (allowVotes && entryId) {
          var viewerVote = Number(entry && entry.viewer_vote || 0) || 0;
          var viewerCanVoteNow = !entry || entry.viewer_can_vote_now !== false;
          var upvoteClass = 'list-entry-vote-btn is-upvote' + (viewerVote > 0 ? (viewerCanVoteNow ? ' is-stale' : ' is-active') : '');
          var downvoteClass = 'list-entry-vote-btn is-downvote' + (viewerVote < 0 ? (viewerCanVoteNow ? ' is-stale' : ' is-active') : '');
          voteControls = '<span class="list-entry-vote-controls" data-list-entry-id="' + escapeHtml(entryId) + '" aria-label="Entry score">' +
            '<button type="button" class="' + upvoteClass + '" data-list-public-action="vote" data-list-entry-id="' + escapeHtml(entryId) + '" data-list-vote-value="1" aria-label="Upvote" title="Upvote">' + voteArrow('up') + '</button>' +
            '<span class="list-entry-score" title="Score">' + escapeHtml(String(Number(entry && entry.list_score || 0) || 0)) + '</span>' +
            '<button type="button" class="' + downvoteClass + '" data-list-public-action="vote" data-list-entry-id="' + escapeHtml(entryId) + '" data-list-vote-value="-1" aria-label="Downvote" title="Downvote">' + voteArrow('down') + '</button>' +
          '</span>';
        }
        var rightMeta = '';
        if (signedIn) {
          var menuUid = String(entry && (entry._public_entry_id || entry._list_entry_id) || '');
          if (menuUid) {
            rightMeta = '<span class="list-entry-meta-right"><span class="list-entry-read-menu list-inline-row-menu-wrap"><button type="button" class="list-inline-row-menu-trigger" data-list-read-action="toggle-menu" data-element-uid="' + escapeHtml(menuUid) + '" aria-label="Row actions" aria-haspopup="menu" aria-expanded="false">' + overflowMenuIcon() + '</button></span></span>';
          }
        }
        html += '<li class="list-entry-line"><div class="list-entry-first-line' + (voteControls ? ' has-votes' : '') + '">' + voteControls + '<span class="list-entry-main-inline"><span class="list-entry-markdown">' + markdownInline(line) + '</span></span>' + rightMeta + '</div></li>';
      });
      html += '</ul>';
    } else {
      html += '<p class="list-page-empty-state">No content yet.</p>';
    }
    content.innerHTML = html;
    root.classList.remove('is-loading');
    root.setAttribute('data-prerender-painted', 'true');
    try {
      window.__wizardryPageInitialContentReady = true;
      window.dispatchEvent(new CustomEvent('blog-page-initial-content-ready', { detail: { slug: slug, prerendered: true } }));
    } catch (_err) {}
    try {
      var gate = window.__wizardryHydration;
      if (gate && typeof gate.markPageReady === 'function') {
        gate.markPageReady();
      }
    } catch (_gateErr) {}
    return true;
  }

  if (document.getElementById('list-page-root') || document.getElementById('icon-gallery-root')) {
    paintListFirstFrame();
  } else if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', paintListFirstFrame, { once: true });
  } else {
    paintListFirstFrame();
  }
EOBOOT
    printf '%s\n' '})();'
  } > "$js_tmp"

  out_file="$bootstrap_dir/$slug.js"
  mv "$js_tmp" "$out_file"
  chmod 644 "$out_file" 2>/dev/null || true
  printf '%s\n' "$slug" >> "$manifest_tmp"
}

write_local_embed_bootstrap_js() {
  slug_in=${1-}
  page_type=${2-local}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1
  js_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-local-js.XXXXXX")
  {
    printf '%s\n' '(function () {'
    printf '%s\n' '  window.__wizardryNostrPageBootstrap = window.__wizardryNostrPageBootstrap || {};'
    printf '  window.__wizardryNostrPageBootstrap[%s] = {' "$(printf '%s\n' "$slug" | jq -R .)"
    printf 'success:true,slug:%s,page_type:%s,local_embed:true' "$(printf '%s\n' "$slug" | jq -R .)" "$(printf '%s\n' "$page_type" | jq -R .)"
    printf '%s\n' '};'
    printf '%s\n' '})();'
  } > "$js_tmp"
  out_file="$bootstrap_dir/$slug.js"
  mv "$js_tmp" "$out_file"
  chmod 644 "$out_file" 2>/dev/null || true
  printf '%s\n' "$slug" >> "$manifest_tmp"
}

cfg_json=$(blog_nostr_pages_load_json)
printf '%s\n' "$cfg_json" | jq -r '.pages[]? | [(.slug // ""), (.type // "list")] | @tsv' 2>/dev/null | while IFS="$(printf '\t')" read -r raw_slug raw_type || [ -n "$raw_slug" ]; do
  slug=$(blog_nostr_page_slug "$raw_slug")
  page_type=$(printf '%s' "${raw_type-}" | tr '[:upper:]' '[:lower:]')
  [ -n "$slug" ] || continue
  if is_local_embed_type "$page_type"; then
    write_local_embed_bootstrap_js "$slug" "$page_type" || true
    continue
  fi
  is_prerender_type "$page_type" || continue
  payload_json=$(render_payload_json "$slug" 2>/dev/null || printf '')
  [ -n "$payload_json" ] || continue
  if [ "$page_type" = "blog" ]; then
    posts_json=$(render_blog_posts_json 2>/dev/null || printf '')
    if [ -n "$posts_json" ]; then
      payload_json=$(printf '%s\n' "$payload_json" | jq -c --argjson posts "$posts_json" '. + {bootstrap_posts: ($posts.posts // [])}' 2>/dev/null || printf '%s\n' "$payload_json")
    fi
  fi
  write_bootstrap_js "$slug" "$payload_json" || true
done

if [ -d "$bootstrap_dir" ]; then
  find "$bootstrap_dir" -type f -name '*.js' ! -name '._*' 2>/dev/null | while IFS= read -r js_file || [ -n "$js_file" ]; do
    file_name=$(basename "$js_file")
    slug=${file_name%.js}
    if ! grep -Fqx "$slug" "$manifest_tmp" 2>/dev/null; then
      rm -f "$js_file"
    fi
  done
fi
