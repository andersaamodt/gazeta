#!/bin/sh
# Build-time prerender of canonical Nostr page payloads for first-paint bootstrap.

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
if [ -z "${WIZARDRY_SITES_DIR:-}" ] || [ -z "${WIZARDRY_SITE_NAME:-}" ]; then
  script_site_root=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd -P)
  : "${WIZARDRY_SITES_DIR:=$(dirname "$script_site_root")}"
  : "${WIZARDRY_SITE_NAME:=$(basename "$script_site_root")}"
  export WIZARDRY_SITES_DIR WIZARDRY_SITE_NAME
fi
. "$SCRIPT_DIR/blog-lib.sh"
. "$SCRIPT_DIR/blog-list-common.sh"
. "$SCRIPT_DIR/blog-public-ranking-common.sh"
. "$SCRIPT_DIR/blog-nostr-pages-common.sh"

blog_init

bootstrap_dir="$blog_site_root/site/static/nostr-page-bootstrap"
mkdir -p "$bootstrap_dir"

sites_dir=${WIZARDRY_SITES_DIR:-$blog_sites_dir}
site_name=${WIZARDRY_SITE_NAME:-$blog_site_name}

manifest_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-manifest.XXXXXX")
trap 'rm -f "$manifest_tmp"' EXIT HUP INT TERM
: > "$manifest_tmp"

is_prerender_type() {
  case "$1" in
    list|icon-gallery|nip23|blog|contact|public-ranking)
      return 0
      ;;
  esac
  return 1
}

is_local_embed_type() {
  case "$1" in
    overworld)
      return 0
      ;;
  esac
  return 1
}

render_payload_json() {
  slug_in=${1-}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1

  raw_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-raw.XXXXXX")
  body_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-body.XXXXXX")
  (
    env \
      "REQUEST_METHOD=GET" \
      "CONTENT_LENGTH=0" \
      "QUERY_STRING=page_slug=$slug" \
      "WIZARDRY_SITES_DIR=$sites_dir" \
      "WIZARDRY_SITE_NAME=$site_name" \
      "$SCRIPT_DIR/blog-get-nostr-page"
  ) > "$raw_tmp" 2>/dev/null || {
    rm -f "$raw_tmp" "$body_tmp"
    return 1
  }

  awk '
    BEGIN { in_body = 0 }
    {
      line = $0
      sub(/\r$/, "", line)
      if (in_body == 1) {
        print line
      } else if (line == "") {
        in_body = 1
      }
    }
  ' "$raw_tmp" > "$body_tmp"
  if [ ! -s "$body_tmp" ]; then
    cp "$raw_tmp" "$body_tmp"
  fi
  payload=$(cat "$body_tmp")
  rm -f "$raw_tmp" "$body_tmp"

  if ! printf '%s\n' "$payload" | jq -e --arg slug "$slug" '
    (.success == true) and
    ((.slug // "") | tostring == $slug) and
    ((.page_type // "") | tostring | ascii_downcase | IN("list", "icon-gallery", "nip23", "blog", "contact", "public-ranking"))
  ' >/dev/null 2>&1; then
    return 1
  fi

  printf '%s\n' "$payload"
}

render_blog_posts_json() {
  raw_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-posts-raw.XXXXXX")
  body_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-posts-body.XXXXXX")
  (
    env \
      "REQUEST_METHOD=GET" \
      "CONTENT_LENGTH=0" \
      "WIZARDRY_SITES_DIR=$sites_dir" \
      "WIZARDRY_SITE_NAME=$site_name" \
      "$SCRIPT_DIR/blog-list-public-posts"
  ) > "$raw_tmp" 2>/dev/null || {
    rm -f "$raw_tmp" "$body_tmp"
    return 1
  }

  awk '
    BEGIN { in_body = 0 }
    {
      line = $0
      sub(/\r$/, "", line)
      if (in_body == 1) {
        print line
      } else if (line == "") {
        in_body = 1
      }
    }
  ' "$raw_tmp" > "$body_tmp"
  if [ ! -s "$body_tmp" ]; then
    cp "$raw_tmp" "$body_tmp"
  fi
  payload=$(cat "$body_tmp")
  rm -f "$raw_tmp" "$body_tmp"

  if ! printf '%s\n' "$payload" | jq -e '
    (.success == true) and ((.posts // null) != null) and ((.posts | type) == "array")
  ' >/dev/null 2>&1; then
    return 1
  fi

  printf '%s\n' "$payload"
}

public_ranking_prerender_nodes_json() {
  state_json=${1-}
  tmp=$(mktemp "${TMPDIR:-/tmp}/blog-ranking-prerender-nodes.XXXXXX")
  printf '%s\n' "$state_json" | jq -r '.root_refs[]? // empty' 2>/dev/null | while IFS= read -r coord || [ -n "$coord" ]; do
    [ -n "$coord" ] || continue
    event_json=$(blog_public_ranking_latest_node_event_json "$coord" 2>/dev/null || printf '')
    [ -n "$event_json" ] || continue
    printf '%s\n' "$event_json" | jq -c --arg coord "$coord" '
      def tag($k): ([.tags[]? | select(type=="array" and length>=2 and .[0]==$k) | .[1]] | first // "");
      {
        coordinate: $coord,
        kind: (.kind // 0),
        pubkey: (.pubkey // ""),
        created_at: (.created_at // 0),
        title: (tag("title") | if length > 0 then . else $coord end),
        summary: tag("summary"),
        content: (.content // ""),
        status: (tag("status") | if length > 0 then . else "approved" end),
        url: tag("url"),
        post_ref: tag("r"),
        author: tag("author"),
        parent: tag("parent"),
        ranking: tag("ranking"),
        metrics: { enthusiasm: 0, support: 0, momentum: 0, intensity: 0 },
        node_kind: (if (.kind // 0) == 30040 then "group" else "entry" end)
      }
    ' 2>/dev/null || true
  done > "$tmp"
  if [ -s "$tmp" ]; then
    jq -s '.' "$tmp" 2>/dev/null || printf '[]\n'
  else
    printf '[]\n'
  fi
  rm -f "$tmp"
}

fallback_payload_json() {
  slug_in=${1-}
  page_type=${2-}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1
  state_json=''
  case "$page_type" in
    public-ranking)
      canonical_event=$(blog_nostr_public_ranking_latest_event_json "$slug" 2>/dev/null || printf '')
      if [ -n "$canonical_event" ]; then
        state_json=$(blog_public_ranking_state_from_event_json "$slug" "$canonical_event" 2>/dev/null || printf '')
      fi
      if [ -z "$state_json" ]; then
        state_json=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || printf '')
      fi
      [ -n "$state_json" ] || state_json=$(blog_public_ranking_default_state_json "$slug")
      nodes_json=$(public_ranking_prerender_nodes_json "$state_json")
      state_json=$(printf '%s\n' "$state_json" | jq -c --argjson nodes "$nodes_json" '. + {nodes: $nodes}' 2>/dev/null || printf '%s\n' "$state_json")
      ;;
    contact)
      state_json=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || blog_contact_default_state_json "$slug")
      ;;
    nip23|blog)
      state_json=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || blog_nip23_default_state_json "$slug" "$page_type")
      ;;
    list|icon-gallery)
      state_json=$(blog_nostr_page_load_draft_state_json "$slug" "$page_type" 2>/dev/null || blog_list_default_state_json "$slug")
      ;;
    *)
      return 1
      ;;
  esac
  jq -cn --arg slug "$slug" --arg page_type "$page_type" --argjson state "$state_json" '{
    success: true,
    slug: $slug,
    page_type: $page_type,
    is_admin: false,
    view_mode: "static-fallback",
    canonical_exists: false,
    draft_exists: true,
    draft_differs: false,
    state: $state,
    canonical_state: $state,
    validation: { errors: [], warnings: [], can_publish: true }
  }'
}

write_bootstrap_js() {
  slug_in=${1-}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1
  payload_json=${2-}
  [ -n "$payload_json" ] || return 1
  signature=$(blog_nostr_prerender_signature "$payload_json")
  payload_json=$(printf '%s\n' "$payload_json" | jq -c --arg signature "$signature" '. + {prerender_signature: $signature}' 2>/dev/null || printf '%s\n' "$payload_json")

  js_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-js.XXXXXX")
  {
    printf '%s\n' '(function () {'
    printf '%s\n' '  window.__wizardryNostrPageBootstrap = window.__wizardryNostrPageBootstrap || {};'
    printf '  var slug = %s;' "$(printf '%s\n' "$slug" | jq -R .)"
    printf '%s\n' ''
    printf '%s\n' '  var payload = '
    printf '%s' "$payload_json"
    printf '%s\n' ';'
    printf '%s\n' '  window.__wizardryNostrPageBootstrap[slug] = payload;'
    printf '%s\n' '})();'
  } > "$js_tmp"

  out_file="$bootstrap_dir/$slug.js"
  mv "$js_tmp" "$out_file"
  chmod 644 "$out_file" 2>/dev/null || true
  printf '%s\n' "$slug" >> "$manifest_tmp"
}

write_local_embed_bootstrap_js() {
  slug_in=${1-}
  page_type=${2-local}
  slug=$(blog_nostr_page_slug "$slug_in")
  [ -n "$slug" ] || return 1
  title=$(blog_nostr_page_default_title "$slug" "$page_type")
  payload_json=$(jq -cn --arg slug "$slug" --arg page_type "$page_type" --arg title "$title" '{
    success: true,
    slug: $slug,
    page_type: $page_type,
    local_embed: true,
    state: { title: $title, content: "" }
  }' 2>/dev/null || printf '')
  signature=$(blog_nostr_prerender_signature "$payload_json")
  js_tmp=$(mktemp "${TMPDIR:-/tmp}/blog-bootstrap-local-js.XXXXXX")
  {
    printf '%s\n' '(function () {'
    printf '%s\n' '  window.__wizardryNostrPageBootstrap = window.__wizardryNostrPageBootstrap || {};'
    printf '  window.__wizardryNostrPageBootstrap[%s] = {' "$(printf '%s\n' "$slug" | jq -R .)"
    printf 'success:true,slug:%s,page_type:%s,local_embed:true,prerender_signature:%s,state:{title:%s,content:""}' "$(printf '%s\n' "$slug" | jq -R .)" "$(printf '%s\n' "$page_type" | jq -R .)" "$(printf '%s\n' "$signature" | jq -R .)" "$(printf '%s\n' "$title" | jq -R .)"
    printf '%s\n' '};'
    printf '%s\n' '})();'
  } > "$js_tmp"
  out_file="$bootstrap_dir/$slug.js"
  mv "$js_tmp" "$out_file"
  chmod 644 "$out_file" 2>/dev/null || true
  printf '%s\n' "$slug" >> "$manifest_tmp"
}

cfg_json=$(blog_nostr_pages_load_json)
printf '%s\n' "$cfg_json" | jq -r '.pages[]? | [(.slug // ""), (.type // "list")] | @tsv' 2>/dev/null | while IFS="$(printf '\t')" read -r raw_slug raw_type || [ -n "$raw_slug" ]; do
  slug=$(blog_nostr_page_slug "$raw_slug")
  page_type=$(printf '%s' "${raw_type-}" | tr '[:upper:]' '[:lower:]')
  [ -n "$slug" ] || continue
  if is_local_embed_type "$page_type"; then
    local_payload=$(jq -cn --arg slug "$slug" --arg page_type "$page_type" --arg title "$(blog_nostr_page_default_title "$slug" "$page_type")" '{
      success: true,
      slug: $slug,
      page_type: $page_type,
      local_embed: true,
      state: { title: $title, content: "" }
    }' 2>/dev/null || printf '')
    if [ -n "$local_payload" ]; then
      blog_nostr_page_write_prerendered_source "$slug" "$page_type" "$local_payload" >/dev/null 2>&1 || true
    fi
    write_local_embed_bootstrap_js "$slug" "$page_type" || true
    continue
  fi
  is_prerender_type "$page_type" || continue
  payload_json=$(render_payload_json "$slug" 2>/dev/null || printf '')
  if [ -z "$payload_json" ]; then
    payload_json=$(fallback_payload_json "$slug" "$page_type" 2>/dev/null || printf '')
  fi
  [ -n "$payload_json" ] || continue
  if [ "$page_type" = "blog" ]; then
    posts_json=$(render_blog_posts_json 2>/dev/null || printf '')
    if [ -n "$posts_json" ]; then
      payload_json=$(printf '%s\n' "$payload_json" | jq -c --argjson posts "$posts_json" '. + {bootstrap_posts: ($posts.posts // [])}' 2>/dev/null || printf '%s\n' "$payload_json")
    fi
  fi
  blog_nostr_page_write_prerendered_source "$slug" "$page_type" "$payload_json" >/dev/null 2>&1 || true
  write_bootstrap_js "$slug" "$payload_json" || true
done

if [ -d "$bootstrap_dir" ]; then
  find "$bootstrap_dir" -type f -name '*.js' ! -name '._*' 2>/dev/null | while IFS= read -r js_file || [ -n "$js_file" ]; do
    file_name=$(basename "$js_file")
    slug=${file_name%.js}
    if ! grep -Fqx "$slug" "$manifest_tmp" 2>/dev/null; then
      rm -f "$js_file"
    fi
  done
fi
