#!/bin/sh
# Upload attachments for blog admin (admin only).

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd -P)
. "$SCRIPT_DIR/blog-lib.sh"

blog_init
blog_read_request_body
blog_send_json_headers

if ! blog_require_session true true; then
  exit 0
fi

filename=$(blog_param filename)
mime_type=$(blog_param mime_type)
data_b64=$(blog_param data_base64)
draft_id=$(blog_param draft_id)

if [ -z "$filename" ] || [ -z "$data_b64" ]; then
  blog_json_error "filename and data_base64 are required" "invalid_request"
  exit 0
fi

# Strip optional data URL prefix if sent.
case "$data_b64" in
  data:*\;base64,*) data_b64=${data_b64#*,} ;;
esac

# Soft size limit (~20MB raw decoded).
if [ ${#data_b64} -gt 28000000 ]; then
  blog_json_error "Upload too large" "file_too_large"
  exit 0
fi

created=$(blog_file_create_upload "$filename" "$mime_type" "$data_b64" "$draft_id" 2>/dev/null || printf '')
if [ -z "$created" ]; then
  blog_json_error "Failed to decode upload" "decode_error"
  exit 0
fi
file_id=$(printf '%s' "$created" | awk -F'\t' '{print $1}')
safe_name=$(printf '%s' "$created" | awk -F'\t' '{print $2}')
url=$(printf '%s' "$created" | awk -F'\t' '{print $3}')
printf '{"success":true,"file_id":"%s","url":"%s","filename":"%s","is_public":false}\n' \
  "$(blog_json_escape "$file_id")" \
  "$(blog_json_escape "$url")" \
  "$(blog_json_escape "$safe_name")"
